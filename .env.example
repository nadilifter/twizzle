# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================

# Environment identifier
# Values: production, staging, development, local
APP_ENVIRONMENT=local

# =============================================================================
# DATABASE
# =============================================================================

DATABASE_URL=postgresql://postgres:postgres@localhost:5434/leapfrog?schema=public

# =============================================================================
# AUTHENTICATION
# =============================================================================

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secure-secret-here

# OAuth Security
# Set to "false" to prevent OAuth accounts from linking to existing email accounts
# This improves security but requires users to sign up with OAuth first
# Default: true (allows linking for convenience)
ALLOW_OAUTH_ACCOUNT_LINKING=true

# Google OAuth (optional)
# Get these from Google Cloud Console: https://console.cloud.google.com/
# Note: Create separate OAuth apps for each environment due to different redirect URIs
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# PAYMENT PROCESSING (Adyen)
# =============================================================================

# Get these from your Adyen Customer Area: https://ca-test.adyen.com/
ADYEN_API_KEY=your-adyen-api-key
ADYEN_MERCHANT_ACCOUNT=your-merchant-account-name
# Environment: TEST for staging/dev/local, LIVE for production only
ADYEN_ENVIRONMENT=TEST
NEXT_PUBLIC_ADYEN_CLIENT_KEY=your-client-key-for-frontend
# Frontend environment: "test" for staging/dev, "live" for production
NEXT_PUBLIC_ADYEN_ENVIRONMENT=test
# Webhook HMAC key for signature verification
ADYEN_WEBHOOK_HMAC_KEY=your-hmac-key

# =============================================================================
# SMS (Twilio)
# =============================================================================

# Get these from your Twilio Console: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Use Messaging Service SID for A2P 10DLC compliance (recommended)
# Get this from Twilio Console > Messaging > Services
TWILIO_MESSAGING_SERVICE_SID=your-messaging-service-sid
# Fallback phone number if not using Messaging Service (E.164 format)
TWILIO_PHONE_NUMBER=+1234567890
# Environment: TEST for staging/dev/local, LIVE for production only
TWILIO_ENVIRONMENT=TEST
# Optional: Override webhook URL (defaults to NEXTAUTH_URL)
# TWILIO_WEBHOOK_URL=https://your-domain.com

# =============================================================================
# EMAIL (Amazon SES)
# =============================================================================

# AWS SES Region
AWS_SES_REGION=us-east-1

# From email address (must be verified in SES)
# Use the appropriate domain for your environment:
# - Production: noreply@uplifterinc.com
# - Staging: noreply@upliftergymnastics.com
# - Development: noreply@uplifterdev.com
# - Local: noreply@localhost (uses MailHog)
AWS_SES_FROM_EMAIL=noreply@localhost

# SES Configuration Set for bounce/complaint/delivery event tracking
# Routes SES events through your configuration for bounce handling
# - Staging: upliftergymnastics-pilot
# - Production: (set to your production configuration set)
# AWS_SES_CONFIGURATION_SET=

# For local development with MailHog, uncomment:
# SES_ENDPOINT=http://localhost:1025

# =============================================================================
# STORAGE (S3 / MinIO)
# =============================================================================

# Set to "true" to use S3 storage, "false" for local filesystem
USE_S3_STORAGE=false

# AWS S3 Configuration
AWS_S3_BUCKET=uplifter-assets-local
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# For local development with MinIO:
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# =============================================================================
# CACHING (Redis)
# =============================================================================

# Upstash Redis (for cloud environments)
# Get these from your Upstash Console: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# For local development with Docker Redis:
# REDIS_URL=redis://localhost:6379

# =============================================================================
# WEBHOOKS
# =============================================================================

# Optional: Tunnel URL for local webhook testing with ngrok
# WEBHOOK_TUNNEL_URL=https://abc123.ngrok.io

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warn, error (default: info in production, debug in development)
LOG_LEVEL=info

# =============================================================================
# FUTURE: STRIPE (Alternative payment processor)
# =============================================================================

# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/leapfrog?schema=public

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secure-secret-here

# OAuth Security
# Set to "false" to prevent OAuth accounts from linking to existing email accounts
# This improves security but requires users to sign up with OAuth first
# Default: true (allows linking for convenience)
ALLOW_OAUTH_ACCOUNT_LINKING=true

# Google OAuth (optional)
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Adyen Payment Processing
# Get these from your Adyen Customer Area: https://ca-test.adyen.com/
ADYEN_API_KEY=your-adyen-api-key
ADYEN_MERCHANT_ACCOUNT=your-merchant-account-name
ADYEN_ENVIRONMENT=TEST  # TEST or LIVE - use LIVE only for production payments
NEXT_PUBLIC_ADYEN_CLIENT_KEY=your-client-key-for-frontend

# Upstash Redis (for visitor analytics)
# Get these from your Upstash Console: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Logging
# Log level: debug, info, warn, error (default: info in production, debug in development)
LOG_LEVEL=info

# Add other environment variables below as needed

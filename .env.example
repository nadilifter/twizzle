# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================

# Environment identifier
# Values: production, staging, development, local
APP_ENVIRONMENT=local

# =============================================================================
# DATABASE
# =============================================================================

DATABASE_URL=postgresql://postgres:postgres@localhost:5434/leapfrog?schema=public
# For staging/production, add connection pool params to prevent connection exhaustion under load:
# DATABASE_URL=postgresql://user:pass@host:5432/leapfrog?connection_limit=10&pool_timeout=20

# =============================================================================
# AUTHENTICATION
# =============================================================================

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secure-secret-here

# OAuth Security
# Set to "false" to prevent OAuth accounts from linking to existing email accounts
# This improves security but requires users to sign up with OAuth first
# Default: true (allows linking for convenience)
ALLOW_OAUTH_ACCOUNT_LINKING=true

# Google OAuth (optional — used by regular users for login)
# Get these from Google Cloud Console: https://console.cloud.google.com/
# Note: Create separate OAuth apps for each environment due to different redirect URIs
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft Entra ID / Azure AD OAuth
# Register an app at https://entra.microsoft.com > App registrations
# Redirect URIs: https://<baseDomain>/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=your-azure-ad-client-id
AZURE_AD_CLIENT_SECRET=your-azure-ad-client-secret
# Optional — defaults to "common" (any Microsoft account).
# Set to a specific tenant GUID to restrict to a single organization,
# or "organizations" to allow any work/school account.
# AZURE_AD_TENANT_ID=common

# =============================================================================
# PAYMENT PROCESSING (Adyen)
# =============================================================================

# Get these from your Adyen Customer Area: https://ca-test.adyen.com/
ADYEN_API_KEY=your-adyen-api-key
ADYEN_MERCHANT_ACCOUNT=KirraCapital_Leapfrog_TEST
# Environment: TEST for staging/dev/local, LIVE for production only
ADYEN_ENVIRONMENT=TEST
NEXT_PUBLIC_ADYEN_CLIENT_KEY=your-client-key-for-frontend
# Frontend environment: "test" for staging/dev, "live" for production
NEXT_PUBLIC_ADYEN_ENVIRONMENT=test
# Webhook HMAC key for signature verification
ADYEN_WEBHOOK_HMAC_KEY=your-hmac-key

# Adyen Platform (Balance Platform / Marketplace model)
# Company account: KirraCapital | Balance platform: UplifterLLC
ADYEN_BALANCE_PLATFORM=UplifterLLC
ADYEN_PLATFORM_MERCHANT_ACCOUNT=KirraCapital_Leapfrog_TEST
# Liable balance account ID (platform's fee collection account)
ADYEN_LIABLE_BALANCE_ACCOUNT_ID=your-liable-balance-account-id
# Hosted onboarding theme ID (optional -- omit to use Adyen default)
# ADYEN_ONBOARDING_THEME_ID=
# Balance platform webhook HMAC keys (one per subscription, all point to same endpoint)
# Note: Adyen sends HMAC in the "Hmacsignature" header (no hyphen)
ADYEN_BP_CONFIG_WEBHOOK_HMAC_KEY=your-config-webhook-hmac-key
ADYEN_BP_TRANSFER_WEBHOOK_HMAC_KEY=your-transfer-webhook-hmac-key
ADYEN_BP_NEGBAL_WEBHOOK_HMAC_KEY=your-negbal-webhook-hmac-key
# Configuration/Transfers API key (ws_508000@BalancePlatform.UplifterLLC)
ADYEN_PLATFORM_API_KEY=your-platform-api-key
# Legal Entity Management API key (ws_236609@Scope.Company_KirraCapital)
ADYEN_LEM_API_KEY=your-lem-api-key

# =============================================================================
# SMS (Twilio)
# =============================================================================

# Get these from your Twilio Console: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Use Messaging Service SID for A2P 10DLC compliance (recommended)
# Get this from Twilio Console > Messaging > Services
TWILIO_MESSAGING_SERVICE_SID=your-messaging-service-sid
# Fallback phone number if not using Messaging Service (E.164 format)
TWILIO_PHONE_NUMBER=+1234567890
# Environment: TEST for staging/dev/local, LIVE for production only
TWILIO_ENVIRONMENT=TEST
# Optional: Override webhook URL (defaults to NEXTAUTH_URL)
# TWILIO_WEBHOOK_URL=https://your-domain.com
# Phone number pool for multi-org inbound routing (comma-separated E.164)
# Each number must be purchased in Twilio and added to the Messaging Service.
# Production: 5 numbers, staging/dev: 2 numbers. Falls back to TWILIO_PHONE_NUMBER.
# SMS_PHONE_POOL=+1234567890,+1234567891

# =============================================================================
# EMAIL (Amazon SES)
# =============================================================================

# AWS SES Region
AWS_SES_REGION=us-east-1

# From email address (must be verified in SES)
# Use the appropriate domain for your environment:
# - Production: noreply@uplifterinc.com (keep until SES is verified for uplifter.app)
# - Staging: noreply@upliftergymnastics.com
# - Development: noreply@uplifterdev.com
# - Local: noreply@localhost (uses MailHog)
AWS_SES_FROM_EMAIL=noreply@localhost

# SES Configuration Set for bounce/complaint/delivery event tracking
# Routes SES events through your configuration for bounce handling
# - Staging: upliftergymnastics-pilot
# - Production: (set to your production configuration set)
# AWS_SES_CONFIGURATION_SET=

# SNS Topic ARN for SES event notifications (optional but recommended)
# Restricts the webhook to only accept messages from this specific topic
# SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:ses-notifications

# For local development with MailHog, uncomment:
# SES_ENDPOINT=http://localhost:1025

# SES Inbound Email (for Chat email replies)
# Required for WEB_EMAIL chat conversations to receive reply emails.
# See devops instructions for MX record, SES receipt rule, and SNS topic setup.
#
# Inbound domain — must have MX record pointing to SES inbound SMTP:
# - Production: chat.uplifterinc.com
# - Staging: chat.upliftergymnastics.com
# - Development: chat.uplifterdev.com
# - Local: (not applicable — inbound email requires public DNS)
# SES_INBOUND_DOMAIN=chat.uplifterdev.com
#
# SNS Topic ARN for inbound email notifications (restricts webhook to this topic)
# SES_INBOUND_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:ses-inbound-chat
#
# HMAC secret for signing chat reply-to addresses (falls back to NEXTAUTH_SECRET if unset)
# Generate with: openssl rand -hex 32
# CHAT_EMAIL_HMAC_SECRET=

# =============================================================================
# STORAGE (S3 / MinIO)
# =============================================================================

# Set to "true" to use S3 storage, "false" for local filesystem
USE_S3_STORAGE=false

# AWS S3 Configuration
AWS_S3_BUCKET=uplifter-assets-local
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# For local development with MinIO:
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# =============================================================================
# CACHING (Redis)
# =============================================================================

# Upstash Redis (for cloud environments)
# Get these from your Upstash Console: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# For local development with Docker Redis:
# REDIS_URL=redis://localhost:6379

# =============================================================================
# CRON JOBS
# =============================================================================

# Shared secret for authenticating Vercel Cron requests.
# Must be set in staging/production; cron routes will reject requests without it.
CRON_SECRET=generate-a-cron-secret-here

# =============================================================================
# WEBHOOKS
# =============================================================================

# Optional: Tunnel URL for local webhook testing with ngrok
# WEBHOOK_TUNNEL_URL=https://abc123.ngrok.io

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warn, error (default: info in production, debug in development)
LOG_LEVEL=info

# Enable verbose auth debugging (prints session/token details to logs).
# WARNING: Do NOT enable in production — may log sensitive user data.
# AUTH_DEBUG=true

# =============================================================================
# ACCOUNTING INTEGRATIONS
# =============================================================================

# AES-256 encryption key for storing OAuth tokens at rest (any random 32+ char string)
# Shared by all accounting integrations (QBO, Xero)
ACCOUNTING_ENCRYPTION_KEY=generate-a-random-encryption-key-here

# --- QuickBooks Online ---
# Create an app at https://developer.intuit.com/ with Accounting scope
QBO_CLIENT_ID=your-qbo-client-id
QBO_CLIENT_SECRET=your-qbo-client-secret
# Must match the redirect URI configured in the Intuit Developer Portal
QBO_REDIRECT_URI=http://localhost:3000/api/integrations/qbo/callback
# Environment: sandbox for dev/staging, production for live
QBO_ENVIRONMENT=sandbox

# --- Xero (not yet implemented — credentials have not been provisioned) ---
# The code scaffolding exists in src/lib/xero.ts but no Xero app has been
# registered yet. Leave these blank until the integration is ready.
# When ready: create an app at https://developer.xero.com/app/manage with accounting scopes
# XERO_CLIENT_ID=your-xero-client-id
# XERO_CLIENT_SECRET=your-xero-client-secret
# Must match the redirect URI configured in the Xero Developer Portal
# XERO_REDIRECT_URI=http://localhost:3000/api/integrations/xero/callback

# =============================================================================
# LIVE SUPPORT (Zendesk)
# =============================================================================

# Zendesk Web Widget key for live chat support
# Get this from Zendesk Admin Center > Channels > Messaging > Installation
# NEXT_PUBLIC_ZENDESK_KEY=your-zendesk-widget-key

# =============================================================================
# MAPS (Stadia Maps)
# =============================================================================

# Stadia Maps API key for map tiles (OpenStreetMap-based)
# Get one from https://stadiamaps.com/ — free tier: 200K credits/mo (non-commercial)
# $20/mo Starter plan for commercial use
NEXT_PUBLIC_STADIA_MAPS_API_KEY=your-stadia-maps-api-key

# =============================================================================
# ERROR MONITORING (Sentry)
# =============================================================================

# Sentry DSN for error tracking and performance monitoring
# Create a Next.js project at https://sentry.io/ to get your DSN
# Leave blank to disable Sentry (e.g. for local development)
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.us.sentry.io/0

# Expose APP_ENVIRONMENT to the browser for Sentry environment tagging
NEXT_PUBLIC_APP_ENVIRONMENT=local

# =============================================================================
# FUTURE: STRIPE (Alternative payment processor)
# =============================================================================

# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

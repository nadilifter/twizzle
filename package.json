{
  "name": "uplifter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,tsc -c blue,yellow \"NODE_OPTIONS='--max-old-space-size=4096' next dev\" \"tsc --noEmit --watch --pretty\"",
    "dev:debug": "NODE_OPTIONS='--max-old-space-size=4096 --inspect' next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:check": "bash scripts/check-schema-drift.sh",
    "delete-org": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/delete-organization-by-slug.ts",
    "clone-org": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/clone-org-from-staging.ts",
    "secrets:decrypt": "./scripts/secrets-decrypt.sh",
    "secrets:encrypt": "./scripts/secrets-encrypt.sh",
    "secrets:edit": "./scripts/secrets-edit.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:tenant": "bash scripts/check-tenant-isolation.sh",
    "prepare": "husky"
  },
  "dependencies": {

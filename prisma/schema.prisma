// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// PHASE 1: Foundation - Organization & Users
// ============================================

model Organization {
  id   String  @id @default(cuid())
  name String
  slug String  @unique
  logo String?

  // Contact
  email String?
  phone String?

  // Address (structured)
  street        String?
  city          String?
  stateProvince String?
  postalCode    String?
  country       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Deactivation
  isActive           Boolean   @default(true)
  deactivatedAt      DateTime?
  deactivatedBy      String?
  deactivationReason String?
  deactivationNotes  String?

  // Relations
  statusLogs          OrganizationStatusLog[]
  membershipGroups    MembershipGroup[]
  passes              Pass[]
  members             OrganizationMember[]
  programs            Program[]
  events              Event[]
  invoices            Invoice[]
  skills              Skill[]
  lessonPlans         LessonPlan[]
  announcements       Announcement[]
  websiteConfig       WebsiteConfig?
  evaluationTemplates EvaluationTemplate[]
  achievements        Achievement[]
  certifications      Certification[]

  // Tax configuration
  taxRate    Decimal?  @db.Decimal(5, 4) // e.g. 0.0600 = 6%; null = 0 (no tax)
  taxEnabled Boolean   @default(true)

  // Financials
  discounts        Discount[]
  glCodes          GLCode[]
  ledgerEntries    LedgerEntry[]
  transactions     Transaction[]
  payouts          Payout[]
  recurringCharges RecurringCharge[]


  // Platform Subscription
  subscription OrganizationSubscription?

  // POS Products
  products Product[]

  // Media
  media             Media[]
  registrationFiles RegistrationFile[]

  // Facilities
  facilities Facility[]
  equipment  Equipment[]

  // Scheduling
  shifts            Shift[]
  scheduleTemplates ScheduleTemplate[]

  // SMS
  smsMessages          SmsMessage[]
  smsCampaigns         SmsCampaign[]
  smsUsage             SmsUsage[]
  smsConversations     SmsConversation[]
  smsNumberAssignments SmsNumberAssignment[]

  // Email
  emailMessages  EmailMessage[]
  emailCampaigns EmailCampaign[]
  emailUsage     EmailUsage[]

  // Medical
  medicalFormConfig      MedicalFormConfig?
  customMedicalQuestions CustomMedicalQuestion[]

  // Registration Queues
  queueConfigs RegistrationQueueConfig[]

  // Invitations
  invitations OrganizationInvitation[]

  // Notification Rules
  notificationRules NotificationRule[]
  notificationLogs  NotificationLog[]

  // Levels
  levels Level[]

  // Waivers
  waivers Waiver[]

  // Organization Payment Methods (for SaaS subscription billing)
  organizationPaymentMethods OrganizationPaymentMethod[]

  // Adyen Platform
  adyenPlatformAccount AdyenPlatformAccount?

  // Program Instances
  programInstances ProgramInstance[]

  // Feature Overrides (superadmin per-org overrides)
  featureOverride OrganizationFeatureOverride?

  // Sports
  sports OrganizationSport[]

  // Competition Categories (org-level custom templates)
  competitionCategoryTemplates CompetitionCategoryTemplate[]

  // Competition Category Preferences (per-org preset overrides)
  categoryPreferences OrganizationCategoryPreference[]

  // Competitions
  competitions     Competition[]
  competitionTeams CompetitionTeam[]

  // Organization-Athlete junction (tracks which athletes are visible to this org)
  organizationAthletes OrganizationAthlete[]

  // Accounting Integrations (QuickBooks Online, Xero)
  accountingConnections AccountingConnection[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           Role         @default(COACH)
  status         MemberStatus @default(ACTIVE)
  joinedAt       DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Employment (optional, per-org profile data)
  employmentType   EmploymentType?
  title            String?
  hourlyRate       Decimal?       @db.Decimal(10, 2)
  hireDate         DateTime?
  certifications   Json?
  phone            String?
  emergencyContact Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Org-scoped permissions (replaces global UserPermission)
  permissions OrgMemberPermission[]

  // Scheduling & assignments (migrated from StaffProfile)
  availability       MemberAvailability[]
  shifts             Shift[]
  eventAssignments   EventStaff[]
  programAssignments ProgramStaff[]

  // Certifications
  memberCertifications MemberCertification[]
  certGrantedBy        MemberCertification[] @relation("CertGrantedBy")

  @@unique([organizationId, userId])
}

enum MemberStatus {
  ACTIVE
  INVITED
  INACTIVE
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String?
  avatar       String?
  phone        String?
  role         Role       @default(COACH)
  status       UserStatus @default(ACTIVE)
  isSuperAdmin Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lastActiveAt DateTime?

  // SMS Preferences
  smsOptOut   Boolean   @default(false)
  smsOptOutAt DateTime?

  // Email Preferences
  emailOptOut   Boolean   @default(false)
  emailOptOutAt DateTime?

  // Billing
  balance Decimal @default(0) @db.Decimal(10, 2)

  // Relations
  memberships         OrganizationMember[]
  lessonPlans         LessonPlan[]
  evaluations         Evaluation[]
  events              Event[]              @relation("EventCoach")
  sessions            Session[]
  accounts            Account[]
  media               Media[]
  registrationFiles   RegistrationFile[]  @relation("UserRegistrationFiles")
  facilityAssignments FacilityAssignment[]

  // Guardian/Ward system
  athleteGuardians      AthleteGuardian[]
  athleteProfile        Athlete?               @relation("SelfAthlete")
  claimRequestsMade     GuardianClaimRequest[] @relation("ClaimRequester")
  claimRequestsReviewed GuardianClaimRequest[] @relation("ClaimReviewer")

  // Billing
  userPaymentMethods   PaymentMethod[]   @relation("UserPaymentMethods")
  userInvoices         Invoice[]         @relation("UserInvoices")
  userPayments         Payment[]         @relation("UserPayments")
  userEnrollments      Enrollment[]      @relation("UserEnrollments")
  userRecurringCharges RecurringCharge[] @relation("UserRecurringCharges")
  userAthletePasses    AthletePass[]    @relation("UserAthletePasses")

  // Communication
  userSmsMessages      SmsMessage[]      @relation("UserSmsMessages")
  userSmsConversations SmsConversation[] @relation("UserSmsConversations")
  userEmailMessages    EmailMessage[]    @relation("UserEmailMessages")

  // Registration
  userInstanceRegistrations InstanceRegistration[] @relation("UserInstanceRegistrations")

  // Waivers
  userWaiverSignatures  WaiverSignature[]  @relation("UserWaiverSignatures")
  userWaiverAcceptances WaiverAcceptance[] @relation("UserWaiverAcceptances")

  // Contacts & Billing Addresses
  contacts         UserContact[]
  billingAddresses UserBillingAddress[]

  // Announcement relations
  announcementReads          AnnouncementRead[]       @relation("AnnouncementReads")
  systemAnnouncementReads    SystemAnnouncementRead[] @relation("SystemAnnouncementReads")
  systemAnnouncementsCreated SystemAnnouncement[]     @relation("SystemAnnouncementCreator")

  // Feature request relations
  featureRequests FeatureRequest[] @relation("FeatureRequestAuthor")
  featureVotes    FeatureVote[]    @relation("FeatureVotes")
  featureComments FeatureComment[] @relation("FeatureComments")

  // Invitations sent by this user
  invitationsSent OrganizationInvitation[] @relation("InvitationsSent")

  // Organization status changes performed by this user
  organizationStatusLogs OrganizationStatusLog[] @relation("StatusLogPerformer")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  ext_expires_in    Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Password Reset Tokens - for forgot password functionality
model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([token])
}

enum VerificationCodeType {
  MFA_CHALLENGE
  EMAIL_LOGIN
  SIGNUP_VERIFICATION
}

// Email verification codes for MFA challenges and passwordless email login
model EmailVerificationCode {
  id        String               @id @default(cuid())
  email     String
  code      String
  token     String               @unique
  type      VerificationCodeType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([email, type])
}

model OrgMemberPermission {
  id         String @id @default(cuid())
  memberId   String
  permission String

  member OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, permission])
}

// Organization Invitations - tracks pending and accepted invitations
model OrganizationInvitation {
  id             String                       @id @default(cuid())
  email          String
  token          String                       @unique
  organizationId String
  role           Role                         @default(COACH)
  status         OrganizationInvitationStatus @default(PENDING)
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitationsSent", fields: [invitedById], references: [id])

  @@index([email])
  @@index([organizationId])
  @@index([token])
}

enum OrganizationInvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum Role {
  ADMIN
  COACH
  VOLUNTEER
  ACCOUNTANT
  CUSTOM
  PARENT
}

enum UserStatus {
  ACTIVE
  INVITED
  INACTIVE
}

// ============================================
// PHASE 2: Core Entities - Athletes & Families
// ============================================

model Athlete {
  id        String             @id @default(cuid())
  name      String // Deprecated: use firstName + lastName
  firstName String             @default("")
  lastName  String             @default("")
  email     String?
  avatar    String?
  birthDate DateTime?
  gender    GenderDeclaration?

  medicalDetails Json? // { allergies: [], conditions: [], emergencyContact: {} }

  // Guardian/Ward system
  userId              String? @unique // Self-athlete: the User who IS this athlete
  allowGuardianClaims Boolean @default(false) // Whether other guardians can claim this athlete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  selfUser         User?                  @relation("SelfAthlete", fields: [userId], references: [id], onDelete: SetNull)
  enrollments      Enrollment[]
  attendances      Attendance[]
  evaluations      Evaluation[]
  lineItems        LineItem[]
  memberships       AthleteMembership[]
  passes            AthletePass[]
  media             Media[]
  registrationFiles RegistrationFile[]
  recurringCharges  RecurringCharge[]
  skillProgress    AthleteSkillProgress[]
  achievements     AthleteAchievement[]

  // Multi-family support / Guardian links
  guardians     AthleteGuardian[]
  claimRequests GuardianClaimRequest[]

  // Medical information
  medicalInfo AthleteMedicalInfo?

  // Program instance registrations & attendance
  instanceRegistrations InstanceRegistration[]
  instanceAttendances   InstanceAttendance[]

  // Waiver signatures & acceptances per athlete
  waiverSignatures  WaiverSignature[]
  waiverAcceptances WaiverAcceptance[]

  // Competition entries & results
  competitionEntries CompetitionEntry[]
  competitionResults CompetitionResult[]

  // Organization-Athlete junction (which orgs can see this athlete)
  organizationAthletes OrganizationAthlete[]
}

model AthleteGuardian {
  id           String  @id @default(cuid())
  athleteId    String
  userId       String? // The guardian user
  relationship String? // e.g. "Parent", "Guardian", "Grandparent", "Self"
  isPrimary    Boolean @default(false)

  // Visibility configuration (what this guardian shares with other guardians)
  shareRegistrations Boolean @default(false)
  shareFinancials    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([athleteId, userId])
}

model OrganizationAthlete {
  id             String        @id @default(cuid())
  organizationId String
  athleteId      String
  level          String        @default("Unassigned")
  status         AthleteStatus @default(ACTIVE)
  customId       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      Athlete      @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([organizationId, athleteId])
  @@index([organizationId])
  @@index([athleteId])
}

model GuardianClaimRequest {
  id               String      @id @default(cuid())
  athleteId        String
  requestingUserId String
  status           ClaimStatus @default(PENDING)
  relationship     String? // Requested relationship type
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  athlete        Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  requestingUser User    @relation("ClaimRequester", fields: [requestingUserId], references: [id], onDelete: Cascade)
  reviewedByUser User?   @relation("ClaimReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([athleteId, requestingUserId])
  @@index([athleteId])
  @@index([requestingUserId])
  @@index([status])
}

enum ClaimStatus {
  PENDING
  APPROVED
  DENIED
}

model UserContact {
  id           String   @id @default(cuid())
  userId       String
  firstName    String
  lastName     String
  email        String
  phone        String
  relationship String? // e.g. "Self", "Spouse", "Other"
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserBillingAddress {
  id            String   @id @default(cuid())
  userId        String
  label         String? // e.g. "Home", "Work"
  street        String
  city          String
  stateProvince String?
  postalCode    String
  country       String   @default("US")
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum AthleteStatus {
  ACTIVE
  INACTIVE
  TRIAL
  GRADUATED
}

enum GenderDeclaration {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// ============================================
// Medical Information System
// ============================================

// Question types for custom medical questions
enum MedicalQuestionType {
  TEXT
  YES_NO
  MULTIPLE_CHOICE
  CHECKBOX
}

// Organization-level medical form configuration
model MedicalFormConfig {
  id             String @id @default(cuid())
  organizationId String @unique

  // Standard questions toggles
  collectAllergies           Boolean @default(true)
  collectMedications         Boolean @default(true)
  collectConditions          Boolean @default(true)
  collectEmergencyContact    Boolean @default(true)
  collectDietaryRestrictions Boolean @default(false)
  collectInsuranceInfo       Boolean @default(false)

  // How long collected medical info remains valid before re-collection is required
  validityDays Int @default(180)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Custom medical questions defined by organization
model CustomMedicalQuestion {
  id             String @id @default(cuid())
  organizationId String

  questionText String
  questionType MedicalQuestionType @default(TEXT)
  options      Json? // For MULTIPLE_CHOICE/CHECKBOX types: string[]
  required     Boolean             @default(false)
  displayOrder Int                 @default(0)
  isActive     Boolean             @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  responses    CustomMedicalResponse[]

  @@index([organizationId])
}

// Structured medical data per athlete
model AthleteMedicalInfo {
  id        String @id @default(cuid())
  athleteId String @unique

  // Standard fields (arrays for multiple entries)
  allergies           String[] // Food, environmental, medication allergies
  medications         String[] // Current medications
  conditions          String[] // Medical conditions (asthma, diabetes, etc.)
  dietaryRestrictions String[] // Dietary restrictions

  // Insurance info
  insuranceProvider     String?
  insurancePolicyNumber String?

  // Emergency contact (structured from JSON)
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // Additional notes
  additionalNotes String? @db.Text

  // Metadata
  lastUpdatedBy String? // User ID who last updated

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  athlete         Athlete                 @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  customResponses CustomMedicalResponse[]

  @@index([athleteId])
}

// Answers to custom medical questions
model CustomMedicalResponse {
  id            String @id @default(cuid())
  medicalInfoId String
  questionId    String

  response String // Stored as string, parsed based on question type

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  medicalInfo AthleteMedicalInfo    @relation(fields: [medicalInfoId], references: [id], onDelete: Cascade)
  question    CustomMedicalQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([medicalInfoId, questionId])
  @@index([medicalInfoId])
  @@index([questionId])
}

model PaymentMethod {
  id        String            @id @default(cuid())
  userId    String? // Guardian/Ward: the user who owns this payment method
  type      PaymentMethodType
  last4     String
  expiry    String?
  brand     String?
  isDefault Boolean           @default(false)
  createdAt DateTime          @default(now())

  // Adyen stored payment method token (for recurring charges)
  adyenTokenId     String? @unique
  shopperReference String?

  // Relations
  user             User?             @relation("UserPaymentMethods", fields: [userId], references: [id], onDelete: Cascade)
  recurringCharges RecurringCharge[]

  @@index([userId])
  @@index([adyenTokenId])
}

enum PaymentMethodType {
  CARD
  BANK
}

// ============================================
// PHASE 2: Programs & Memberships
// ============================================

// Organization-defined levels for programs and skills
model Level {
  id             String   @id @default(cuid())
  organizationId String
  name           String // e.g., "Bronze", "Level 1", "Beginner"
  description    String?
  order          Int      @default(0) // Display order
  color          String? // Optional hex color for UI
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization                Organization                      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  skills                      Skill[]                           @relation("SkillLevel")
  programRequirements         ProgramLevelRequirement[]
  membershipGroupRequirements MembershipGroupLevelRequirement[]
  evaluations                 Evaluation[]
  evaluationTemplates         EvaluationTemplate[]

  @@index([organizationId])
  @@index([order])
}

model Program {
  id             String        @id @default(cuid())
  name           String
  description    String?
  color          String        @default("#3b82f6")
  status         ProgramStatus @default(ACTIVE)
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Registration style
  registrationType RegistrationType @default(ALL_INSTANCES)

  // Pricing Configuration
  pricingModel    PricingModel @default(FLAT_RATE)
  basePrice       Decimal?     @db.Decimal(10, 2) // For flat-rate pricing
  perSessionPrice Decimal?     @db.Decimal(10, 2) // For per-session pricing

  // Schedule Configuration
  startDate DateTime?
  endDate   DateTime?
  rrule     String? // RFC 5545 RRULE string (e.g., "FREQ=WEEKLY;BYDAY=MO,WE,FR")
  startTime String? // Default start time (e.g., "09:00")
  duration  Int? // Duration in minutes

  // Default Facility
  facilityId String? // Default facility for this program

  // Capacity (for classes)
  capacity Int?

  // Waitlist
  waitlistEnabled     Boolean @default(false)
  waitlistAutoPromote Boolean @default(false)
  waitlistCapacity    Int? // null = unlimited

  // Display
  showCoachOnSite Boolean @default(true)
  imageUrl        String?

  // Age Restrictions
  minAge Int? // Minimum age (0-100)
  maxAge Int? // Maximum age (0-100)

  // Space Capacity
  hasSpaceRestriction Boolean           @default(false)
  spaceCapacityMode   SpaceCapacityMode @default(MINIMUM)

  // Restriction Flags (for UI toggle state)
  hasGenderRestriction     Boolean @default(false)
  hasLevelRestriction      Boolean @default(false)
  hasCapacityRestriction   Boolean @default(false)
  hasAgeRestriction        Boolean @default(false)
  hasMembershipRestriction Boolean @default(false)
  hasPassRestriction       Boolean @default(false)
  hasWaiverRestriction     Boolean @default(false)
  hasMedicalRequirement    Boolean @default(false)
  hasFileRequirement       Boolean @default(false)
  fileRequirementConfig    Json?

  // Gender Restriction Values
  allowedGenders GenderDeclaration[] // empty = unrestricted

  // GL Code
  glCodeId String?

  // Relations
  organization        Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facility            Facility?                   @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  glCode              GLCode?                     @relation(fields: [glCodeId], references: [id], onDelete: SetNull)
  events              Event[]
  lessonPlans         LessonPlan[]
  enrollments         Enrollment[]
  lineItems           LineItem[]
  staffAssignments    ProgramStaff[]
  requiredMemberships MembershipInstance[]
  coveredByPasses     Pass[]              @relation("PassCoveredPrograms")
  requiredPasses      Pass[]              @relation("PassRequiredForPrograms")
  evaluations         Evaluation[]
  evaluationTemplates ProgramEvaluationTemplate[]
  bulkDiscounts       ProgramBulkDiscount[]
  levelRequirements   ProgramLevelRequirement[]
  waiverRequirements  ProgramWaiverRequirement[]
  instances           ProgramInstance[]
  spaces              ProgramSpace[]
  registrationFiles   RegistrationFile[]

  // Registration Queue
  queueConfigs      RegistrationQueueConfig[]
  queueReservations QueueReservation[]

  @@index([facilityId])
  @@index([glCodeId])
}

enum ProgramStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum RegistrationType {
  ALL_INSTANCES // User registers for entire series
  PER_INSTANCE // User registers for individual sessions
}

enum PricingModel {
  FLAT_RATE // Fixed price for entire program
  PER_SESSION // Price calculated per session
}

// Program Bulk Discounts - for family and multi-session discounts
model ProgramBulkDiscount {
  id            String           @id @default(cuid())
  programId     String
  type          BulkDiscountType
  minQuantity   Int // e.g., 2 for 2nd child, 10 for 10-pack
  discountType  DiscountType // PERCENTAGE, FIXED_AMOUNT
  discountValue Decimal          @db.Decimal(10, 2)
  description   String? // Display text for marketing site
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
}

enum BulkDiscountType {
  FAMILY_SIBLING // Nth child discount
  MULTI_SESSION // Buy X, save Y
}

// Program Level Requirements - many-to-many for level restrictions
model ProgramLevelRequirement {
  id        String   @id @default(cuid())
  programId String
  levelId   String
  createdAt DateTime @default(now())

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  level   Level   @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([programId, levelId])
  @@index([programId])
  @@index([levelId])
}

// Membership Structure
model MembershipGroup {
  id             String   @id @default(cuid())
  organizationId String
  name           String // e.g., "Annual Membership"
  description    String?
  programTypes   String[] // Relevant program types

  // Recurrence Configuration
  isRecurring    Boolean @default(false)
  allowAutoRenew Boolean @default(false)

  // Default Pricing (copied to instances on creation)
  defaultPrice           Decimal?        @db.Decimal(10, 2)
  defaultBillingInterval BillingInterval @default(ONE_TIME)

  // Instance Generation (for recurring groups)
  autoGenerateInstances Boolean @default(false)
  generationLeadDays    Int     @default(30) // How far ahead to auto-generate draft instances

  // Purchase Window
  purchaseWindowDays Int? // Days before instance startDate purchase opens; null = always open

  // Capacity (default, can be overridden per instance)
  capacity Int?

  // Restriction Flags (mirrors Program)
  hasGenderRestriction   Boolean @default(false)
  hasAgeRestriction      Boolean @default(false)
  hasLevelRestriction    Boolean @default(false)
  hasCapacityRestriction Boolean @default(false)
  hasWaiverRestriction   Boolean @default(false)
  hasMedicalRequirement  Boolean @default(false)

  // Restriction Values
  allowedGenders GenderDeclaration[] // empty = unrestricted
  minAge         Int?
  maxAge         Int?

  // GL Code
  glCodeId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization       Organization                       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  glCode             GLCode?                            @relation(fields: [glCodeId], references: [id], onDelete: SetNull)
  instances          MembershipInstance[]
  levelRequirements  MembershipGroupLevelRequirement[]
  waiverRequirements MembershipGroupWaiverRequirement[]

  @@index([glCodeId])
}

model MembershipInstance {
  id                String @id @default(cuid())
  membershipGroupId String
  name              String // e.g., "FY25"

  // Billing
  price           Decimal         @db.Decimal(10, 2)
  billingInterval BillingInterval

  // Validity
  startDate DateTime
  endDate   DateTime

  // Purchase Window Overrides
  purchaseStartDate DateTime? // Overrides group purchaseWindowDays calculation
  purchaseEndDate   DateTime? // Defaults to endDate if null

  // Instance-level capacity override
  capacity Int? // Overrides group capacity if set

  // Renewal Logic
  autoRenewDate DateTime? // When to trigger creation of next instance (if handled by system)

  // Auto-generation tracking
  isAutoGenerated Boolean @default(false)

  status    MembershipInstanceStatus @default(DRAFT)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  // Relations
  group               MembershipGroup     @relation(fields: [membershipGroupId], references: [id], onDelete: Cascade)
  athleteMemberships  AthleteMembership[]
  requiredForEvents   Event[]
  requiredForPrograms Program[]
  lineItems           LineItem[]
}

model AthleteMembership {
  id                   String @id @default(cuid())
  athleteId            String
  membershipInstanceId String

  startDate DateTime
  endDate   DateTime?
  status    MembershipStatus @default(ACTIVE)

  // Auto-renewal for the athlete
  autoRenew Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  athlete  Athlete            @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  instance MembershipInstance @relation(fields: [membershipInstanceId], references: [id], onDelete: Cascade)

  @@index([athleteId, status])
  @@index([athleteId, status, membershipInstanceId])
}

// Membership Group Level Requirements - many-to-many for level restrictions
model MembershipGroupLevelRequirement {
  id                String   @id @default(cuid())
  membershipGroupId String
  levelId           String
  createdAt         DateTime @default(now())

  membershipGroup MembershipGroup @relation(fields: [membershipGroupId], references: [id], onDelete: Cascade)
  level           Level           @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([membershipGroupId, levelId])
  @@index([membershipGroupId])
  @@index([levelId])
}

// Membership Group Waiver Requirements - many-to-many for waiver restrictions
model MembershipGroupWaiverRequirement {
  id                String   @id @default(cuid())
  membershipGroupId String
  waiverId          String
  createdAt         DateTime @default(now())

  membershipGroup MembershipGroup @relation(fields: [membershipGroupId], references: [id], onDelete: Cascade)
  waiver          Waiver          @relation(fields: [waiverId], references: [id], onDelete: Cascade)

  @@unique([membershipGroupId, waiverId])
  @@index([membershipGroupId])
  @@index([waiverId])
}

// Status for individual athlete memberships
enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  ARCHIVED
}

// Status for membership instances (periods)
enum MembershipInstanceStatus {
  DRAFT // Auto-generated, pending admin review
  ACTIVE // Published, available for purchase within window
  EXPIRED // Past end date
  CANCELLED
  ARCHIVED
}

enum BillingInterval {
  ONE_TIME // For non-recurring memberships
  MONTHLY
  YEARLY
  SESSION
}

model Enrollment {
  id        String           @id @default(cuid())
  athleteId String
  programId String
  userId    String? // The guardian who registered this enrollment
  startDate DateTime
  endDate   DateTime?
  status    EnrollmentStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  user    User?   @relation("UserEnrollments", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([athleteId])
  @@index([status])
  @@index([createdAt])
  @@index([athleteId, status])
  @@index([athleteId, createdAt])
  @@index([programId, athleteId, status])
  @@index([programId, status])
}

enum EnrollmentStatus {
  ACTIVE
  WAITLISTED
  PAUSED
  CANCELLED
  COMPLETED
}

// ============================================
// Program Instances (Individual Sessions)
// ============================================

model ProgramInstance {
  id             String         @id @default(cuid())
  programId      String
  date           DateTime
  startTime      String // e.g., "09:00"
  endTime        String // e.g., "10:30"
  facilityId     String? // Can override program's default facility
  capacity       Int? // Can override program capacity
  status         InstanceStatus @default(SCHEDULED)
  notes          String?
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  program       Program                        @relation(fields: [programId], references: [id], onDelete: Cascade)
  facility      Facility?                      @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  organization  Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  registrations InstanceRegistration[]
  attendances   InstanceAttendance[]
  spaces        ProgramInstanceSpace[]
  evaluations   Evaluation[]

  @@index([programId])
  @@index([facilityId])
  @@index([organizationId])
  @@index([date])
  @@index([status])
  @@index([organizationId, date])
}

enum InstanceStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

// Instance Registration - for per-instance program registrations
model InstanceRegistration {
  id                String             @id @default(cuid())
  programInstanceId String
  athleteId         String
  userId            String? // The guardian who registered this instance
  passId            String? // Pass used for this registration (session credit)
  status            RegistrationStatus @default(REGISTERED)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  programInstance ProgramInstance @relation(fields: [programInstanceId], references: [id], onDelete: Cascade)
  athlete         Athlete         @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  user            User?           @relation("UserInstanceRegistrations", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([programInstanceId, athleteId])
  @@index([programInstanceId])
  @@index([athleteId])
  @@index([userId])
  @@index([passId])
  @@index([status])
  @@index([programInstanceId, status])
}

enum RegistrationStatus {
  REGISTERED
  WAITLISTED
  CANCELLED
}

// Instance Attendance - tracks attendance for specific program instances
model InstanceAttendance {
  id                String           @id @default(cuid())
  programInstanceId String
  athleteId         String
  status            AttendanceStatus @default(REGISTERED)
  checkedIn         DateTime?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  programInstance ProgramInstance @relation(fields: [programInstanceId], references: [id], onDelete: Cascade)
  athlete         Athlete         @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([programInstanceId, athleteId])
  @@index([programInstanceId])
  @@index([athleteId])
}

// ============================================
// PHASE 3: Events & Attendance
// ============================================

model Event {
  id                  String               @id @default(cuid())
  title               String
  color               String               @default("#3b82f6")
  date                DateTime
  startTime           String
  endTime             String
  type                EventType            @default(CLASS)
  description         String?
  meetingLink         String?
  timezone            String?
  capacity            Int?
  location            Json? // { lat, lng, address, name } - for external/custom locations
  details             Json? // { whatToBring, whatToExpect, requirements }
  programId           String?
  coachId             String?
  facilityId          String? // Optional - links to a Facility for scheduling
  requiredMemberships MembershipInstance[]
  hasFileRequirement  Boolean              @default(false)
  fileRequirementConfig Json?
  glCodeId            String?
  organizationId      String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program           Program?     @relation(fields: [programId], references: [id])
  coach             User?        @relation("EventCoach", fields: [coachId], references: [id])
  facility          Facility?    @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  glCode            GLCode?      @relation(fields: [glCodeId], references: [id], onDelete: SetNull)
  attendances       Attendance[]
  lineItems         LineItem[]
  media             Media[]
  staffAssignments  EventStaff[]
  registrationFiles RegistrationFile[]

  @@index([glCodeId])
}

enum EventType {
  CLASS
  CLINIC
  PARTY
  TRYOUT
  MEETING
  OTHER
}

model Attendance {
  id        String           @id @default(cuid())
  athleteId String
  eventId   String
  status    AttendanceStatus @default(PRESENT)
  checkedIn DateTime?
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([athleteId, eventId])
}

enum AttendanceStatus {
  REGISTERED
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// ============================================
// PHASE 4: Financial System
// ============================================

model Invoice {
  id             String        @id @default(cuid())
  reference      String        @unique
  userId         String? // The guardian billed for this invoice
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime
  subtotal       Decimal       @db.Decimal(10, 2)
  tax            Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  notes          String?
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation("UserInvoices", fields: [userId], references: [id], onDelete: SetNull)
  lineItems    LineItem[]
  payments     Payment[]

  @@index([userId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  PARTIAL
}

model LineItem {
  id                    String   @id @default(cuid())
  invoiceId             String
  description           String
  quantity              Int
  unitPrice             Decimal  @db.Decimal(10, 2)
  total                 Decimal  @db.Decimal(10, 2)
  programId             String? // What program is this for?
  eventId               String? // What specific event?
  athleteId             String? // Which athlete?
  discountId            String? // Applied discount
  membershipInstanceId  String? // What membership instance?
  passId                String? // What pass is this for?
  competitionId         String? // What competition is this for?
  competitionCategoryId String? // What competition category?
  glCodeId              String? // GL code at time of sale
  createdAt             DateTime @default(now())

  // Relations
  invoice             Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  program             Program?             @relation(fields: [programId], references: [id], onDelete: SetNull)
  event               Event?               @relation(fields: [eventId], references: [id], onDelete: SetNull)
  athlete             Athlete?             @relation(fields: [athleteId], references: [id])
  discount            Discount?            @relation(fields: [discountId], references: [id])
  membershipInstance  MembershipInstance?  @relation(fields: [membershipInstanceId], references: [id], onDelete: SetNull)
  pass                Pass?                @relation(fields: [passId], references: [id], onDelete: SetNull)
  competition         Competition?         @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  competitionCategory CompetitionCategory? @relation(fields: [competitionCategoryId], references: [id], onDelete: SetNull)
  glCode              GLCode?              @relation(fields: [glCodeId], references: [id], onDelete: SetNull)

  @@index([glCodeId])
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String?
  userId        String? // The guardian who made this payment
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentType
  status        PaymentStatus @default(PENDING)
  transactionId String? // Legacy field, keeping for backwards compatibility
  processedAt   DateTime?
  createdAt     DateTime      @default(now())

  // Relations
  invoice     Invoice?     @relation(fields: [invoiceId], references: [id])
  user        User?        @relation("UserPayments", fields: [userId], references: [id], onDelete: SetNull)
  transaction Transaction? // Linked Adyen transaction

  @@index([userId])
}

enum PaymentType {
  CARD
  BANK
  CASH
  CHECK
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Discount {
  id             String         @id @default(cuid())
  name           String
  code           String         @unique
  type           DiscountType
  amount         Decimal        @db.Decimal(10, 2)
  validFrom      DateTime
  validTo        DateTime?
  userScope      UserScope      @default(ALL)
  productScope   ProductScope   @default(ALL)
  usageLimit     Int?
  usageCount     Int            @default(0)
  status         DiscountStatus @default(ACTIVE)
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lineItems    LineItem[]
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum UserScope {
  ALL
  NEW_USERS
  MEMBERS
  VIP
}

enum ProductScope {
  ALL
  MERCHANDISE
  EVENTS
  MEMBERSHIP
}

enum DiscountStatus {
  ACTIVE
  EXPIRED
  SCHEDULED
  DRAFT
}

model GLCode {
  id              String            @id @default(cuid())
  code            String
  description     String
  type            GLCodeType
  status          GLCodeStatus      @default(ACTIVE)
  isDefault       Boolean           @default(false)
  defaultForType  GLCodeEntityType?
  organizationId  String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ledgerEntries    LedgerEntry[]
  programs         Program[]
  events           Event[]
  competitions     Competition[]
  products         Product[]
  membershipGroups MembershipGroup[]
  passes           Pass[]
  lineItems        LineItem[]

  @@unique([code, organizationId])
  @@index([organizationId])
}

enum GLCodeType {
  REVENUE
  EXPENSE
  LIABILITY
  ASSET
  EQUITY
}

enum GLCodeStatus {
  ACTIVE
  INACTIVE
}

enum GLCodeEntityType {
  PROGRAM
  EVENT
  COMPETITION
  MEMBERSHIP
  PASS
  PRODUCT
}

model LedgerEntry {
  id             String            @id @default(cuid())
  date           DateTime
  description    String
  glCodeId       String
  reference      String?
  debit          Decimal?          @db.Decimal(10, 2)
  credit         Decimal?          @db.Decimal(10, 2)
  status         LedgerEntryStatus @default(PENDING)
  organizationId String
  createdAt      DateTime          @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  glCode       GLCode       @relation(fields: [glCodeId], references: [id])
}

enum LedgerEntryStatus {
  POSTED
  PENDING
}

// ============================================
// Adyen Transaction Tracking
// ============================================

model Transaction {
  id             String            @id @default(cuid())
  organizationId String
  paymentId      String?           @unique
  pspReference   String            @unique // Adyen PSP reference
  merchantRef    String? // Our internal reference
  type           TransactionType
  amount         Decimal           @db.Decimal(10, 2)
  currency       String            @default("USD")
  status         TransactionStatus
  method         String? // visa, mastercard, applepay, etc.
  description    String?
  metadata       Json?
  settledAt      DateTime?
  payoutId       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payment      Payment?     @relation(fields: [paymentId], references: [id])
  payout       Payout?      @relation(fields: [payoutId], references: [id])

  @@index([organizationId])
  @@index([pspReference])
  @@index([payoutId])
}

enum TransactionType {
  PAYMENT
  REFUND
  CHARGEBACK
  CAPTURE
  CANCEL
}

enum TransactionStatus {
  AUTHORISED
  CAPTURED
  SETTLED
  REFUSED
  CANCELLED
  ERROR
  PENDING
}

// ============================================
// Payouts (Settlement from Adyen)
// ============================================

model Payout {
  id             String       @id @default(cuid())
  organizationId String
  reference      String       @unique // Adyen payout reference
  amount         Decimal      @db.Decimal(10, 2)
  fees           Decimal      @default(0) @db.Decimal(10, 2)
  net            Decimal      @db.Decimal(10, 2)
  currency       String       @default("USD")
  status         PayoutStatus
  bankAccount    String? // Last 4 digits
  scheduledAt    DateTime?
  paidAt         DateTime?
  estimatedArrivalTime DateTime?
  createdAt      DateTime     @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([organizationId])
}

enum PayoutStatus {
  PENDING
  SCHEDULED
  PAID
  FAILED
}

// ============================================
// Recurring Billing
// ============================================

model RecurringCharge {
  id              String          @id @default(cuid())
  organizationId  String
  userId          String? // The guardian billed for this recurring charge
  athleteId       String?
  description     String
  amount          Decimal         @db.Decimal(10, 2)
  frequency       BillingInterval // MONTHLY, YEARLY, SESSION
  nextChargeDate  DateTime
  lastChargedAt   DateTime?
  status          RecurringStatus
  paymentMethodId String?
  failureCount    Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User?          @relation("UserRecurringCharges", fields: [userId], references: [id], onDelete: SetNull)
  athlete       Athlete?       @relation(fields: [athleteId], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([nextChargeDate])
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  CANCELLED
  FAILED
}

// ============================================
// PHASE 5: Training & Evaluations
// ============================================

model Skill {
  id             String   @id @default(cuid())
  name           String
  category       String // e.g., "Vault", "Bars", "Beam", "Floor"
  level          String? // Legacy field - kept for backwards compatibility
  description    String?  @db.Text
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Age targeting
  minAge   Int? // Suggested minimum age
  maxAge   Int? // Suggested maximum age
  videoUrl String? // Demo video URL
  imageUrl String? // Demo image URL

  // Level reference (new system)
  levelId String? // FK to Level model

  // Relations
  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  skillLevel       Level?                    @relation("SkillLevel", fields: [levelId], references: [id], onDelete: SetNull)
  evaluationSkills EvaluationSkill[]
  rotationSkills   RotationSkill[]
  templateSkills   EvaluationTemplateSkill[]
  athleteProgress  AthleteSkillProgress[]

  @@index([levelId])
}

// Evaluation Templates - reusable groupings of skills for assessments
model EvaluationTemplate {
  id             String   @id @default(cuid())
  name           String
  description    String?  @db.Text
  levelId        String? // FK to Level model
  minAge         Int?
  maxAge         Int?
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Auto-sync configuration
  autoSyncEnabled    Boolean  @default(false)
  autoSyncLevels     String[] @default([]) // Level IDs for auto-sync filtering
  autoSyncCategories String[] @default([]) // e.g., ["Vault", "Bars"]

  // Scoring configuration
  scoringType             ScoringType @default(PASS_FAIL)
  pointScaleMin           Int         @default(1)
  pointScaleMax           Int         @default(10)
  pointScalePassThreshold Int         @default(7)

  // Completion requirements for achievements
  completionType      CompletionType @default(PERCENTAGE)
  completionThreshold Decimal        @default(80) @db.Decimal(5, 2)

  // Relations
  organization     Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  level            Level?                      @relation(fields: [levelId], references: [id], onDelete: SetNull)
  skills           EvaluationTemplateSkill[]
  evaluations      Evaluation[]
  programTemplates ProgramEvaluationTemplate[]
  achievements     Achievement[]

  @@index([organizationId])
  @@index([levelId])
}

// Junction table for skills in evaluation templates
model EvaluationTemplateSkill {
  id         String  @id @default(cuid())
  templateId String
  skillId    String
  order      Int     @default(0) // Display order
  isRequired Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  template EvaluationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  skill    Skill              @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([templateId, skillId])
  @@index([templateId])
  @@index([skillId])
}

// Junction table for linking evaluation templates to programs
model ProgramEvaluationTemplate {
  id         String    @id @default(cuid())
  programId  String
  templateId String
  isRequired Boolean   @default(false)
  dueDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  program  Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  template EvaluationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([programId, templateId])
  @@index([programId])
  @@index([templateId])
}

model LessonPlan {
  id             String           @id @default(cuid())
  name           String
  programId      String
  date           DateTime?
  authorId       String
  status         LessonPlanStatus @default(DRAFT)
  theme          String?
  notes          String?
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program      @relation(fields: [programId], references: [id])
  author       User         @relation(fields: [authorId], references: [id])
  rotations    Rotation[]
}

enum LessonPlanStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

model Rotation {
  id           String   @id @default(cuid())
  lessonPlanId String
  name         String
  description  String?
  order        Int      @default(0)
  media        String[] // Array of media URLs
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  lessonPlan LessonPlan      @relation(fields: [lessonPlanId], references: [id], onDelete: Cascade)
  skills     RotationSkill[]
}

model RotationSkill {
  id         String @id @default(cuid())
  rotationId String
  skillId    String

  // Relations
  rotation Rotation @relation(fields: [rotationId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([rotationId, skillId])
}

model Evaluation {
  id                String           @id @default(cuid())
  athleteId         String
  coachId           String
  templateId        String? // Optional link to evaluation template
  programId         String? // Optional link to program
  programInstanceId String? // Optional link to specific session
  levelId           String? // FK to Level model
  date              DateTime
  overallScore      Decimal          @db.Decimal(3, 1)
  status            EvaluationStatus
  notes             String?          @db.Text
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  athlete             Athlete              @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  coach               User                 @relation(fields: [coachId], references: [id])
  template            EvaluationTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  program             Program?             @relation(fields: [programId], references: [id], onDelete: SetNull)
  programInstance     ProgramInstance?     @relation(fields: [programInstanceId], references: [id], onDelete: SetNull)
  level               Level?               @relation(fields: [levelId], references: [id], onDelete: SetNull)
  skillRatings        EvaluationSkill[]
  athleteAchievements AthleteAchievement[]

  @@index([athleteId])
  @@index([coachId])
  @@index([templateId])
  @@index([programId])
  @@index([programInstanceId])
  @@index([levelId])
}

enum EvaluationStatus {
  PENDING // Evaluation assigned but not completed
  IN_PROGRESS // Evaluation started
  PASS
  RETRY
  EXCELLENT
  SATISFACTORY
}

model EvaluationSkill {
  id            String             @id @default(cuid())
  evaluationId  String
  skillId       String
  rating        Int? // Legacy: 1-5, optional (can use attemptStatus instead)
  pointScore    Int? // For POINT_SCALE scoring type
  attemptStatus SkillAttemptStatus @default(NOT_ATTEMPTED)
  passed        Boolean            @default(false) // Computed based on scoring type
  comment       String?

  // Relations
  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id])

  @@unique([evaluationId, skillId])
  @@index([evaluationId])
  @@index([skillId])
}

enum SkillAttemptStatus {
  NOT_ATTEMPTED
  ATTEMPTED
  SUCCEEDED
}

// Scoring types for evaluations
enum ScoringType {
  PASS_FAIL // 3 states: NOT_ATTEMPTED, ATTEMPTED, PASSED
  POINT_SCALE // Configurable range with pass threshold
}

// Completion requirement types for achievements
enum CompletionType {
  PERCENTAGE // e.g., 80% of skills passed
  COUNT // e.g., 15 skills passed
  ALL // All required skills passed
}

// Track athlete progress on individual skills across all evaluations
model AthleteSkillProgress {
  id               String             @id @default(cuid())
  athleteId        String
  skillId          String
  bestStatus       SkillAttemptStatus @default(NOT_ATTEMPTED)
  firstAttemptedAt DateTime?
  firstSucceededAt DateTime?
  attemptCount     Int                @default(0)
  successCount     Int                @default(0)
  lastEvaluatedAt  DateTime
  lastEvaluationId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Relations
  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([athleteId, skillId])
  @@index([athleteId])
  @@index([skillId])
}

// Achievement definitions linked to evaluation templates
model Achievement {
  id             String   @id @default(cuid())
  templateId     String
  name           String
  description    String?  @db.Text
  badgeImageUrl  String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  template            EvaluationTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athleteAchievements AthleteAchievement[]

  @@index([templateId])
  @@index([organizationId])
}

// Track athlete achievements earned
model AthleteAchievement {
  id            String   @id @default(cuid())
  athleteId     String
  achievementId String
  evaluationId  String? // The evaluation that earned this achievement
  earnedAt      DateTime @default(now())

  // Best results by category at time of earning
  bestResultsByCategory Json? // { "Vault": 9.5, "Bars": 8.0, ... }
  overallScore          Decimal? @db.Decimal(5, 2)

  // Relations
  athlete     Athlete     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  evaluation  Evaluation? @relation(fields: [evaluationId], references: [id], onDelete: SetNull)

  @@unique([athleteId, achievementId])
  @@index([athleteId])
  @@index([achievementId])
  @@index([evaluationId])
}

// ============================================
// PHASE 6: Communication
// ============================================

model Announcement {
  id              String               @id @default(cuid())
  title           String
  content         String // HTML content from WYSIWYG
  targetScope     AnnouncementScope    @default(ALL)
  targetProgramId String?
  targetEventId   String?
  status          AnnouncementStatus   @default(DRAFT)
  priority        AnnouncementPriority @default(NORMAL)
  publishedAt     DateTime?
  expiresAt       DateTime?
  organizationId  String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Relations
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  readBy       AnnouncementRead[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([status, publishedAt])
}

model AnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation("AnnouncementReads", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
  @@index([announcementId])
}

// System-wide announcements from superadmins (sent to all organizations)
model SystemAnnouncement {
  id          String               @id @default(cuid())
  title       String
  content     String               @db.Text // HTML content from WYSIWYG
  priority    AnnouncementPriority @default(NORMAL)
  status      AnnouncementStatus   @default(DRAFT)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  // Track who created it
  createdById String
  createdBy   User   @relation("SystemAnnouncementCreator", fields: [createdById], references: [id])

  // Read tracking
  readBy SystemAnnouncementRead[]

  @@index([status])
  @@index([status, publishedAt])
}

model SystemAnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement SystemAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User               @relation("SystemAnnouncementReads", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
  @@index([announcementId])
}

enum AnnouncementScope {
  ALL
  PROGRAM
  EVENT
  GUARDIAN
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================
// SMS Messaging
// ============================================

model SmsMessage {
  id             String  @id @default(cuid())
  organizationId String
  userId         String? // Recipient user (if outbound)
  campaignId     String? // Part of a campaign
  conversationId String? // Part of a conversation thread

  // Message details
  to       String // E.164 format phone number
  from     String // Twilio number used
  body     String @db.Text
  segments Int    @default(1) // SMS segment count

  // Twilio tracking
  twilioSid    String?   @unique // Twilio message SID
  twilioStatus SmsStatus @default(QUEUED)

  // Direction
  direction SmsDirection @default(OUTBOUND)

  // Classification
  classification SmsClassification @default(GENERAL)

  // Cost tracking (in cents)
  cost Decimal? @db.Decimal(10, 4)

  // Timestamps
  sentAt      DateTime?
  deliveredAt DateTime?
  failedAt    DateTime?

  // Error handling
  errorCode    String?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?            @relation("UserSmsMessages", fields: [userId], references: [id], onDelete: SetNull)
  campaign     SmsCampaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  conversation SmsConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([campaignId])
  @@index([conversationId, createdAt])
  @@index([twilioSid])
  @@index([twilioStatus])
  @@index([createdAt])
}

enum SmsStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  UNDELIVERED
  FAILED
}

enum SmsDirection {
  OUTBOUND
  INBOUND
}

enum SmsClassification {
  GENERAL
  REMINDER
  ALERT
  BILLING
  EVENT
  NEWS
}

model SmsCampaign {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  body           String            @db.Text
  classification SmsClassification @default(GENERAL)

  // Targeting - legacy field kept for backward compatibility
  targetScope              AnnouncementScope @default(ALL)
  // Expanded targeting (matching EmailCampaign)
  targetType               SmsTargetType     @default(ALL_MEMBERS)
  targetProgramId          String?
  targetEventId            String?
  targetMembershipStatus   String? // "ACTIVE", "EXPIRED", or null for all
  targetProgramInstanceId  String? // For PROGRAM_SPECIFIC_INSTANCE
  targetMembershipGroupIds String[] // For MEMBERSHIP_HOLDERS (array of group IDs)
  targetUserIds            String[] // For SPECIFIC_USERS (hand-picked guardian users)

  // Status
  status SmsCampaignStatus @default(DRAFT)

  // Statistics
  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  deliveredCount  Int @default(0)
  failedCount     Int @default(0)

  // Scheduling
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  // Author
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     SmsMessage[]

  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
}

enum SmsTargetType {
  ALL_USERS
  ALL_MEMBERS
  ALL_PROGRAM_REGISTRANTS
  PROGRAM_ANY_INSTANCE
  PROGRAM_SPECIFIC_INSTANCE
  MEMBERSHIP_HOLDERS
  SPECIFIC_USERS
  ALL_GUARDIANS
}

enum SmsCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
  CANCELLED
}

model SmsConversation {
  id             String  @id @default(cuid())
  organizationId String
  userId         String? // The guardian user in this conversation
  phoneNumber    String // User's phone number (E.164)

  // Status
  status SmsConversationStatus @default(OPEN)

  // Tracking
  lastMessageAt   DateTime?
  lastMessageBody String?   @db.Text
  unreadCount     Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation("UserSmsConversations", fields: [userId], references: [id], onDelete: Cascade)
  messages     SmsMessage[]

  @@unique([organizationId, userId])
  @@index([organizationId, lastMessageAt])
  @@index([organizationId, status])
}

enum SmsConversationStatus {
  OPEN
  CLOSED
  ARCHIVED
}

model SmsUsage {
  id             String @id @default(cuid())
  organizationId String

  // Period tracking
  periodStart DateTime
  periodEnd   DateTime

  // Counts
  messagesSent      Int @default(0)
  messagesDelivered Int @default(0)
  messagesFailed    Int @default(0)
  totalSegments     Int @default(0)

  // Cost tracking (in dollars)
  totalCost Decimal @default(0) @db.Decimal(10, 2)

  // Plan-based tracking
  includedMessages Int     @default(0) // From plan
  overageMessages  Int     @default(0) // Beyond plan limit
  overageCost      Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, periodStart])
  @@index([organizationId])
  @@index([periodStart])
}

model SmsNumberAssignment {
  id             String @id @default(cuid())
  phone          String // Guardian's phone (E.164 normalized)
  twilioNumber   String // Pool number assigned to this phone+org
  organizationId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([phone, organizationId])
  @@unique([phone, twilioNumber])
  @@index([twilioNumber, phone])
}

// ============================================
// Email Campaigns
// ============================================

model EmailMessage {
  id             String  @id @default(cuid())
  organizationId String
  userId         String? // Recipient guardian user
  campaignId     String? // Part of a campaign

  // Message details
  to       String // Recipient email address
  from     String // Sender email (org's from address)
  subject  String
  htmlBody String  @db.Text
  textBody String? @db.Text

  // SES tracking
  sesMessageId String?     @unique // SES message ID for tracking
  status       EmailStatus @default(QUEUED)

  // Classification
  classification EmailClassification @default(GENERAL)

  // Engagement tracking
  openedAt   DateTime?
  openCount  Int       @default(0)
  clickedAt  DateTime?
  clickCount Int       @default(0)

  // Timestamps
  sentAt       DateTime?
  deliveredAt  DateTime?
  bouncedAt    DateTime?
  complainedAt DateTime?
  failedAt     DateTime?

  // Error handling
  bounceType    String? // "Permanent" or "Transient"
  bounceSubType String? // e.g., "General", "NoEmail", "Suppressed"
  errorCode     String?
  errorMessage  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?          @relation("UserEmailMessages", fields: [userId], references: [id], onDelete: SetNull)
  campaign     EmailCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([campaignId])
  @@index([sesMessageId])
  @@index([status])
  @@index([createdAt])
}

enum EmailStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
}

enum EmailClassification {
  GENERAL
  PROGRAM_UPDATE
  EVENT_UPDATE
  MEMBERSHIP
  BILLING
  NEWSLETTER
}

model EmailCampaign {
  id             String              @id @default(cuid())
  organizationId String
  name           String
  subject        String
  htmlBody       String              @db.Text
  textBody       String?             @db.Text
  classification EmailClassification @default(GENERAL)

  // Targeting - legacy field kept for backward compatibility
  targetScope     AnnouncementScope @default(ALL)
  // New expanded targeting
  targetType      EmailTargetType   @default(ALL_MEMBERS)
  targetProgramId String?
  targetEventId   String?

  // Additional targeting options
  targetMembershipStatus   String? // "ACTIVE", "EXPIRED", or null for all
  targetProgramInstanceId  String? // For PROGRAM_SPECIFIC_INSTANCE
  targetMembershipGroupIds String[] // For MEMBERSHIP_HOLDERS (array of group IDs)
  targetUserIds            String[] // For SPECIFIC_USERS (hand-picked guardian users)

  // Status
  status EmailCampaignStatus @default(DRAFT)

  // Statistics
  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  deliveredCount  Int @default(0)
  openedCount     Int @default(0)
  clickedCount    Int @default(0)
  bouncedCount    Int @default(0)
  complainedCount Int @default(0)
  failedCount     Int @default(0)

  // Scheduling
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  // Author
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     EmailMessage[]

  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
}

enum EmailTargetType {
  ALL_USERS
  ALL_MEMBERS
  ALL_PROGRAM_REGISTRANTS
  PROGRAM_ANY_INSTANCE
  PROGRAM_SPECIFIC_INSTANCE
  MEMBERSHIP_HOLDERS
  SPECIFIC_USERS
  ALL_GUARDIANS
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
  CANCELLED
}

model EmailUsage {
  id             String @id @default(cuid())
  organizationId String

  // Period tracking
  periodStart DateTime
  periodEnd   DateTime

  // Counts
  emailsSent       Int @default(0)
  emailsDelivered  Int @default(0)
  emailsOpened     Int @default(0)
  emailsClicked    Int @default(0)
  emailsBounced    Int @default(0)
  emailsComplained Int @default(0)
  emailsFailed     Int @default(0)

  // Plan-based tracking
  includedEmails Int     @default(0) // From plan
  overageEmails  Int     @default(0) // Beyond plan limit
  overageCost    Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, periodStart])
  @@index([organizationId])
  @@index([periodStart])
}

// ============================================
// PHASE 7: Website Builder
// ============================================

model WebsiteConfig {
  id             String @id @default(cuid())
  organizationId String @unique

  // Theming
  primaryColor   String? @default("#000000")
  secondaryColor String? @default("#ffffff")

  // Assets
  logo    String?
  favicon String?

  // Content
  heroImage          String?
  heroHeadline       String?
  heroSubheadline    String?
  heroText           String? @db.Text
  heroAgeRange       String? // e.g., "All Ages Welcome", "Ages 5-18"
  heroProgramPeriods String? // e.g., "Year-Round Programs", "Fall & Spring Sessions"
  heroLocation       String? // e.g., "Austin, TX"

  // Visibility
  showCalendar     Boolean @default(true)
  showRegistration Boolean @default(true)
  showContact      Boolean @default(true)
  showCompetitions Boolean @default(false)

  // Competitions marketing content
  competitionsHeading     String?
  competitionsDescription String? @db.Text
  competitionsCtaText     String?

  // Domain
  domain            String? @unique
  subdomain         String? @unique // prefix to uplifterinc.com
  emailSenderDomain String?

  // Status
  isPublished Boolean @default(false)

  // SEO
  seoDescription     String? @db.Text // Custom meta description for search engines
  seoKeywords        String? // Comma-separated keywords
  googleVerification String? // Google Search Console verification code

  // Information Boxes (up to 3 configurable boxes on home page)
  infoBox1Title   String?
  infoBox1Content String? @db.Text
  infoBox2Title   String?
  infoBox2Content String? @db.Text
  infoBox3Title   String?
  infoBox3Content String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ============================================
// POS Products & Inventory
// ============================================

model Product {
  id               String   @id @default(cuid())
  organizationId   String
  name             String
  description      String?
  sku              String?
  category         String   @default("General")
  price            Decimal  @db.Decimal(10, 2)
  imageUrl         String?
  maxInventory     Int? // null = unlimited
  currentInventory Int? // null = unlimited
  isActive         Boolean  @default(true)
  glCodeId         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  glCode         GLCode?         @relation(fields: [glCodeId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([glCodeId])
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  type        StockMovementType
  quantity    Int // positive for additions, negative for sales
  previousQty Int
  newQty      Int
  referenceId String? // invoiceId, orderId, etc.
  notes       String?
  createdBy   String?
  createdAt   DateTime          @default(now())

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

enum StockMovementType {
  SALE
  RESTOCK
  ADJUSTMENT
  RETURN
}

// ============================================
// PHASE 8: Feedback & Feature Requests
// ============================================

enum FeatureStatus {
  SUBMITTED // New submission, pending review
  PLANNED // Accepted and on roadmap
  IN_PROGRESS // Currently being built
  DONE // Completed
  CLOSED // Rejected/won't do
}

model FeatureRequest {
  id              String        @id @default(cuid())
  title           String
  description     String
  status          FeatureStatus @default(SUBMITTED)
  isPublic        Boolean       @default(false) // Only show on public roadmap if true
  targetDate      DateTime? // Target delivery date
  statusChangedAt DateTime? // Last status change timestamp
  categories      String[] // Array of category strings
  mergedIntoId    String? // If merged into another feature
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userId          String? // Author (submitter)

  // Relations
  user       User?            @relation("FeatureRequestAuthor", fields: [userId], references: [id], onDelete: SetNull)
  mergedInto FeatureRequest?  @relation("FeatureMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom FeatureRequest[] @relation("FeatureMerge")
  comments   FeatureComment[]
  votes      FeatureVote[]

  @@index([status])
  @@index([isPublic])
  @@index([userId])
}

model FeatureVote {
  id               String   @id @default(cuid())
  featureRequestId String
  userId           String
  createdAt        DateTime @default(now())

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  user           User           @relation("FeatureVotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([featureRequestId, userId]) // One vote per user per feature
  @@index([featureRequestId])
  @@index([userId])
}

model FeatureComment {
  id               String   @id @default(cuid())
  featureRequestId String
  content          String
  userId           String
  isStaffReply     Boolean  @default(false) // True if from superadmin/staff
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  user           User           @relation("FeatureComments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([featureRequestId])
  @@index([userId])
}

// ============================================
// Media
// ============================================

model Media {
  id             String    @id @default(cuid())
  url            String
  type           MediaType
  title          String?
  description    String?
  fileSize       Int       @default(0) // File size in bytes
  athleteId      String?
  eventId        String?
  uploadedById   String
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  athlete      Athlete?     @relation(fields: [athleteId], references: [id], onDelete: SetNull)
  event        Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([athleteId])
  @@index([eventId])
  @@index([uploadedById])
}

enum MediaType {
  IMAGE
  VIDEO
}

// ============================================
// Facilities & Equipment
// ============================================

model Facility {
  id             String @id @default(cuid())
  organizationId String
  name           String

  // Address
  street        String?
  city          String?
  stateProvince String?
  postalCode    String?
  country       String?

  // Contact
  phone String?
  email String?

  // Status & Metadata
  status        FacilityStatus @default(ACTIVE)
  isDefault     Boolean        @default(false)
  squareFootage Int?
  maxCapacity   Int?
  description   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  spaces           Space[]
  equipment        Equipment[]
  assignments      FacilityAssignment[]
  events           Event[]
  shifts           Shift[]
  programs         Program[]
  programInstances ProgramInstance[]
  competitions     Competition[]
  operatingHours   FacilityOperatingHours[]

  @@index([organizationId])
}

enum FacilityStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

model FacilityOperatingHours {
  id         String @id @default(cuid())
  facilityId String
  dayOfWeek  Int // 0=Sunday, 1=Monday, ..., 6=Saturday
  openTime   String // e.g., "09:00"
  closeTime  String // e.g., "17:00"

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
}

model Space {
  id          String      @id @default(cuid())
  facilityId  String
  name        String
  capacity    Int?
  status      SpaceStatus @default(OPEN)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  facility            Facility                @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  equipment           Equipment[]
  programAssignments  ProgramSpace[]
  instanceAssignments ProgramInstanceSpace[]
  availability        SpaceAvailability[]

  @@index([facilityId])
}

enum SpaceStatus {
  OPEN
  CLOSED
  MAINTENANCE
}

enum SpaceCapacityMode {
  MINIMUM // Capacity = smallest space capacity
  SUM // Capacity = sum of space capacities
}

model ProgramSpace {
  id      String @id @default(cuid())
  programId String
  spaceId   String

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  space   Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([programId, spaceId])
  @@index([programId])
  @@index([spaceId])
}

model ProgramInstanceSpace {
  id                String @id @default(cuid())
  programInstanceId String
  spaceId           String

  programInstance ProgramInstance @relation(fields: [programInstanceId], references: [id], onDelete: Cascade)
  space           Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([programInstanceId, spaceId])
  @@index([programInstanceId])
  @@index([spaceId])
}

model SpaceAvailability {
  id      String @id @default(cuid())
  spaceId String
  dayOfWeek Int // 0=Sunday, 1=Monday, ..., 6=Saturday
  openTime  String // e.g., "08:00"
  closeTime String // e.g., "18:00"

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([spaceId, dayOfWeek])
  @@index([spaceId])
}

model Equipment {
  id             String  @id @default(cuid())
  organizationId String
  facilityId     String? // Optional - null means org-level equipment
  spaceId        String?

  name         String
  serialNumber String?
  condition    EquipmentCondition @default(GOOD)
  status       EquipmentStatus    @default(ACTIVE)

  // Tracking
  purchaseDate       DateTime?
  lastInspectionDate DateTime?
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facility     Facility?    @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  space        Space?       @relation(fields: [spaceId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([facilityId])
  @@index([spaceId])
}

enum EquipmentCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  UNSAFE
}

enum EquipmentStatus {
  ACTIVE
  RETIRED
  MAINTENANCE
}

model FacilityAssignment {
  id         String  @id @default(cuid())
  facilityId String
  userId     String
  isPrimary  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([facilityId, userId])
  @@index([facilityId])
  @@index([userId])
}

// ============================================
// Reserved Domains/Prefixes
// ============================================

model ReservedDomain {
  id        String             @id @default(cuid())
  pattern   String             @unique // The reserved domain or prefix pattern
  type      ReservedDomainType @default(EXACT)
  reason    String? // Why this is reserved (e.g., "Brand protection", "System use")
  createdBy String? // User ID who created this reservation
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

enum ReservedDomainType {
  EXACT // Exact match (e.g., "admin" blocks only "admin")
  PREFIX // Prefix match (e.g., "test-" blocks "test-anything")
}

// ============================================
// Platform Subscription & Billing
// ============================================

model SubscriptionPlan {
  id          String  @id @default(cuid())
  name        String // e.g., "Free", "Starter", "Gold", "Platinum"
  slug        String  @unique // URL-friendly identifier
  description String?

  // Pricing
  monthlyPrice      Decimal  @db.Decimal(10, 2)
  yearlyPrice       Decimal? @db.Decimal(10, 2) // Optional yearly discount
  transactionFee    Decimal  @db.Decimal(5, 4) // e.g., 0.029 for 2.9%
  perTransactionFee Decimal  @db.Decimal(10, 2) // e.g., 0.30 for $0.30

  // Limits
  maxAthletes Int? // null = unlimited
  maxUsers    Int? // null = unlimited
  maxPrograms Int? // null = unlimited
  maxEvents   Int? // null = unlimited

  // SMS Limits
  smsIncluded    Int? // Messages included per month (null = no SMS)
  smsOverageRate Decimal? @db.Decimal(10, 4) // Cost per message over limit (e.g., 0.05 for $0.05)

  // Email Limits
  emailIncluded    Int? // Emails included per month (null = no email campaigns)
  emailOverageRate Decimal? @db.Decimal(10, 4) // Cost per email over limit

  // Storage Limits
  maxStorageMB Int? // Storage in MB (null = unlimited)

  // Membership Limits
  maxMembershipTypes Int? // Max membership groups (null = unlimited)

  // Features (stored as JSON for flexibility)
  features Json // Array of feature strings (display text for pricing pages)

  // Feature Toggles (structured boolean flags controlling access to modules)
  featureToggles Json @default("{}") // { events: true, sms: false, ... }

  // Display
  isPopular    Boolean @default(false)
  displayOrder Int     @default(0)

  // Status
  isActive Boolean @default(true)
  isPublic Boolean @default(true) // Can orgs self-select this plan?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  subscriptions OrganizationSubscription[]
}

model OrganizationSubscription {
  id             String @id @default(cuid())
  organizationId String @unique
  planId         String

  // Billing
  status             SubscriptionStatus @default(ACTIVE)
  billingCycle       BillingCycle       @default(MONTHLY)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  // Payment info (stored tokens, not actual card data)
  stripeCustomerId     String?
  stripeSubscriptionId String?

  // Adyen Payment Info
  adyenShopperReference   String? @unique // Unique ID for this org in Adyen
  adyenRecurringDetailRef String? // Primary payment method token ID

  // Admin controls
  isLocked     Boolean   @default(false) // If true, org cannot change plan
  lockedReason String? // Why it's locked (shown to org admins)
  lockedBy     String? // Super admin who locked it
  lockedAt     DateTime?

  // Trial
  trialEndsAt DateTime?

  // Cancellation
  cancelAtPeriodEnd Boolean   @default(false)
  cancelledAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])
}

model OrganizationFeatureOverride {
  id             String   @id @default(cuid())
  organizationId String   @unique
  featureToggles Json // Partial set of feature keys to override from plan defaults
  updatedBy      String? // Super admin user ID who set the override
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  PAUSED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

// Organization Payment Methods - for SaaS subscription billing via Adyen
model OrganizationPaymentMethod {
  id             String @id @default(cuid())
  organizationId String

  // Adyen Token Info
  storedPaymentMethodId String @unique // Token from Adyen (storedPaymentMethodId)
  shopperReference      String // Links to org's Adyen identity

  // Card Display Info (safe to store - no sensitive data)
  type        String // "scheme", "sepadirectdebit", etc.
  brand       String? // "visa", "mc", "amex"
  lastFour    String // Last 4 digits of card
  expiryMonth String? // "03"
  expiryYear  String? // "2030"
  holderName  String? // Cardholder name

  // Status
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([shopperReference])
}

// ============================================
// Adyen Platform (Balance Platform / Marketplace)
// ============================================

model AdyenPlatformAccount {
  id             String @id @default(cuid())
  organizationId String @unique

  // Adyen entity IDs (populated progressively during onboarding)
  legalEntityId    String  @unique
  businessLineId   String?
  accountHolderId  String? @unique
  balanceAccountId String? @unique
  storeId          String?
  storeReference   String?

  // Onboarding
  onboardingStatus   AdyenOnboardingStatus @default(PENDING_HOSTED)
  verificationStatus String?
  capabilities       Json?

  // Sweep
  sweepId              String?
  transferInstrumentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([legalEntityId])
  @@index([accountHolderId])
}

enum AdyenOnboardingStatus {
  PENDING_HOSTED
  IN_PROGRESS
  AWAITING_DATA
  IN_REVIEW
  VERIFIED
  REJECTED
}

// ============================================
// PHASE 9: Staff & Scheduling
// ============================================

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
  VOLUNTEER
}

// Event Staff - many-to-many with roles
model EventStaff {
  id       String         @id @default(cuid())
  eventId  String
  memberId String
  role     EventStaffRole @default(ASSISTANT)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event  Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
}

enum EventStaffRole {
  LEAD
  ASSISTANT
  VOLUNTEER
  OBSERVER
}

// Program Staff - many-to-many with roles (coach assignments)
model ProgramStaff {
  id        String           @id @default(cuid())
  programId String
  memberId  String
  role      ProgramStaffRole @default(ASSISTANT_COACH)
  isPrimary Boolean          @default(false)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  program Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  member  OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([programId, memberId])
  @@index([programId])
  @@index([memberId])
}

enum ProgramStaffRole {
  LEAD_COACH
  ASSISTANT_COACH
  SUBSTITUTE
  VOLUNTEER
}

// Work Shifts - one-time scheduling assignments
model Shift {
  id             String  @id @default(cuid())
  organizationId String
  memberId       String
  facilityId     String?

  // Time
  date      DateTime
  startTime String // "09:00"
  endTime   String // "17:00"

  // Role/Type
  shiftType String // e.g., "Opening Manager", "Coach", "Front Desk"
  notes     String?

  // Status
  status ShiftStatus @default(SCHEDULED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  member       OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  facility     Facility?          @relation(fields: [facilityId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([memberId])
  @@index([date])
}

enum ShiftStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// Recurring Schedule Templates - weekly patterns
model ScheduleTemplate {
  id             String  @id @default(cuid())
  organizationId String
  name           String // e.g., "Standard Week", "Summer Schedule"
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries      ScheduleTemplateEntry[]

  @@index([organizationId])
}

model ScheduleTemplateEntry {
  id         String @id @default(cuid())
  templateId String

  dayOfWeek  Int     // 0=Sunday, 1=Monday, ... 6=Saturday
  startTime  String  // "09:00"
  endTime    String  // "17:00"
  shiftType  String  // Role/position type
  memberId   String? // Optional - can be unassigned
  facilityId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template ScheduleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

// Member Availability - personal weekly availability
model MemberAvailability {
  id       String @id @default(cuid())
  memberId String

  dayOfWeek   Int     // 0=Sunday, 1=Monday, ... 6=Saturday
  startTime   String  // "09:00"
  endTime     String  // "17:00"
  isAvailable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, dayOfWeek])
  @@index([memberId])
}

// ============================================
// PHASE 10: Registration Queue System
// ============================================

// Queue configuration per organization or program
model RegistrationQueueConfig {
  id             String  @id @default(cuid())
  organizationId String
  programId      String? // null = org-wide default

  // Queue settings
  isEnabled          Boolean @default(false)
  reservationMinutes Int     @default(10) // How long a spot is reserved
  maxConcurrent      Int     @default(50) // Max users in registration at once

  // Activation rules
  activationType      QueueActivationType @default(ALWAYS)
  activationThreshold Int? // For THRESHOLD type: activate when X users waiting
  scheduledStart      DateTime? // For SCHEDULED type
  scheduledEnd        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program?     @relation(fields: [programId], references: [id], onDelete: Cascade)
  entries      QueueEntry[]

  @@unique([organizationId, programId])
  @@index([organizationId])
  @@index([programId])
}

enum QueueActivationType {
  ALWAYS // Queue always active when enabled
  THRESHOLD // Activate when concurrent users exceed threshold
  SCHEDULED // Active during scheduled time windows
}

// Track users waiting in queue
model QueueEntry {
  id            String @id @default(cuid())
  queueConfigId String
  sessionToken  String @unique // Browser session identifier

  // User info (may be anonymous until they identify)
  email    String?

  // Queue status
  position Int // Current position in queue
  status   QueueEntryStatus @default(WAITING)

  // Timing
  enteredAt  DateTime  @default(now())
  admittedAt DateTime?
  exitedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  queueConfig RegistrationQueueConfig @relation(fields: [queueConfigId], references: [id], onDelete: Cascade)
  reservation QueueReservation?

  @@index([queueConfigId, status])
  @@index([queueConfigId, status, enteredAt])
  @@index([sessionToken])
  @@index([status])
}

enum QueueEntryStatus {
  WAITING // In queue
  ADMITTED // Let through, has active reservation
  COMPLETED // Successfully registered
  EXPIRED // Reservation timed out
  ABANDONED // Left the queue
}

// Active reservations for users in registration
model QueueReservation {
  id           String @id @default(cuid())
  queueEntryId String @unique
  programId    String

  // Timing
  startedAt   DateTime  @default(now())
  expiresAt   DateTime
  completedAt DateTime?

  // Status
  status ReservationStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  queueEntry QueueEntry @relation(fields: [queueEntryId], references: [id], onDelete: Cascade)
  program    Program    @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId, status])
  @@index([expiresAt])
  @@index([status])
  @@index([status, expiresAt])
}

enum ReservationStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

// ============================================
// PHASE 11: Notification Rules System
// ============================================

// Notification trigger types - what events can trigger a notification
enum NotificationTriggerType {
  // Membership-related
  MEMBERSHIP_EXPIRY // Membership is expiring
  MEMBERSHIP_EXPIRED // Membership has expired

  // Payment-related
  PAYMENT_DUE // Payment is due
  PAYMENT_OVERDUE // Payment is overdue
  PAYMENT_RECEIVED // Payment was received

  // Program-related
  PROGRAM_REMINDER // Upcoming class/session reminder
  PROGRAM_ENROLLMENT // Athlete enrolled in program
  PROGRAM_CANCELLATION // Program/class cancelled

  // Event-related
  EVENT_REMINDER // Upcoming event reminder
  EVENT_REGISTRATION_OPEN // Registration opens for an event
  EVENT_REGISTRATION_CLOSE // Registration closing soon

  // Athlete-related
  ATTENDANCE_MISSED // Athlete missed attendance
  SKILL_ACHIEVED // New skill achievement
  EVALUATION_DUE // Evaluation is due
  EVALUATION_COMPLETED // Evaluation was completed
  BIRTHDAY // Athlete birthday

  // Administrative
  WAITLIST_OPENING // Spot available from waitlist
  CONTRACT_RENEWAL // Contract up for renewal
  MAKEUP_CLASS_EXPIRING // Makeup class credit expiring

  // Custom
  CUSTOM // Custom/manual trigger
}

// Action types - what happens when notification triggers
enum NotificationActionType {
  ANNOUNCEMENT // Post an in-app announcement
  EMAIL // Send an email
  SMS // Send an SMS message
  // PUSH                   // Push notification (future - for mobile app)
}

// Recipient types - who receives the notification
enum NotificationRecipientType {
  ALL_GUARDIANS // All guardians in organization
  ALL_ATHLETES // All athletes (via their guardians)
  PROGRAM_MEMBERS // Athletes/guardians in specific programs
  MEMBERSHIP_HOLDERS // Athletes with specific memberships
  INTERNAL_USERS // Staff, coaches, admins
  CUSTOM // Custom filter combination
}

// Timing direction - before or after the trigger event
enum NotificationTimingDirection {
  BEFORE // X days/hours before event
  AFTER // X days/hours after event
  AT // At the time of event (0 offset)
}

// Timing unit
enum NotificationTimingUnit {
  MINUTES
  HOURS
  DAYS
  WEEKS
  MONTHS
}

// Notification Rule - defines when and how to send notifications
model NotificationRule {
  id             String @id @default(cuid())
  organizationId String

  // Rule identification
  name        String
  description String? @db.Text

  // Trigger configuration
  triggerType NotificationTriggerType

  // Timing configuration
  timingValue     Int                         @default(0) // e.g., 3 (days)
  timingUnit      NotificationTimingUnit      @default(DAYS)
  timingDirection NotificationTimingDirection @default(BEFORE)

  // Action configuration
  actionType NotificationActionType

  // System flag - true for mandatory rules that cannot be disabled/deleted
  isSystem Boolean @default(false)

  // Status
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization         Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template             NotificationTemplate?
  recipientConfig      NotificationRecipientConfig?
  logs                 NotificationLog[]
  deduplicationRecords NotificationDeduplication[]

  @@index([organizationId])
  @@index([triggerType])
  @@index([isSystem])
  @@index([isActive])
}

// Notification Template - the message content with placeholders
model NotificationTemplate {
  id                 String @id @default(cuid())
  notificationRuleId String @unique

  // Email-specific fields
  subject String? // Email subject line (with placeholders)

  // Message content
  body String @db.Text // Main message body (with placeholders)

  // SMS-specific (shorter version)
  smsBody String? @db.Text // SMS-optimized version (shorter)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  notificationRule NotificationRule @relation(fields: [notificationRuleId], references: [id], onDelete: Cascade)
}

// Notification Recipient Config - who receives the notification
model NotificationRecipientConfig {
  id                 String @id @default(cuid())
  notificationRuleId String @unique

  // Primary recipient type
  recipientType NotificationRecipientType @default(ALL_GUARDIANS)

  // Filters (JSON for flexibility)
  // Structure: {
  //   programIds?: string[],
  //   membershipGroupIds?: string[],
  //   membershipStatuses?: string[],
  //   athleteStatuses?: string[],
  //   userRoles?: string[],
  //   includeInactive?: boolean
  // }
  filters Json?

  // Include CC recipients (e.g., always CC the admin)
  ccEmails String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  notificationRule NotificationRule @relation(fields: [notificationRuleId], references: [id], onDelete: Cascade)
}

// Notification Log - tracks sent notifications for auditing
model NotificationLog {
  id                 String  @id @default(cuid())
  organizationId     String
  notificationRuleId String?

  // What was sent
  triggerType NotificationTriggerType
  actionType  NotificationActionType

  // Who received it
  recipientEmail String?
  recipientPhone String?
  recipientName  String?
  athleteId      String?
  userId         String?

  // Message content (rendered)
  subject String?
  body    String  @db.Text

  // Status
  status NotificationLogStatus @default(PENDING)

  // Links to actual message records
  emailMessageId String?
  smsMessageId   String?
  announcementId String?

  // Error tracking
  errorMessage String? @db.Text

  // Timing
  scheduledFor DateTime?
  sentAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notificationRule NotificationRule? @relation(fields: [notificationRuleId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([notificationRuleId])
  @@index([status])
  @@index([triggerType])
  @@index([createdAt])
  @@index([athleteId])
}

enum NotificationLogStatus {
  PENDING // Queued but not sent
  SENT // Successfully sent
  DELIVERED // Confirmed delivered
  FAILED // Failed to send
  SKIPPED // Skipped (e.g., recipient opted out)
}

// Notification Deduplication - prevents sending same notification twice for same entity
model NotificationDeduplication {
  id         String   @id @default(cuid())
  ruleId     String
  entityType String // "membership", "invoice", "event", "athlete" (for birthday), etc.
  entityId   String // The specific entity ID
  userId     String? // The guardian user this dedup record is for
  sentAt     DateTime @default(now())

  // Relations
  rule NotificationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, entityType, entityId, userId])
  @@index([ruleId])
  @@index([sentAt])
}

// ============================================
// PHASE 12: Waivers & Digital Signatures
// ============================================

enum WaiverStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// Waiver - top-level waiver entity owned by an organization
model Waiver {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  status         WaiverStatus @default(DRAFT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  organization                Organization                       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pages                       WaiverPage[]
  programRequirements         ProgramWaiverRequirement[]
  membershipGroupRequirements MembershipGroupWaiverRequirement[]
  signatures                  WaiverSignature[]
  acceptances                 WaiverAcceptance[]

  @@index([organizationId])
  @@index([status])
}

// WaiverPage - individual page of a waiver with rich text content
model WaiverPage {
  id         String  @id @default(cuid())
  waiverId   String
  pageNumber Int // Ordering: 1, 2, 3...
  title      String? // Optional page title (e.g., "Section A: Liability")
  content    String  @db.Text // HTML content from WYSIWYG editor

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  waiver     Waiver            @relation(fields: [waiverId], references: [id], onDelete: Cascade)
  signatures WaiverSignature[]

  @@index([waiverId])
  @@index([waiverId, pageNumber])
}

// ProgramWaiverRequirement - junction table linking Programs to required Waivers
model ProgramWaiverRequirement {
  id        String   @id @default(cuid())
  programId String
  waiverId  String
  createdAt DateTime @default(now())

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  waiver  Waiver  @relation(fields: [waiverId], references: [id], onDelete: Cascade)

  @@unique([programId, waiverId])
  @@index([programId])
  @@index([waiverId])
}

// WaiverSignature - records a customer's signature on a specific waiver page
model WaiverSignature {
  id            String   @id @default(cuid())
  waiverId      String
  waiverPageId  String
  userId        String? // The guardian user who signed
  athleteId     String? // The athlete this signature is for (waivers are per-athlete)
  signatureData String   @db.Text // Base64 PNG from signature canvas
  signedByName  String // Full name of signer
  signedByEmail String // Email of signer
  ipAddress     String? // IP address at time of signing
  userAgent     String? // Browser user agent at time of signing
  signedAt      DateTime @default(now())

  // Relations
  waiver     Waiver     @relation(fields: [waiverId], references: [id], onDelete: Cascade)
  waiverPage WaiverPage @relation(fields: [waiverPageId], references: [id], onDelete: Cascade)
  user       User?      @relation("UserWaiverSignatures", fields: [userId], references: [id], onDelete: SetNull)
  athlete    Athlete?   @relation(fields: [athleteId], references: [id], onDelete: SetNull)

  @@unique([waiverPageId, userId, athleteId])
  @@index([waiverId])
  @@index([waiverPageId])
  @@index([userId])
  @@index([athleteId])
}

// WaiverAcceptance - rolled-up record: user has fully signed all pages of a waiver
// This is the table queried to check "has this customer already signed?" for sign-once behavior
model WaiverAcceptance {
  id          String   @id @default(cuid())
  waiverId    String
  userId      String? // The guardian user who completed the waiver
  athleteId   String? // The athlete this acceptance is for (waivers are per-athlete)
  completedAt DateTime @default(now())

  // Relations
  waiver  Waiver   @relation(fields: [waiverId], references: [id], onDelete: Cascade)
  user    User?    @relation("UserWaiverAcceptances", fields: [userId], references: [id], onDelete: SetNull)
  athlete Athlete? @relation(fields: [athleteId], references: [id], onDelete: SetNull)

  @@unique([waiverId, userId, athleteId])
  @@index([waiverId])
  @@index([userId])
  @@index([athleteId])
  @@index([userId, waiverId])
}

// ============================================
// SPORTS
// ============================================

model Sport {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  description  String?
  icon         String?
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizations OrganizationSport[]

  // Competition category templates for this sport (legacy generic system)
  competitionCategoryTemplates CompetitionCategoryTemplate[]

  // Sport-specific structured data
  events        SportEvent[]
  ageCategories SportAgeCategory[]
}

model OrganizationSport {
  id             String   @id @default(cuid())
  organizationId String
  sportId        String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sport        Sport        @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sportId])
  @@index([sportId])
}

// ============================================
// SPORT-SPECIFIC EVENT & AGE CATEGORY MODELS
// ============================================

// Known events for a sport (e.g. 100m, Shot Put, High Jump for Athletics)
model SportEvent {
  id               String        @id @default(cuid())
  sportId          String
  code             String // e.g. "100M", "HJ", "SP"
  name             String // e.g. "100m", "High Jump", "Shot Put"
  eventGroup       String // e.g. "sprints", "jumps", "throws"
  eventType        String // e.g. "track", "field", "relay", "combined", "road", "racewalk"
  resultType       ResultType // TIME, DISTANCE, HEIGHT, SCORE
  sortDirection    SortDirection // ASC (lower-is-better) or DESC (higher-is-better)
  defaultPrecision Int           @default(3) // decimal places for display
  isActive         Boolean       @default(true)
  displayOrder     Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  sport                 Sport                   @relation(fields: [sportId], references: [id], onDelete: Cascade)
  eligibility           SportEventEligibility[]
  competitionCategories CompetitionCategory[]

  @@unique([sportId, code])
  @@index([sportId])
}

// Age divisions for a sport (e.g. U10, U12, SEN for Athletics)
model SportAgeCategory {
  id           String   @id @default(cuid())
  sportId      String
  code         String // e.g. "U10", "SEN", "MAS"
  name         String // e.g. "Under 10", "Senior", "Masters"
  minAge       Int
  maxAge       Int? // null = no upper limit (e.g. Masters 35+)
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sport                 Sport                   @relation(fields: [sportId], references: [id], onDelete: Cascade)
  eligibility           SportEventEligibility[]
  competitionCategories CompetitionCategory[]

  @@unique([sportId, code])
  @@index([sportId])
}

// Eligibility matrix: which event+age category combos are allowed
model SportEventEligibility {
  id            String  @id @default(cuid())
  sportEventId  String
  ageCategoryId String
  isEnabled     Boolean @default(true)

  sportEvent  SportEvent       @relation(fields: [sportEventId], references: [id], onDelete: Cascade)
  ageCategory SportAgeCategory @relation(fields: [ageCategoryId], references: [id], onDelete: Cascade)

  @@unique([sportEventId, ageCategoryId])
  @@index([sportEventId])
  @@index([ageCategoryId])
}

// ============================================
// COMPETITION RESULT ENUMS
// ============================================

enum ResultType {
  TIME // Time-based: stored as h/m/s/ms components
  DISTANCE // Field events: stored in metres (Decimal)
  HEIGHT // Field events: stored in metres (Decimal)
  SCORE // Combined events: stored as points (Decimal)
  PLACEMENT // Placement: stored as string (e.g. "1" or "3h5")
}

enum SortDirection {
  ASC // Lower is better (TIME)
  DESC // Higher is better (SCORE, DISTANCE, HEIGHT)
}

enum SubmissionMode {
  NONE // No pre-event submission
  VERIFIED_RESULT // Must have a verified prior result
  MANUAL_ENTRY // Self-reported, admin reviews
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CompetitionStatus {
  DRAFT
  PUBLISHED
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CompetitionPricingMode {
  FREE // No charge
  PER_COMPETITION // Flat fee to participate at all
  PER_EVENT // Flat price per event entered
  TIERED // Price tiers based on number of events
  PER_CATEGORY // Specific price per event/age combination
}

enum EntryStatus {
  PENDING_SEED
  PENDING_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
  SCRATCHED
}

// ============================================
// COMPETITION CATEGORIES
// ============================================

enum CategoryTemplateType {
  COMBINATION // Grid of row x column intersections
  INDIVIDUAL // Standalone single entries
}

enum CategoryAxis {
  ROW
  COLUMN
}

// Unified template for sport-level presets (sportId set) and org-level custom (organizationId set)
model CompetitionCategoryTemplate {
  id             String               @id @default(cuid())
  sportId        String? // Non-null = sport-level preset (superadmin)
  organizationId String? // Non-null = org-level custom (dashboard)
  name           String
  description    String?
  type           CategoryTemplateType
  isActive       Boolean              @default(true)
  displayOrder   Int                  @default(0)

  // COMBINATION specific fields
  rowAxisLabel    String? // e.g. "Age Group"
  columnAxisLabel String? // e.g. "Discipline"
  restrictionAxis CategoryAxis? // Which axis's values carry restrictions

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sport        Sport?        @relation(fields: [sportId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  axisValues              CategoryAxisValue[]
  combinationEntries      CategoryCombinationEntry[]
  individualEntries       CategoryIndividualEntry[]
  organizationPreferences OrganizationCategoryPreference[]

  @@index([sportId])
  @@index([organizationId])
}

// Row/column values for COMBINATION templates
model CategoryAxisValue {
  id           String       @id @default(cuid())
  templateId   String
  axis         CategoryAxis // ROW or COLUMN
  name         String // e.g. "Under 8", "Cross Country"
  displayOrder Int          @default(0)

  // Restriction fields (applied when this value's axis matches the template's restrictionAxis)
  minAge         Int?
  maxAge         Int?
  allowedGenders GenderDeclaration[]

  // Result configuration (typically set on the discipline/event axis, not the age group axis)
  resultType    ResultType?
  sortDirection SortDirection?

  template           CompetitionCategoryTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  rowCombinations    CategoryCombinationEntry[]  @relation("CombinationRow")
  columnCombinations CategoryCombinationEntry[]  @relation("CombinationColumn")

  @@index([templateId])
}

// Grid intersection for COMBINATION templates (row x column)
model CategoryCombinationEntry {
  id         String  @id @default(cuid())
  templateId String
  rowValueId String
  colValueId String
  isActive   Boolean @default(true) // Can be disabled (e.g. no 3-year-old Long Jump)
  name       String? // Auto-generated or custom override

  template CompetitionCategoryTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  rowValue CategoryAxisValue           @relation("CombinationRow", fields: [rowValueId], references: [id], onDelete: Cascade)
  colValue CategoryAxisValue           @relation("CombinationColumn", fields: [colValueId], references: [id], onDelete: Cascade)

  // Competition categories that reference this combination entry
  competitionCategories CompetitionCategory[]

  @@unique([templateId, rowValueId, colValueId])
  @@index([templateId])
}

// Standalone entries for INDIVIDUAL templates
model CategoryIndividualEntry {
  id           String  @id @default(cuid())
  templateId   String
  name         String
  description  String?
  displayOrder Int     @default(0)

  // Restriction flags
  hasGenderRestriction   Boolean @default(false)
  hasAgeRestriction      Boolean @default(false)
  hasCapacityRestriction Boolean @default(false)

  // Restriction values
  allowedGenders GenderDeclaration[]
  minAge         Int?
  maxAge         Int?
  capacity       Int?

  // Result configuration
  resultType    ResultType?
  sortDirection SortDirection?

  template CompetitionCategoryTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Competition categories that reference this entry
  competitionCategories CompetitionCategory[]

  @@index([templateId])
}

// Per-organization preference overrides for preset templates (e.g. disabling a sport preset)
model OrganizationCategoryPreference {
  id             String  @id @default(cuid())
  organizationId String
  templateId     String
  isDisabled     Boolean @default(false)

  organization Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     CompetitionCategoryTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([organizationId, templateId])
  @@index([organizationId])
}

// ============================================
// COMPETITIONS
// ============================================

model Competition {
  id              String            @id @default(cuid())
  organizationId  String
  name            String
  color           String            @default("#3b82f6")
  competitionType String // e.g. "GYMNASTICS", "TRACK_AND_FIELD"
  status          CompetitionStatus @default(DRAFT)

  // Location
  facilityId    String?
  country       String?
  stateProvince String?
  city          String?
  streetAddress String?
  postalCode    String?

  // Dates & Times
  startDate DateTime
  endDate   DateTime
  startTime String
  endTime   String

  // Category mode
  categoryMode String @default("ALL") // ALL or SPECIFIC

  // Restrictions
  hasLevelRestriction      Boolean  @default(false)
  levelRequirementIds      String[] // Array of Level IDs
  hasCapacityRestriction   Boolean  @default(false)
  capacity                 Int?
  hasAgeRestriction        Boolean  @default(false)
  minAge                   Int?
  maxAge                   Int?
  hasMembershipRestriction Boolean  @default(false)
  membershipRequirementIds String[] // Array of MembershipInstance IDs
  hasWaiverRestriction     Boolean  @default(false)
  waiverRequirementIds     String[] // Array of Waiver IDs
  hasMedicalRequirement    Boolean  @default(false)
  hasFileRequirement       Boolean  @default(false)
  fileRequirementConfig    Json?

  // Pricing
  pricingMode CompetitionPricingMode @default(FREE)
  entryFee    Decimal?               @db.Decimal(10, 2) // Used for PER_COMPETITION and PER_EVENT modes

  // GL Code
  glCodeId String?

  // Publishing
  publishStatus       String? // LIVE, DRAFT, SCHEDULED
  scheduledGoLiveDate DateTime?
  scheduledGoLiveTime String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facility     Facility?    @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  glCode       GLCode?      @relation(fields: [glCodeId], references: [id], onDelete: SetNull)

  categories        CompetitionCategory[]
  entries           CompetitionEntry[]
  results           CompetitionResult[]
  teams             CompetitionTeam[]
  pricingTiers      CompetitionPricingTier[]
  lineItems         LineItem[]
  registrationFiles RegistrationFile[]

  @@index([organizationId])
  @@index([status])
  @@index([glCodeId])
}

// Links a competition to a specific category entry with result and seed mark configuration
model CompetitionCategory {
  id            String @id @default(cuid())
  competitionId String

  // Reference to template category entry (legacy generic system - one of these will be set)
  combinationEntryId String? // For COMBINATION templates
  individualEntryId  String? // For INDIVIDUAL templates

  // Sport-specific references (new structured system - used instead of legacy refs)
  sportEventId  String? // Reference to SportEvent
  ageCategoryId String? // Reference to SportAgeCategory

  // Result configuration
  resultType    ResultType
  sortDirection SortDirection @default(ASC)
  precision     Int           @default(3) // Decimal places for display

  // Seed mark configuration
  seedMarkRequired Boolean        @default(false)
  submissionMode   SubmissionMode @default(NONE)
  qualifyingMark   Decimal?       @db.Decimal(12, 3)

  // Team configuration
  isTeamEvent Boolean @default(false)
  teamSize    Int? // Number of athletes per team

  // Pricing (used when competition.pricingMode is PER_CATEGORY)
  price Decimal? @db.Decimal(10, 2)

  isActive     Boolean @default(true)
  displayOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  competition      Competition               @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  combinationEntry CategoryCombinationEntry? @relation(fields: [combinationEntryId], references: [id], onDelete: SetNull)
  individualEntry  CategoryIndividualEntry?  @relation(fields: [individualEntryId], references: [id], onDelete: SetNull)
  sportEvent       SportEvent?               @relation(fields: [sportEventId], references: [id], onDelete: SetNull)
  ageCategory      SportAgeCategory?         @relation(fields: [ageCategoryId], references: [id], onDelete: SetNull)

  entries   CompetitionEntry[]
  results   CompetitionResult[]
  teams     CompetitionTeam[]
  lineItems LineItem[]

  @@index([competitionId])
  @@index([sportEventId])
  @@index([ageCategoryId])
}

// Pricing tiers for TIERED pricing mode (discounts for multiple events)
model CompetitionPricingTier {
  id            String @id @default(cuid())
  competitionId String

  minEvents     Int // Minimum events to qualify for this tier
  maxEvents     Int? // Maximum events (null = unlimited)
  pricePerEvent Decimal @db.Decimal(10, 2)
  displayOrder  Int     @default(0)

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
}

// An athlete's entry into a competition category
model CompetitionEntry {
  id                    String  @id @default(cuid())
  competitionId         String
  competitionCategoryId String
  athleteId             String
  teamId                String?

  status EntryStatus @default(PENDING_SEED)

  // Seed mark fields (structured by result type)
  seedHours           Int?
  seedMinutes         Int?
  seedSeconds         Int?
  seedMs              Int?
  seedHandTimed       Boolean           @default(false)
  seedDistance        Decimal?          @db.Decimal(8, 2)
  seedPoints          Decimal?          @db.Decimal(10, 3)
  seedPlacement       String?
  seedMarkSubmittedAt DateTime?
  seedMarkReviewedAt  DateTime?
  seedMarkReviewedBy  String?
  seedMarkStatus      SubmissionStatus?
  seedMarkNotes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  competition Competition         @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  category    CompetitionCategory @relation(fields: [competitionCategoryId], references: [id], onDelete: Cascade)
  athlete     Athlete             @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  team        CompetitionTeam?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([competitionCategoryId, athleteId])
  @@index([competitionId])
  @@index([athleteId])
}

// Team for relay/team events
model CompetitionTeam {
  id                    String @id @default(cuid())
  competitionId         String
  competitionCategoryId String
  name                  String
  organizationId        String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  competition  Competition         @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  category     CompetitionCategory @relation(fields: [competitionCategoryId], references: [id])
  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  entries CompetitionEntry[]
  results CompetitionResult[]

  @@index([competitionId])
  @@index([competitionCategoryId])
}

// Actual competition result
model CompetitionResult {
  id                    String  @id @default(cuid())
  competitionId         String
  competitionCategoryId String
  athleteId             String?
  teamId                String?

  // Result value (universal: ms for TIME, mm for DISTANCE/HEIGHT, raw for SCORE)
  value        Decimal @db.Decimal(12, 3)
  displayValue String? // Pre-formatted string for display

  // Placement
  placement   Int?
  heat        Int?
  isHandTimed Boolean @default(false)

  // Status flags
  isPersonalBest Boolean @default(false)
  isDNF          Boolean @default(false) // Did Not Finish
  isDNS          Boolean @default(false) // Did Not Start
  isDQ           Boolean @default(false) // Disqualified

  // For field events with multiple attempts
  attemptNumber Int?
  isBestAttempt Boolean @default(false)

  notes      String?
  recordedBy String? // Admin/official user ID
  recordedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  competition Competition         @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  category    CompetitionCategory @relation(fields: [competitionCategoryId], references: [id], onDelete: Cascade)
  athlete     Athlete?            @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  team        CompetitionTeam?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([competitionId])
  @@index([competitionCategoryId])
  @@index([athleteId])
  @@index([competitionId, competitionCategoryId, placement])
}

model OrganizationStatusLog {
  id             String   @id @default(cuid())
  organizationId String
  action         String   // "DEACTIVATED" | "REACTIVATED"
  reason         String?
  notes          String?
  performedBy    String
  performedAt    DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("StatusLogPerformer", fields: [performedBy], references: [id])

  @@index([organizationId])
}

model RegistrationFile {
  id             String @id @default(cuid())
  organizationId String
  athleteId      String
  uploadedById   String

  programId     String?
  competitionId String?
  eventId       String?

  fileName    String
  fileSize    Int
  contentType String
  storageKey  String?
  url         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athlete      Athlete      @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation("UserRegistrationFiles", fields: [uploadedById], references: [id], onDelete: Cascade)
  program      Program?     @relation(fields: [programId], references: [id], onDelete: Cascade)
  competition  Competition? @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  event        Event?       @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([athleteId, programId])
  @@unique([athleteId, competitionId])
  @@unique([athleteId, eventId])
  @@index([organizationId])
  @@index([athleteId])
}

// ─── Certifications ──────────────────────────────────────────────────────────

model Certification {
  id             String @id @default(cuid())
  organizationId String
  name           String
  description    String?
  criteria       String?

  evaluationMethod CertificationEvaluationMethod @default(PASS_FAIL)
  pointScaleMin    Int                           @default(1)
  pointScaleMax    Int                           @default(10)
  passThreshold    Int                           @default(7)

  renewalPeriodMonths Int?

  requiredForPrograms     Boolean @default(false)
  requiredForEvents       Boolean @default(false)
  requiredForCompetitions Boolean @default(false)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberCertifications MemberCertification[]

  @@index([organizationId])
}

model MemberCertification {
  id              String  @id @default(cuid())
  certificationId String
  memberId        String
  grantedById     String?

  passed Boolean
  score  Int?
  notes  String?

  grantedAt DateTime  @default(now())
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  certification Certification      @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  member        OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  grantedBy     OrganizationMember? @relation("CertGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([certificationId, memberId])
  @@index([certificationId])
  @@index([memberId])
}

enum CertificationEvaluationMethod {
  PASS_FAIL
  POINT_SCALE
}

// ============================================
// PASSES
// ============================================

enum PassLimitPeriod {
  WEEKLY
  MONTHLY
}

enum PassStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  ARCHIVED
}

model Pass {
  id                String          @id @default(cuid())
  name              String
  description       String?
  price             Decimal         @db.Decimal(10, 2)
  billingInterval   BillingInterval @default(MONTHLY)
  sessionLimit      Int
  limitPeriod       PassLimitPeriod @default(WEEKLY)
  coversAllPrograms Boolean         @default(false)
  status            PassStatus      @default(ACTIVE)
  glCodeId          String?
  organizationId    String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  glCode              GLCode?      @relation(fields: [glCodeId], references: [id], onDelete: SetNull)
  coveredPrograms     Program[]    @relation("PassCoveredPrograms")
  requiredForPrograms Program[]    @relation("PassRequiredForPrograms")
  athletePasses       AthletePass[]
  lineItems           LineItem[]

  @@index([organizationId])
  @@index([status])
  @@index([glCodeId])
}

model AthletePass {
  id        String     @id @default(cuid())
  passId    String
  athleteId String
  userId    String?
  startDate DateTime
  endDate   DateTime?
  status    PassStatus @default(ACTIVE)
  autoRenew Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  pass    Pass     @relation(fields: [passId], references: [id], onDelete: Cascade)
  athlete Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  user    User?    @relation("UserAthletePasses", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([passId, athleteId])
  @@index([passId])
  @@index([athleteId])
  @@index([userId])
  @@index([status])
}

// ============================================
// ACCOUNTING INTEGRATIONS (QBO, Xero)
// ============================================

model AccountingConnection {
  id               String             @id @default(cuid())
  organizationId   String
  provider         AccountingProvider
  tenantId         String
  accessToken      String             @db.Text
  refreshToken     String             @db.Text
  tokenExpiresAt   DateTime
  refreshExpiresAt DateTime
  scope            String
  companyName      String?
  isActive         Boolean            @default(true)
  setupComplete    Boolean            @default(false)
  lastSyncAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization    Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accountMappings AccountingAccountMapping[]
  syncMappings    AccountingSyncMapping[]
  syncQueue       AccountingSyncQueue[]
  syncLogs        AccountingSyncLog[]

  @@unique([organizationId, provider])
  @@index([provider, isActive, setupComplete])
}

model AccountingAccountMapping {
  id                  String               @id @default(cuid())
  connectionId        String
  mappingType         AccountingMappingType
  uplifterEntityId    String?
  externalAccountId   String
  externalAccountName String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  connection AccountingConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, mappingType, uplifterEntityId])
  @@index([connectionId])
}

model AccountingSyncMapping {
  id               String               @id @default(cuid())
  connectionId     String
  entityType       AccountingEntityType
  uplifterEntityId String
  externalEntityId String
  lastSyncedAt     DateTime
  checksum         String?

  connection AccountingConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, entityType, uplifterEntityId])
  @@index([connectionId, entityType])
}

model AccountingSyncQueue {
  id               String               @id @default(cuid())
  connectionId     String
  entityType       AccountingEntityType
  uplifterEntityId String
  action           AccountingSyncAction
  status           AccountingSyncStatus @default(PENDING)
  priority         Int                  @default(0)
  attempts         Int                  @default(0)
  lastAttemptAt    DateTime?
  errorMessage     String?              @db.Text
  createdAt        DateTime             @default(now())

  connection AccountingConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, status])
  @@index([status, priority, createdAt])
}

model AccountingSyncLog {
  id               String               @id @default(cuid())
  connectionId     String
  entityType       AccountingEntityType
  uplifterEntityId String
  action           AccountingSyncAction
  status           AccountingSyncStatus
  externalEntityId String?
  errorMessage     String?              @db.Text
  durationMs       Int?
  createdAt        DateTime             @default(now())

  connection AccountingConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
}

enum AccountingProvider {
  QBO
  XERO
}

enum AccountingEntityType {
  ACCOUNT
  CUSTOMER
  ITEM
  INVOICE
  PAYMENT
  REFUND
  JOURNAL_ENTRY
  DEPOSIT
}

enum AccountingSyncAction {
  CREATE
  UPDATE
}

enum AccountingSyncStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AccountingMappingType {
  GL_CODE
  BANK_ACCOUNT
  PROCESSING_FEES
  REFUNDS
  UNDEPOSITED_FUNDS
}

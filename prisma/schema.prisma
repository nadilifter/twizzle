// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// PHASE 1: Foundation - Organization & Users
// ============================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  
  // Contact
  email         String?
  phone         String?
  
  // Address (structured)
  street        String?
  city          String?
  stateProvince String?
  postalCode    String?
  country       String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  membershipTiers MembershipTier[] // Legacy, to be removed
  membershipGroups MembershipGroup[]
  members     OrganizationMember[]
  users       User[] // Legacy relation, keep for now but rely on members
  families    Family[]
  programs    Program[]
  events      Event[]
  invoices    Invoice[]
  skills      Skill[]
  lessonPlans LessonPlan[]
  announcements Announcement[]
  websiteConfig WebsiteConfig?
  evaluationTemplates EvaluationTemplate[]
  achievements Achievement[]

  // Financials
  discounts       Discount[]
  glCodes         GLCode[]
  ledgerEntries   LedgerEntry[]
  transactions    Transaction[]
  payouts         Payout[]
  recurringCharges RecurringCharge[]
  
  // Athletes (Direct relation for easier querying)
  athletes      Athlete[]
  
  // Platform Subscription
  subscription  OrganizationSubscription?
  
  // POS Products
  products      Product[]
  
  // Media
  media         Media[]
  
  // Facilities
  facilities    Facility[]
  equipment     Equipment[]
  
  // Staff & Scheduling
  staffProfiles     StaffProfile[]
  shifts            Shift[]
  scheduleTemplates ScheduleTemplate[]
  
  // SMS
  smsMessages       SmsMessage[]
  smsCampaigns      SmsCampaign[]
  smsUsage          SmsUsage[]
  
  // Medical
  medicalFormConfig      MedicalFormConfig?
  customMedicalQuestions CustomMedicalQuestion[]
  
  // Registration Queues
  queueConfigs           RegistrationQueueConfig[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           Role         @default(COACH)
  status         MemberStatus @default(ACTIVE)
  joinedAt       DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

enum MemberStatus {
  ACTIVE
  INVITED
  INACTIVE
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String?
  avatar         String?
  role           Role     @default(COACH) // Platform role or fallback
  status         UserStatus @default(ACTIVE)
  organizationId String?   // Made optional - Last active organization
  isSuperAdmin   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastActiveAt   DateTime?

  // Relations
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships   OrganizationMember[]
  permissions   UserPermission[]
  lessonPlans   LessonPlan[]
  evaluations   Evaluation[]
  events        Event[]      @relation("EventCoach")
  sessions      Session[]
  accounts      Account[]
  media         Media[]
  facilityAssignments FacilityAssignment[]
  staffProfile  StaffProfile?
  
  // Announcement relations
  announcementReads       AnnouncementRead[] @relation("AnnouncementReads")
  systemAnnouncementReads SystemAnnouncementRead[] @relation("SystemAnnouncementReads")
  systemAnnouncementsCreated SystemAnnouncement[] @relation("SystemAnnouncementCreator")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserPermission {
  id         String @id @default(cuid())
  userId     String
  permission String // e.g., "athletes.read", "financials.write"
  
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, permission])
}

enum Role {
  ADMIN
  COACH
  VOLUNTEER
  ACCOUNTANT
  CUSTOM
  PARENT
  STAFF
}

enum UserStatus {
  ACTIVE
  INVITED
  INACTIVE
}

// ============================================
// PHASE 2: Core Entities - Athletes & Families
// ============================================

model Family {
  id             String   @id @default(cuid())
  name           String
  primaryContact String
  email          String
  phone          String
  address        String?
  balance        Decimal  @default(0) @db.Decimal(10, 2)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // SMS Preferences
  smsOptOut      Boolean  @default(false) // True if family has opted out of SMS
  smsOptOutAt    DateTime?               // When they opted out

  // Relations
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // athletes       Athlete[] // Deprecated, use guardians
  guardians        AthleteGuardian[]
  paymentMethods   PaymentMethod[]
  invoices         Invoice[]
  payments         Payment[]
  enrollments      Enrollment[] // Enrollments paid/managed by this family
  recurringCharges RecurringCharge[]
  smsMessages      SmsMessage[]

  // Auth Link
  userId         String?   @unique
}

model Athlete {
  id        String       @id @default(cuid())
  name      String
  email     String?
  level     String
  group     String
  status    AthleteStatus @default(ACTIVE)
  avatar    String?
  birthDate DateTime?
  familyId  String? // Deprecated: Use guardians relation
  
  // New fields for refactor
  customId       String?  // Club-specific ID (e.g. Member ID)
  organizationId String?  // Direct organization link
  medicalDetails Json?    // { allergies: [], conditions: [], emergencyContact: {} }
  
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relations
  organization     Organization? @relation(fields: [organizationId], references: [id])
  enrollments      Enrollment[]
  attendances      Attendance[]
  evaluations      Evaluation[]
  lineItems        LineItem[]
  memberships      AthleteMembership[]
  media            Media[]
  recurringCharges RecurringCharge[]
  skillProgress    AthleteSkillProgress[]
  achievements     AthleteAchievement[]
  
  // Multi-family support
  guardians   AthleteGuardian[]
  
  // Medical information
  medicalInfo AthleteMedicalInfo?
}

model AthleteGuardian {
  id           String   @id @default(cuid())
  athleteId    String
  familyId     String
  relationship String?  // e.g. "Parent", "Guardian", "Grandparent"
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  athlete      Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  family       Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([athleteId, familyId])
}

enum AthleteStatus {
  ACTIVE
  INACTIVE
  TRIAL
  GRADUATED
}

// ============================================
// Medical Information System
// ============================================

// Question types for custom medical questions
enum MedicalQuestionType {
  TEXT
  YES_NO
  MULTIPLE_CHOICE
  CHECKBOX
}

// Organization-level medical form configuration
model MedicalFormConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique
  
  // Standard questions toggles
  collectAllergies          Boolean @default(true)
  collectMedications        Boolean @default(true)
  collectConditions         Boolean @default(true)
  collectEmergencyContact   Boolean @default(true)
  collectDietaryRestrictions Boolean @default(false)
  collectInsuranceInfo      Boolean @default(false)
  
  // Registration integration
  requireDuringRegistration Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Custom medical questions defined by organization
model CustomMedicalQuestion {
  id             String   @id @default(cuid())
  organizationId String
  
  questionText   String
  questionType   MedicalQuestionType @default(TEXT)
  options        Json?    // For MULTIPLE_CHOICE/CHECKBOX types: string[]
  required       Boolean  @default(false)
  displayOrder   Int      @default(0)
  isActive       Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  responses    CustomMedicalResponse[]

  @@index([organizationId])
}

// Structured medical data per athlete
model AthleteMedicalInfo {
  id        String   @id @default(cuid())
  athleteId String   @unique
  
  // Standard fields (arrays for multiple entries)
  allergies              String[] // Food, environmental, medication allergies
  medications            String[] // Current medications
  conditions             String[] // Medical conditions (asthma, diabetes, etc.)
  dietaryRestrictions    String[] // Dietary restrictions
  
  // Insurance info
  insuranceProvider      String?
  insurancePolicyNumber  String?
  
  // Emergency contact (structured from JSON)
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  
  // Additional notes
  additionalNotes        String?  @db.Text
  
  // Metadata
  lastUpdatedBy String?  // User ID who last updated
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  athlete         Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  customResponses CustomMedicalResponse[]

  @@index([athleteId])
}

// Answers to custom medical questions
model CustomMedicalResponse {
  id            String   @id @default(cuid())
  medicalInfoId String
  questionId    String
  
  response      String   // Stored as string, parsed based on question type
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  medicalInfo AthleteMedicalInfo    @relation(fields: [medicalInfoId], references: [id], onDelete: Cascade)
  question    CustomMedicalQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([medicalInfoId, questionId])
  @@index([medicalInfoId])
  @@index([questionId])
}

model PaymentMethod {
  id        String  @id @default(cuid())
  familyId  String
  type      PaymentMethodType
  last4     String
  expiry    String?
  brand     String?
  isDefault Boolean @default(false)
  createdAt DateTime @default(now())

  // Relations
  family           Family            @relation(fields: [familyId], references: [id], onDelete: Cascade)
  recurringCharges RecurringCharge[]
}

enum PaymentMethodType {
  CARD
  BANK
}

// ============================================
// PHASE 2: Programs & Memberships
// ============================================

model Program {
  id             String   @id @default(cuid())
  name           String
  description    String?
  level          String
  status         ProgramStatus @default(ACTIVE)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events              Event[]
  lessonPlans         LessonPlan[]
  enrollments         Enrollment[]
  lineItems           LineItem[]
  membershipTiers     MembershipTier[] // Legacy
  staffAssignments    ProgramStaff[]
  requiredMemberships MembershipInstance[]
  evaluations         Evaluation[]
  evaluationTemplates ProgramEvaluationTemplate[]
  
  // Registration Queue
  queueConfigs        RegistrationQueueConfig[]
  queueReservations   QueueReservation[]
}

enum ProgramStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

// Legacy - to be deprecated
model MembershipTier {
  id          String   @id @default(cuid())
  programId   String?
  name        String
  price       Decimal  @db.Decimal(10, 2)
  interval    BillingInterval
  description String?
  features    String[] // Array of feature strings
  organizationId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program     Program?  @relation(fields: [programId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
}

// New Membership Structure
model MembershipGroup {
  id             String   @id @default(cuid())
  organizationId String
  name           String   // e.g., "Annual Membership"
  description    String?
  programTypes   String[] // Relevant program types
  
  // Logic & Defaults
  allowAutoRenew Boolean  @default(false)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  instances      MembershipInstance[]
}

model MembershipInstance {
  id                String   @id @default(cuid())
  membershipGroupId String
  name              String   // e.g., "FY25"
  
  // Billing
  price             Decimal  @db.Decimal(10, 2)
  billingInterval   BillingInterval
  
  // Validity
  startDate         DateTime
  endDate           DateTime
  
  // Renewal Logic
  autoRenewDate     DateTime? // When to trigger creation of next instance (if handled by system)
  
  status            MembershipStatus @default(ACTIVE)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  group             MembershipGroup @relation(fields: [membershipGroupId], references: [id], onDelete: Cascade)
  athleteMemberships AthleteMembership[]
  requiredForEvents Event[]
  requiredForPrograms Program[]
}

model AthleteMembership {
  id                   String   @id @default(cuid())
  athleteId            String
  membershipInstanceId String
  
  startDate            DateTime
  endDate              DateTime?
  status               MembershipStatus @default(ACTIVE)
  
  // Auto-renewal for the athlete
  autoRenew            Boolean @default(false)
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  athlete              Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  instance             MembershipInstance @relation(fields: [membershipInstanceId], references: [id], onDelete: Cascade)
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  ARCHIVED
}

enum BillingInterval {
  MONTHLY
  YEARLY
  SESSION
}

model Enrollment {
  id                String    @id @default(cuid())
  athleteId         String
  programId         String
  membershipTierId  String?   // Legacy
  familyId          String?   // The family responsible for this enrollment
  startDate         DateTime
  endDate           DateTime?
  status            EnrollmentStatus @default(ACTIVE)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  athlete        Athlete        @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  program        Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  membershipTier MembershipTier? @relation(fields: [membershipTierId], references: [id])
  family         Family?        @relation(fields: [familyId], references: [id])
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}

// ============================================
// PHASE 3: Events & Attendance
// ============================================

model Event {
  id             String    @id @default(cuid())
  title          String
  date           DateTime
  startTime      String
  endTime        String
  type           EventType @default(CLASS)
  description    String?
  meetingLink    String?
  timezone       String?
  capacity       Int?
  location       Json?     // { lat, lng, address, name } - for external/custom locations
  details        Json?     // { whatToBring, whatToExpect, requirements }
  programId      String?
  coachId        String?
  facilityId     String?   // Optional - links to a Facility for scheduling
  requiredMemberships MembershipInstance[]
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program?     @relation(fields: [programId], references: [id])
  coach        User?        @relation("EventCoach", fields: [coachId], references: [id])
  facility     Facility?    @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  attendances  Attendance[]
  lineItems    LineItem[]
  media        Media[]
  staffAssignments EventStaff[]
}

enum EventType {
  CLASS
  CAMP
  PARTY
  COMPETITION
  MEETING
  OTHER
}

model Attendance {
  id        String           @id @default(cuid())
  athleteId String
  eventId   String
  status    AttendanceStatus @default(PRESENT)
  checkedIn DateTime?
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([athleteId, eventId])
}

enum AttendanceStatus {
  REGISTERED
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// ============================================
// PHASE 4: Financial System
// ============================================

model Invoice {
  id             String        @id @default(cuid())
  reference      String        @unique
  familyId       String
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime
  subtotal       Decimal       @db.Decimal(10, 2)
  tax            Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  notes          String?
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  family       Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  lineItems    LineItem[]
  payments     Payment[]
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  PARTIAL
}

model LineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  programId   String? // What program is this for?
  eventId     String? // What specific event?
  athleteId   String? // Which athlete?
  discountId  String? // Applied discount
  createdAt   DateTime @default(now())

  // Relations
  invoice  Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  program  Program? @relation(fields: [programId], references: [id])
  event    Event?   @relation(fields: [eventId], references: [id])
  athlete  Athlete? @relation(fields: [athleteId], references: [id])
  discount Discount? @relation(fields: [discountId], references: [id])
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String?
  familyId      String
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentType
  status        PaymentStatus @default(PENDING)
  transactionId String?       // Legacy field, keeping for backwards compatibility
  processedAt   DateTime?
  createdAt     DateTime      @default(now())

  // Relations
  invoice     Invoice?     @relation(fields: [invoiceId], references: [id])
  family      Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  transaction Transaction? // Linked Adyen transaction
}

enum PaymentType {
  CARD
  BANK
  CASH
  CHECK
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Discount {
  id           String       @id @default(cuid())
  name         String
  code         String       @unique
  type         DiscountType
  amount       Decimal      @db.Decimal(10, 2)
  validFrom    DateTime
  validTo      DateTime?
  userScope    UserScope    @default(ALL)
  productScope ProductScope @default(ALL)
  usageLimit   Int?
  usageCount   Int          @default(0)
  status       DiscountStatus @default(ACTIVE)
  organizationId String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lineItems    LineItem[]
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum UserScope {
  ALL
  NEW_USERS
  MEMBERS
  VIP
}

enum ProductScope {
  ALL
  MERCHANDISE
  EVENTS
  MEMBERSHIP
}

enum DiscountStatus {
  ACTIVE
  EXPIRED
  SCHEDULED
  DRAFT
}

model GLCode {
  id          String       @id @default(cuid())
  code        String       @unique
  description String
  type        GLCodeType
  status      GLCodeStatus @default(ACTIVE)
  organizationId String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ledgerEntries LedgerEntry[]
}

enum GLCodeType {
  REVENUE
  EXPENSE
  LIABILITY
  ASSET
  EQUITY
}

enum GLCodeStatus {
  ACTIVE
  INACTIVE
}

model LedgerEntry {
  id          String            @id @default(cuid())
  date        DateTime
  description String
  glCodeId    String
  reference   String?
  debit       Decimal?          @db.Decimal(10, 2)
  credit      Decimal?          @db.Decimal(10, 2)
  status      LedgerEntryStatus @default(PENDING)
  organizationId String
  createdAt   DateTime          @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  glCode GLCode @relation(fields: [glCodeId], references: [id])
}

enum LedgerEntryStatus {
  POSTED
  PENDING
}

// ============================================
// Adyen Transaction Tracking
// ============================================

model Transaction {
  id              String            @id @default(cuid())
  organizationId  String
  paymentId       String?           @unique
  pspReference    String            @unique // Adyen PSP reference
  merchantRef     String?           // Our internal reference
  type            TransactionType
  amount          Decimal           @db.Decimal(10, 2)
  currency        String            @default("USD")
  status          TransactionStatus
  method          String?           // visa, mastercard, applepay, etc.
  description     String?
  metadata        Json?
  settledAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payment      Payment?     @relation(fields: [paymentId], references: [id])

  @@index([organizationId])
  @@index([pspReference])
}

enum TransactionType {
  PAYMENT
  REFUND
  CHARGEBACK
  CAPTURE
  CANCEL
}

enum TransactionStatus {
  AUTHORISED
  CAPTURED
  SETTLED
  REFUSED
  CANCELLED
  ERROR
  PENDING
}

// ============================================
// Payouts (Settlement from Adyen)
// ============================================

model Payout {
  id             String       @id @default(cuid())
  organizationId String
  reference      String       @unique // Adyen payout reference
  amount         Decimal      @db.Decimal(10, 2)
  fees           Decimal      @default(0) @db.Decimal(10, 2)
  net            Decimal      @db.Decimal(10, 2)
  currency       String       @default("USD")
  status         PayoutStatus
  bankAccount    String?      // Last 4 digits
  scheduledAt    DateTime?
  paidAt         DateTime?
  createdAt      DateTime     @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

enum PayoutStatus {
  PENDING
  SCHEDULED
  PAID
  FAILED
}

// ============================================
// Recurring Billing
// ============================================

model RecurringCharge {
  id              String          @id @default(cuid())
  organizationId  String
  familyId        String
  athleteId       String?
  description     String
  amount          Decimal         @db.Decimal(10, 2)
  frequency       BillingInterval // MONTHLY, YEARLY, SESSION
  nextChargeDate  DateTime
  lastChargedAt   DateTime?
  status          RecurringStatus
  paymentMethodId String?
  failureCount    Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  family        Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  athlete       Athlete?       @relation(fields: [athleteId], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@index([organizationId])
  @@index([familyId])
  @@index([nextChargeDate])
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  CANCELLED
  FAILED
}

// ============================================
// PHASE 5: Training & Evaluations
// ============================================

model Skill {
  id             String   @id @default(cuid())
  name           String
  category       String   // e.g., "Vault", "Bars", "Beam", "Floor"
  level          String?  // Legacy field
  description    String?  @db.Text
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Difficulty and age targeting
  difficultyLevel SkillDifficulty @default(BEGINNER)
  minAge          Int?     // Suggested minimum age
  maxAge          Int?     // Suggested maximum age
  videoUrl        String?  // Demo video URL
  imageUrl        String?  // Demo image URL

  // Relations
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  evaluationSkills EvaluationSkill[]
  rotationSkills   RotationSkill[]
  templateSkills   EvaluationTemplateSkill[]
  athleteProgress  AthleteSkillProgress[]
}

enum SkillDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// Evaluation Templates - reusable groupings of skills for assessments
model EvaluationTemplate {
  id              String          @id @default(cuid())
  name            String
  description     String?         @db.Text
  difficultyLevel SkillDifficulty @default(BEGINNER)
  minAge          Int?
  maxAge          Int?
  isActive        Boolean         @default(true)
  organizationId  String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Auto-sync configuration
  autoSyncEnabled    Boolean   @default(false)
  autoSyncLevels     String[]  @default([])  // e.g., ["BEGINNER", "INTERMEDIATE"]
  autoSyncCategories String[]  @default([])  // e.g., ["Vault", "Bars"]

  // Scoring configuration
  scoringType             ScoringType    @default(PASS_FAIL)
  pointScaleMin           Int            @default(1)
  pointScaleMax           Int            @default(10)
  pointScalePassThreshold Int            @default(7)

  // Completion requirements for achievements
  completionType      CompletionType @default(PERCENTAGE)
  completionThreshold Decimal        @default(80) @db.Decimal(5, 2)

  // Relations
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  skills           EvaluationTemplateSkill[]
  evaluations      Evaluation[]
  programTemplates ProgramEvaluationTemplate[]
  achievements     Achievement[]
  
  @@index([organizationId])
}

// Junction table for skills in evaluation templates
model EvaluationTemplateSkill {
  id         String  @id @default(cuid())
  templateId String
  skillId    String
  order      Int     @default(0)  // Display order
  isRequired Boolean @default(true)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  template   EvaluationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  skill      Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([templateId, skillId])
  @@index([templateId])
  @@index([skillId])
}

// Junction table for linking evaluation templates to programs
model ProgramEvaluationTemplate {
  id          String    @id @default(cuid())
  programId   String
  templateId  String
  isRequired  Boolean   @default(false)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  program     Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  template    EvaluationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([programId, templateId])
  @@index([programId])
  @@index([templateId])
}

model LessonPlan {
  id             String           @id @default(cuid())
  name           String
  programId      String
  date           DateTime?
  authorId       String
  status         LessonPlanStatus @default(DRAFT)
  theme          String?
  notes          String?
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program      @relation(fields: [programId], references: [id])
  author       User         @relation(fields: [authorId], references: [id])
  rotations    Rotation[]
}

enum LessonPlanStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

model Rotation {
  id           String   @id @default(cuid())
  lessonPlanId String
  name         String
  description  String?
  order        Int      @default(0)
  media        String[] // Array of media URLs
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  lessonPlan LessonPlan      @relation(fields: [lessonPlanId], references: [id], onDelete: Cascade)
  skills     RotationSkill[]
}

model RotationSkill {
  id         String @id @default(cuid())
  rotationId String
  skillId    String

  // Relations
  rotation Rotation @relation(fields: [rotationId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([rotationId, skillId])
}

model Evaluation {
  id           String           @id @default(cuid())
  athleteId    String
  coachId      String
  templateId   String?          // Optional link to evaluation template
  programId    String?          // Optional link to program
  date         DateTime
  level        String
  overallScore Decimal          @db.Decimal(3, 1)
  status       EvaluationStatus
  notes        String?          @db.Text
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Relations
  athlete             Athlete              @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  coach               User                 @relation(fields: [coachId], references: [id])
  template            EvaluationTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  program             Program?             @relation(fields: [programId], references: [id], onDelete: SetNull)
  skillRatings        EvaluationSkill[]
  athleteAchievements AthleteAchievement[]
  
  @@index([athleteId])
  @@index([coachId])
  @@index([templateId])
  @@index([programId])
}

enum EvaluationStatus {
  PENDING      // Evaluation assigned but not completed
  IN_PROGRESS  // Evaluation started
  PASS
  RETRY
  EXCELLENT
  SATISFACTORY
}

model EvaluationSkill {
  id            String             @id @default(cuid())
  evaluationId  String
  skillId       String
  rating        Int?               // Legacy: 1-5, optional (can use attemptStatus instead)
  pointScore    Int?               // For POINT_SCALE scoring type
  attemptStatus SkillAttemptStatus @default(NOT_ATTEMPTED)
  passed        Boolean            @default(false) // Computed based on scoring type
  comment       String?

  // Relations
  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id])

  @@unique([evaluationId, skillId])
  @@index([evaluationId])
  @@index([skillId])
}

enum SkillAttemptStatus {
  NOT_ATTEMPTED
  ATTEMPTED
  SUCCEEDED
}

// Scoring types for evaluations
enum ScoringType {
  PASS_FAIL    // 3 states: NOT_ATTEMPTED, ATTEMPTED, PASSED
  POINT_SCALE  // Configurable range with pass threshold
}

// Completion requirement types for achievements
enum CompletionType {
  PERCENTAGE   // e.g., 80% of skills passed
  COUNT        // e.g., 15 skills passed
  ALL          // All required skills passed
}

// Track athlete progress on individual skills across all evaluations
model AthleteSkillProgress {
  id               String             @id @default(cuid())
  athleteId        String
  skillId          String
  bestStatus       SkillAttemptStatus @default(NOT_ATTEMPTED)
  firstAttemptedAt DateTime?
  firstSucceededAt DateTime?
  attemptCount     Int                @default(0)
  successCount     Int                @default(0)
  lastEvaluatedAt  DateTime
  lastEvaluationId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Relations
  athlete        Athlete     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  skill          Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([athleteId, skillId])
  @@index([athleteId])
  @@index([skillId])
}

// Achievement definitions linked to evaluation templates
model Achievement {
  id             String   @id @default(cuid())
  templateId     String
  name           String
  description    String?  @db.Text
  badgeImageUrl  String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  template            EvaluationTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athleteAchievements AthleteAchievement[]

  @@index([templateId])
  @@index([organizationId])
}

// Track athlete achievements earned
model AthleteAchievement {
  id                    String   @id @default(cuid())
  athleteId             String
  achievementId         String
  evaluationId          String?  // The evaluation that earned this achievement
  earnedAt              DateTime @default(now())
  
  // Best results by category at time of earning
  bestResultsByCategory Json?    // { "Vault": 9.5, "Bars": 8.0, ... }
  overallScore          Decimal? @db.Decimal(5, 2)

  // Relations
  athlete     Athlete      @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  achievement Achievement  @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  evaluation  Evaluation?  @relation(fields: [evaluationId], references: [id], onDelete: SetNull)

  @@unique([athleteId, achievementId])
  @@index([athleteId])
  @@index([achievementId])
  @@index([evaluationId])
}

// ============================================
// PHASE 6: Communication
// ============================================

model Announcement {
  id             String              @id @default(cuid())
  title          String
  content        String              // HTML content from WYSIWYG
  targetScope    AnnouncementScope   @default(ALL)
  targetProgramId String?
  targetEventId  String?
  status         AnnouncementStatus  @default(DRAFT)
  priority       AnnouncementPriority @default(NORMAL)
  publishedAt    DateTime?
  expiresAt      DateTime?
  organizationId String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  readBy       AnnouncementRead[]
}

model AnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())
  
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User @relation("AnnouncementReads", fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([announcementId, userId])
  @@index([userId])
  @@index([announcementId])
}

// System-wide announcements from superadmins (sent to all organizations)
model SystemAnnouncement {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text // HTML content from WYSIWYG
  priority    AnnouncementPriority @default(NORMAL)
  status      AnnouncementStatus @default(DRAFT)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Track who created it
  createdById String
  createdBy   User @relation("SystemAnnouncementCreator", fields: [createdById], references: [id])
  
  // Read tracking
  readBy      SystemAnnouncementRead[]
}

model SystemAnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())
  
  announcement   SystemAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User @relation("SystemAnnouncementReads", fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([announcementId, userId])
  @@index([userId])
  @@index([announcementId])
}

enum AnnouncementScope {
  ALL
  PROGRAM
  EVENT
  FAMILY
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================
// SMS Messaging
// ============================================

model SmsMessage {
  id             String           @id @default(cuid())
  organizationId String
  familyId       String?          // Recipient family (if outbound)
  staffProfileId String?          // Recipient staff (if outbound)
  campaignId     String?          // Part of a campaign
  
  // Message details
  to             String           // E.164 format phone number
  from           String           // Twilio number used
  body           String           @db.Text
  segments       Int              @default(1) // SMS segment count
  
  // Twilio tracking
  twilioSid      String?          @unique // Twilio message SID
  twilioStatus   SmsStatus        @default(QUEUED)
  
  // Direction
  direction      SmsDirection     @default(OUTBOUND)
  
  // Classification
  classification SmsClassification @default(GENERAL)
  
  // Cost tracking (in cents)
  cost           Decimal?         @db.Decimal(10, 4)
  
  // Timestamps
  sentAt         DateTime?
  deliveredAt    DateTime?
  failedAt       DateTime?
  
  // Error handling
  errorCode      String?
  errorMessage   String?
  
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  family         Family?          @relation(fields: [familyId], references: [id], onDelete: SetNull)
  campaign       SmsCampaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([familyId])
  @@index([campaignId])
  @@index([twilioSid])
  @@index([twilioStatus])
  @@index([createdAt])
}

enum SmsStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  UNDELIVERED
  FAILED
}

enum SmsDirection {
  OUTBOUND
  INBOUND
}

enum SmsClassification {
  GENERAL
  REMINDER
  ALERT
  BILLING
  EVENT
  NEWS
}

model SmsCampaign {
  id              String              @id @default(cuid())
  organizationId  String
  name            String
  body            String              @db.Text
  classification  SmsClassification   @default(GENERAL)
  
  // Targeting
  targetScope     AnnouncementScope   @default(ALL) // Reuse existing enum
  targetProgramId String?
  targetEventId   String?
  
  // Status
  status          SmsCampaignStatus   @default(DRAFT)
  
  // Statistics
  totalRecipients Int                 @default(0)
  sentCount       Int                 @default(0)
  deliveredCount  Int                 @default(0)
  failedCount     Int                 @default(0)
  
  // Scheduling
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  
  // Author
  createdById     String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages        SmsMessage[]

  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
}

enum SmsCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
  CANCELLED
}

model SmsUsage {
  id               String   @id @default(cuid())
  organizationId   String
  
  // Period tracking
  periodStart      DateTime
  periodEnd        DateTime
  
  // Counts
  messagesSent     Int      @default(0)
  messagesDelivered Int     @default(0)
  messagesFailed   Int      @default(0)
  totalSegments    Int      @default(0)
  
  // Cost tracking (in dollars)
  totalCost        Decimal  @default(0) @db.Decimal(10, 2)
  
  // Plan-based tracking
  includedMessages Int      @default(0) // From plan
  overageMessages  Int      @default(0) // Beyond plan limit
  overageCost      Decimal  @default(0) @db.Decimal(10, 2)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, periodStart])
  @@index([organizationId])
  @@index([periodStart])
}

// ============================================
// PHASE 7: Website Builder
// ============================================

model WebsiteConfig {
  id                String   @id @default(cuid())
  organizationId    String   @unique
  
  // Theming
  primaryColor      String?  @default("#000000")
  secondaryColor    String?  @default("#ffffff")
  
  // Assets
  logo              String?
  favicon           String?
  
  // Content
  heroImage         String?
  heroHeadline      String?
  heroSubheadline   String?
  heroText          String?  @db.Text
  heroAgeRange      String?  // e.g., "All Ages Welcome", "Ages 5-18"
  heroProgramPeriods String? // e.g., "Year-Round Programs", "Fall & Spring Sessions"
  heroLocation      String?  // e.g., "Austin, TX"
  
  // Visibility
  showCalendar      Boolean  @default(true)
  showRegistration  Boolean  @default(true)
  showLogin         Boolean  @default(true)
  showContact       Boolean  @default(true)
  
  // Domain
  domain            String?  @unique
  subdomain         String?  @unique // prefix to uplifterinc.com
  emailSenderDomain String?
  
  // Status
  isPublished       Boolean  @default(false)
  
  // SEO
  seoDescription    String?  @db.Text  // Custom meta description for search engines
  seoKeywords       String?            // Comma-separated keywords
  googleVerification String?           // Google Search Console verification code
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ============================================
// POS Products & Inventory
// ============================================

model Product {
  id               String   @id @default(cuid())
  organizationId   String
  name             String
  description      String?
  sku              String?
  category         String   @default("General")
  price            Decimal  @db.Decimal(10, 2)
  imageUrl         String?
  maxInventory     Int?     // null = unlimited
  currentInventory Int?     // null = unlimited
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stockMovements  StockMovement[]

  @@unique([organizationId, sku])
  @@index([organizationId])
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  type        StockMovementType
  quantity    Int               // positive for additions, negative for sales
  previousQty Int
  newQty      Int
  referenceId String?           // invoiceId, orderId, etc.
  notes       String?
  createdBy   String?
  createdAt   DateTime          @default(now())

  // Relations
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

enum StockMovementType {
  SALE
  RESTOCK
  ADJUSTMENT
  RETURN
}

// ============================================
// PHASE 8: Feedback & Feature Requests
// ============================================

model FeatureRequest {
  id          String    @id @default(cuid())
  title       String
  description String
  status      FeatureStatus @default(OPEN)
  votes       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String?   // Author
  
  comments    FeatureComment[]
}

enum FeatureStatus {
  OPEN
  IN_PROGRESS
  DONE
  CLOSED
}

model FeatureComment {
  id               String         @id @default(cuid())
  featureRequestId String
  content          String
  userId           String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
}


// ============================================
// Media
// ============================================

model Media {
  id             String    @id @default(cuid())
  url            String
  type           MediaType
  title          String?
  description    String?
  athleteId      String?
  eventId        String?
  uploadedById   String
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  athlete      Athlete?      @relation(fields: [athleteId], references: [id], onDelete: SetNull)
  event        Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  uploadedBy   User          @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([athleteId])
  @@index([eventId])
  @@index([uploadedById])
}

enum MediaType {
  IMAGE
  VIDEO
}

// ============================================
// Facilities & Equipment
// ============================================

model Facility {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  
  // Address
  street         String?
  city           String?
  stateProvince  String?
  postalCode     String?
  country        String?
  
  // Contact
  phone          String?
  email          String?
  
  // Status & Metadata
  status         FacilityStatus @default(ACTIVE)
  isDefault      Boolean        @default(false)
  squareFootage  Int?
  maxCapacity    Int?
  description    String?
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trainingZones  TrainingZone[]
  equipment      Equipment[]
  assignments    FacilityAssignment[]
  events         Event[]
  shifts         Shift[]

  @@index([organizationId])
}

enum FacilityStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

model TrainingZone {
  id          String     @id @default(cuid())
  facilityId  String
  name        String
  type        String     // e.g., "Floor", "Vault", "Bars", "Beam", "Trampoline"
  capacity    Int?
  status      ZoneStatus @default(OPEN)
  description String?
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  facility    Facility   @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  equipment   Equipment[]

  @@index([facilityId])
}

enum ZoneStatus {
  OPEN
  CLOSED
  MAINTENANCE
}

model Equipment {
  id                 String             @id @default(cuid())
  organizationId     String
  facilityId         String?            // Optional - null means org-level equipment
  trainingZoneId     String?            // Optional - for zone assignment within facility
  
  name               String
  type               String             // e.g., "Apparatus", "Mat", "Training Aid"
  serialNumber       String?
  condition          EquipmentCondition @default(GOOD)
  status             EquipmentStatus    @default(ACTIVE)
  
  // Tracking
  purchaseDate       DateTime?
  lastInspectionDate DateTime?
  notes              String?
  
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facility           Facility?          @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  trainingZone       TrainingZone?      @relation(fields: [trainingZoneId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([facilityId])
  @@index([trainingZoneId])
}

enum EquipmentCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  UNSAFE
}

enum EquipmentStatus {
  ACTIVE
  RETIRED
  MAINTENANCE
}

model FacilityAssignment {
  id         String   @id @default(cuid())
  facilityId String
  userId     String
  isPrimary  Boolean  @default(false)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([facilityId, userId])
  @@index([facilityId])
  @@index([userId])
}

// ============================================
// Reserved Domains/Prefixes
// ============================================

model ReservedDomain {
  id          String             @id @default(cuid())
  pattern     String             @unique // The reserved domain or prefix pattern
  type        ReservedDomainType @default(EXACT)
  reason      String?            // Why this is reserved (e.g., "Brand protection", "System use")
  createdBy   String?            // User ID who created this reservation
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum ReservedDomainType {
  EXACT   // Exact match (e.g., "admin" blocks only "admin")
  PREFIX  // Prefix match (e.g., "test-" blocks "test-anything")
}

// ============================================
// Platform Subscription & Billing
// ============================================

model SubscriptionPlan {
  id                String   @id @default(cuid())
  name              String   // e.g., "Free", "Starter", "Gold", "Platinum"
  slug              String   @unique // URL-friendly identifier
  description       String?
  
  // Pricing
  monthlyPrice      Decimal  @db.Decimal(10, 2)
  yearlyPrice       Decimal? @db.Decimal(10, 2) // Optional yearly discount
  transactionFee    Decimal  @db.Decimal(5, 4) // e.g., 0.029 for 2.9%
  perTransactionFee Decimal  @db.Decimal(10, 2) // e.g., 0.30 for $0.30
  
  // Limits
  maxAthletes       Int?     // null = unlimited
  maxUsers          Int?     // null = unlimited
  maxEvents         Int?     // null = unlimited
  
  // SMS Limits
  smsIncluded       Int?     // Messages included per month (null = no SMS)
  smsOverageRate    Decimal? @db.Decimal(10, 4) // Cost per message over limit (e.g., 0.05 for $0.05)
  
  // Features (stored as JSON for flexibility)
  features          Json     // Array of feature strings
  
  // Display
  isPopular         Boolean  @default(false)
  displayOrder      Int      @default(0)
  
  // Status
  isActive          Boolean  @default(true)
  isPublic          Boolean  @default(true) // Can orgs self-select this plan?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  subscriptions     OrganizationSubscription[]
}

model OrganizationSubscription {
  id                String             @id @default(cuid())
  organizationId    String             @unique
  planId            String
  
  // Billing
  status            SubscriptionStatus @default(ACTIVE)
  billingCycle      BillingCycle       @default(MONTHLY)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  
  // Payment info (stored tokens, not actual card data)
  stripeCustomerId  String?
  stripeSubscriptionId String?
  
  // Admin controls
  isLocked          Boolean  @default(false) // If true, org cannot change plan
  lockedReason      String?  // Why it's locked (shown to org admins)
  lockedBy          String?  // Super admin who locked it
  lockedAt          DateTime?
  
  // Trial
  trialEndsAt       DateTime?
  
  // Cancellation
  cancelAtPeriodEnd Boolean  @default(false)
  cancelledAt       DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan              SubscriptionPlan @relation(fields: [planId], references: [id])
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  PAUSED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

// ============================================
// PHASE 9: Staff & Scheduling
// ============================================

// Staff Profile - extends User with staff-specific data
model StaffProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  organizationId String
  
  // Employment
  employmentType EmploymentType @default(FULL_TIME)
  title          String?        // e.g., "Head Coach", "Assistant Coach"
  hourlyRate     Decimal?       @db.Decimal(10, 2)
  hireDate       DateTime?
  
  // Certifications (JSON array for flexibility)
  certifications Json?    // [{ name, expiresAt, verified }]
  
  // Contact (override user contact if needed)
  phone          String?
  emergencyContact Json?  // { name, phone, relationship }
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shifts           Shift[]
  availability     StaffAvailability[]
  eventAssignments EventStaff[]
  programAssignments ProgramStaff[]

  @@index([organizationId])
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
  VOLUNTEER
}

// Event Staff - many-to-many with roles
model EventStaff {
  id             String   @id @default(cuid())
  eventId        String
  staffProfileId String
  role           EventStaffRole @default(ASSISTANT)
  notes          String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@unique([eventId, staffProfileId])
  @@index([eventId])
  @@index([staffProfileId])
}

enum EventStaffRole {
  LEAD
  ASSISTANT
  VOLUNTEER
  OBSERVER
}

// Program Staff - many-to-many with roles (coach assignments)
model ProgramStaff {
  id             String   @id @default(cuid())
  programId      String
  staffProfileId String
  role           ProgramStaffRole @default(ASSISTANT_COACH)
  isPrimary      Boolean  @default(false)
  notes          String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  program        Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@unique([programId, staffProfileId])
  @@index([programId])
  @@index([staffProfileId])
}

enum ProgramStaffRole {
  LEAD_COACH
  ASSISTANT_COACH
  SUBSTITUTE
  VOLUNTEER
}

// Work Shifts - one-time scheduling assignments
model Shift {
  id             String      @id @default(cuid())
  organizationId String
  staffProfileId String
  facilityId     String?
  
  // Time
  date           DateTime
  startTime      String      // "09:00"
  endTime        String      // "17:00"
  
  // Role/Type
  shiftType      String      // e.g., "Opening Manager", "Coach", "Front Desk"
  notes          String?
  
  // Status
  status         ShiftStatus @default(SCHEDULED)
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  facility       Facility?    @relation(fields: [facilityId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([staffProfileId])
  @@index([date])
}

enum ShiftStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// Recurring Schedule Templates - weekly patterns
model ScheduleTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String   // e.g., "Standard Week", "Summer Schedule"
  isActive       Boolean  @default(true)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries        ScheduleTemplateEntry[]

  @@index([organizationId])
}

model ScheduleTemplateEntry {
  id                 String   @id @default(cuid())
  templateId         String
  
  dayOfWeek          Int      // 0=Sunday, 1=Monday, ... 6=Saturday
  startTime          String   // "09:00"
  endTime            String   // "17:00"
  shiftType          String   // Role/position type
  staffProfileId     String?  // Optional - can be unassigned
  facilityId         String?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  template           ScheduleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

// Staff Availability - personal weekly availability
model StaffAvailability {
  id             String   @id @default(cuid())
  staffProfileId String
  
  dayOfWeek      Int      // 0=Sunday, 1=Monday, ... 6=Saturday
  startTime      String   // "09:00"
  endTime        String   // "17:00"
  isAvailable    Boolean  @default(true)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@unique([staffProfileId, dayOfWeek]) // One entry per day per staff
  @@index([staffProfileId])
}

// ============================================
// PHASE 10: Registration Queue System
// ============================================

// Queue configuration per organization or program
model RegistrationQueueConfig {
  id                 String   @id @default(cuid())
  organizationId     String
  programId          String?  // null = org-wide default
  
  // Queue settings
  isEnabled          Boolean  @default(false)
  reservationMinutes Int      @default(10)  // How long a spot is reserved
  maxConcurrent      Int      @default(50)  // Max users in registration at once
  
  // Activation rules
  activationType       QueueActivationType @default(ALWAYS)
  activationThreshold  Int?     // For THRESHOLD type: activate when X users waiting
  scheduledStart       DateTime? // For SCHEDULED type
  scheduledEnd         DateTime?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program            Program?     @relation(fields: [programId], references: [id], onDelete: Cascade)
  entries            QueueEntry[]

  @@unique([organizationId, programId])
  @@index([organizationId])
  @@index([programId])
}

enum QueueActivationType {
  ALWAYS        // Queue always active when enabled
  THRESHOLD     // Activate when concurrent users exceed threshold
  SCHEDULED     // Active during scheduled time windows
}

// Track users waiting in queue
model QueueEntry {
  id             String   @id @default(cuid())
  queueConfigId  String
  sessionToken   String   @unique  // Browser session identifier
  
  // User info (may be anonymous until they identify)
  email          String?
  familyId       String?
  
  // Queue status
  position       Int      // Current position in queue
  status         QueueEntryStatus @default(WAITING)
  
  // Timing
  enteredAt      DateTime @default(now())
  admittedAt     DateTime?
  exitedAt       DateTime?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  queueConfig    RegistrationQueueConfig @relation(fields: [queueConfigId], references: [id], onDelete: Cascade)
  reservation    QueueReservation?

  @@index([queueConfigId, status])
  @@index([sessionToken])
  @@index([status])
}

enum QueueEntryStatus {
  WAITING       // In queue
  ADMITTED      // Let through, has active reservation
  COMPLETED     // Successfully registered
  EXPIRED       // Reservation timed out
  ABANDONED     // Left the queue
}

// Active reservations for users in registration
model QueueReservation {
  id            String   @id @default(cuid())
  queueEntryId  String   @unique
  programId     String
  
  // Timing
  startedAt     DateTime @default(now())
  expiresAt     DateTime
  completedAt   DateTime?
  
  // Status
  status        ReservationStatus @default(ACTIVE)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  queueEntry    QueueEntry @relation(fields: [queueEntryId], references: [id], onDelete: Cascade)
  program       Program    @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId, status])
  @@index([expiresAt])
  @@index([status])
}

enum ReservationStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// PHASE 1: Foundation - Organization & Users
// ============================================

model Organization {
  id   String  @id @default(cuid())
  name String
  slug String  @unique
  logo String?

  // Contact
  email String?
  phone String?

  // Address (structured)
  street        String?
  city          String?
  stateProvince String?
  postalCode    String?
  country       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  membershipGroups    MembershipGroup[]
  members             OrganizationMember[]
  users               User[] // Legacy relation, keep for now but rely on members
  families            Family[]
  programs            Program[]
  events              Event[]
  invoices            Invoice[]
  skills              Skill[]
  lessonPlans         LessonPlan[]
  announcements       Announcement[]
  websiteConfig       WebsiteConfig?
  evaluationTemplates EvaluationTemplate[]
  achievements        Achievement[]

  // Financials
  discounts        Discount[]
  glCodes          GLCode[]
  ledgerEntries    LedgerEntry[]
  transactions     Transaction[]
  payouts          Payout[]
  recurringCharges RecurringCharge[]

  // Athletes (Direct relation for easier querying)
  athletes Athlete[]

  // Platform Subscription
  subscription OrganizationSubscription?

  // POS Products
  products Product[]

  // Media
  media Media[]

  // Facilities
  facilities Facility[]
  equipment  Equipment[]

  // Staff & Scheduling
  staffProfiles     StaffProfile[]
  shifts            Shift[]
  scheduleTemplates ScheduleTemplate[]

  // SMS
  smsMessages  SmsMessage[]
  smsCampaigns SmsCampaign[]
  smsUsage     SmsUsage[]

  // Email
  emailMessages  EmailMessage[]
  emailCampaigns EmailCampaign[]
  emailUsage     EmailUsage[]

  // Medical
  medicalFormConfig      MedicalFormConfig?
  customMedicalQuestions CustomMedicalQuestion[]

  // Registration Queues
  queueConfigs RegistrationQueueConfig[]

  // Invitations
  invitations OrganizationInvitation[]

  // Notification Rules
  notificationRules NotificationRule[]
  notificationLogs  NotificationLog[]

  // Levels
  levels Level[]

  // Waivers
  waivers Waiver[]

  // Organization Payment Methods (for SaaS subscription billing)
  organizationPaymentMethods OrganizationPaymentMethod[]

  // Program Instances
  programInstances ProgramInstance[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           Role         @default(COACH)
  status         MemberStatus @default(ACTIVE)
  joinedAt       DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

enum MemberStatus {
  ACTIVE
  INVITED
  INACTIVE
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  name           String
  passwordHash   String?
  avatar         String?
  role           Role       @default(COACH) // Platform role or fallback
  status         UserStatus @default(ACTIVE)
  organizationId String? // Made optional - Last active organization
  isSuperAdmin   Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  lastActiveAt   DateTime?

  // Relations
  organization        Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships         OrganizationMember[]
  permissions         UserPermission[]
  lessonPlans         LessonPlan[]
  evaluations         Evaluation[]
  events              Event[]              @relation("EventCoach")
  sessions            Session[]
  accounts            Account[]
  media               Media[]
  facilityAssignments FacilityAssignment[]
  staffProfile        StaffProfile?

  // Announcement relations
  announcementReads          AnnouncementRead[]       @relation("AnnouncementReads")
  systemAnnouncementReads    SystemAnnouncementRead[] @relation("SystemAnnouncementReads")
  systemAnnouncementsCreated SystemAnnouncement[]     @relation("SystemAnnouncementCreator")

  // Feature request relations
  featureRequests FeatureRequest[] @relation("FeatureRequestAuthor")
  featureVotes    FeatureVote[]    @relation("FeatureVotes")
  featureComments FeatureComment[] @relation("FeatureComments")

  // Invitations sent by this user
  invitationsSent OrganizationInvitation[] @relation("InvitationsSent")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Password Reset Tokens - for forgot password functionality
model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([token])
}

model UserPermission {
  id         String @id @default(cuid())
  userId     String
  permission String // e.g., "athletes.read", "financials.write"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
}

// Organization Invitations - tracks pending and accepted invitations
model OrganizationInvitation {
  id             String                       @id @default(cuid())
  email          String
  token          String                       @unique
  organizationId String
  role           Role                         @default(COACH)
  status         OrganizationInvitationStatus @default(PENDING)
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitationsSent", fields: [invitedById], references: [id])

  @@index([email])
  @@index([organizationId])
  @@index([token])
}

enum OrganizationInvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum Role {
  ADMIN
  COACH
  VOLUNTEER
  ACCOUNTANT
  CUSTOM
  PARENT
  STAFF
}

enum UserStatus {
  ACTIVE
  INVITED
  INACTIVE
}

// ============================================
// PHASE 2: Core Entities - Athletes & Families
// ============================================

model Family {
  id             String   @id @default(cuid())
  name           String
  primaryContact String
  email          String
  phone          String
  address        String?
  balance        Decimal  @default(0) @db.Decimal(10, 2)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // SMS Preferences
  smsOptOut   Boolean   @default(false) // True if family has opted out of SMS
  smsOptOutAt DateTime? // When they opted out

  // Email Preferences
  emailOptOut   Boolean   @default(false) // True if family has opted out of marketing emails
  emailOptOutAt DateTime? // When they opted out

  // Relations
  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // athletes       Athlete[] // Deprecated, use guardians
  guardians             AthleteGuardian[]
  paymentMethods        PaymentMethod[]
  invoices              Invoice[]
  payments              Payment[]
  enrollments           Enrollment[] // Enrollments paid/managed by this family
  recurringCharges      RecurringCharge[]
  smsMessages           SmsMessage[]
  emailMessages         EmailMessage[]
  instanceRegistrations InstanceRegistration[] // Per-instance program registrations
  waiverSignatures      WaiverSignature[]
  waiverAcceptances     WaiverAcceptance[]

  // Contacts & Billing
  contacts         FamilyContact[]
  billingAddresses FamilyBillingAddress[]

  // Auth Link
  userId String? @unique
}

model FamilyContact {
  id           String   @id @default(cuid())
  familyId     String
  firstName    String
  lastName     String
  email        String
  phone        String
  relationship String? // e.g. "Parent", "Guardian", "Sibling"
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model FamilyBillingAddress {
  id            String   @id @default(cuid())
  familyId      String
  label         String? // e.g. "Home", "Work"
  street        String
  city          String
  stateProvince String?
  postalCode    String
  country       String   @default("US")
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model Athlete {
  id        String        @id @default(cuid())
  name      String // Deprecated: use firstName + lastName
  firstName String        @default("")
  lastName  String        @default("")
  email     String?
  level     String
  group     String
  status    AthleteStatus @default(ACTIVE)
  avatar    String?
  birthDate DateTime?
  gender    GenderDeclaration?
  familyId  String? // Deprecated: Use guardians relation

  // New fields for refactor
  customId       String? // Club-specific ID (e.g. Member ID)
  organizationId String? // Direct organization link
  medicalDetails Json? // { allergies: [], conditions: [], emergencyContact: {} }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization     Organization?          @relation(fields: [organizationId], references: [id])
  enrollments      Enrollment[]
  attendances      Attendance[]
  evaluations      Evaluation[]
  lineItems        LineItem[]
  memberships      AthleteMembership[]
  media            Media[]
  recurringCharges RecurringCharge[]
  skillProgress    AthleteSkillProgress[]
  achievements     AthleteAchievement[]

  // Multi-family support
  guardians AthleteGuardian[]

  // Medical information
  medicalInfo AthleteMedicalInfo?

  // Program instance registrations & attendance
  instanceRegistrations InstanceRegistration[]
  instanceAttendances   InstanceAttendance[]

  // Waiver signatures & acceptances per athlete
  waiverSignatures  WaiverSignature[]
  waiverAcceptances WaiverAcceptance[]
}

model AthleteGuardian {
  id           String   @id @default(cuid())
  athleteId    String
  familyId     String
  relationship String? // e.g. "Parent", "Guardian", "Grandparent"
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  family  Family  @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([athleteId, familyId])
}

enum AthleteStatus {
  ACTIVE
  INACTIVE
  TRIAL
  GRADUATED
}

enum GenderDeclaration {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// ============================================
// Medical Information System
// ============================================

// Question types for custom medical questions
enum MedicalQuestionType {
  TEXT
  YES_NO
  MULTIPLE_CHOICE
  CHECKBOX
}

// Organization-level medical form configuration
model MedicalFormConfig {
  id             String @id @default(cuid())
  organizationId String @unique

  // Standard questions toggles
  collectAllergies           Boolean @default(true)
  collectMedications         Boolean @default(true)
  collectConditions          Boolean @default(true)
  collectEmergencyContact    Boolean @default(true)
  collectDietaryRestrictions Boolean @default(false)
  collectInsuranceInfo       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Custom medical questions defined by organization
model CustomMedicalQuestion {
  id             String @id @default(cuid())
  organizationId String

  questionText String
  questionType MedicalQuestionType @default(TEXT)
  options      Json? // For MULTIPLE_CHOICE/CHECKBOX types: string[]
  required     Boolean             @default(false)
  displayOrder Int                 @default(0)
  isActive     Boolean             @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  responses    CustomMedicalResponse[]

  @@index([organizationId])
}

// Structured medical data per athlete
model AthleteMedicalInfo {
  id        String @id @default(cuid())
  athleteId String @unique

  // Standard fields (arrays for multiple entries)
  allergies           String[] // Food, environmental, medication allergies
  medications         String[] // Current medications
  conditions          String[] // Medical conditions (asthma, diabetes, etc.)
  dietaryRestrictions String[] // Dietary restrictions

  // Insurance info
  insuranceProvider     String?
  insurancePolicyNumber String?

  // Emergency contact (structured from JSON)
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // Additional notes
  additionalNotes String? @db.Text

  // Metadata
  lastUpdatedBy String? // User ID who last updated

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  athlete         Athlete                 @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  customResponses CustomMedicalResponse[]

  @@index([athleteId])
}

// Answers to custom medical questions
model CustomMedicalResponse {
  id            String @id @default(cuid())
  medicalInfoId String
  questionId    String

  response String // Stored as string, parsed based on question type

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  medicalInfo AthleteMedicalInfo    @relation(fields: [medicalInfoId], references: [id], onDelete: Cascade)
  question    CustomMedicalQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([medicalInfoId, questionId])
  @@index([medicalInfoId])
  @@index([questionId])
}

model PaymentMethod {
  id        String            @id @default(cuid())
  familyId  String
  type      PaymentMethodType
  last4     String
  expiry    String?
  brand     String?
  isDefault Boolean           @default(false)
  createdAt DateTime          @default(now())

  // Relations
  family           Family            @relation(fields: [familyId], references: [id], onDelete: Cascade)
  recurringCharges RecurringCharge[]
}

enum PaymentMethodType {
  CARD
  BANK
}

// ============================================
// PHASE 2: Programs & Memberships
// ============================================

// Organization-defined levels for programs and skills
model Level {
  id             String   @id @default(cuid())
  organizationId String
  name           String // e.g., "Bronze", "Level 1", "Beginner"
  description    String?
  order          Int      @default(0) // Display order
  color          String? // Optional hex color for UI
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization        Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  skills              Skill[]                   @relation("SkillLevel")
  programRequirements ProgramLevelRequirement[]
  evaluations         Evaluation[]
  evaluationTemplates EvaluationTemplate[]

  @@index([organizationId])
  @@index([order])
}

model Program {
  id             String        @id @default(cuid())
  name           String
  description    String?
  status         ProgramStatus @default(ACTIVE)
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Calendar-based scheduling
  recurrenceType   RecurrenceType    @default(RECURRING)
  registrationType RegistrationType? // Only for recurring: all-at-once or per-instance

  // Pricing Configuration
  pricingModel    PricingModel @default(FLAT_RATE)
  basePrice       Decimal?     @db.Decimal(10, 2) // For flat-rate pricing
  perSessionPrice Decimal?     @db.Decimal(10, 2) // For per-session pricing

  // Schedule Configuration
  startDate DateTime?
  endDate   DateTime?
  rrule     String? // RFC 5545 RRULE string (e.g., "FREQ=WEEKLY;BYDAY=MO,WE,FR")
  startTime String? // Default start time (e.g., "09:00")
  duration  Int? // Duration in minutes

  // Default Facility
  facilityId String? // Default facility for this program

  // Capacity (for classes)
  capacity Int?

  // Display
  showCoachOnSite Boolean @default(true)

  // Age Restrictions
  minAge Int? // Minimum age (0-100)
  maxAge Int? // Maximum age (0-100)

  // Restriction Flags (for UI toggle state)
  hasLevelRestriction      Boolean @default(false)
  hasCapacityRestriction   Boolean @default(false)
  hasAgeRestriction        Boolean @default(false)
  hasMembershipRestriction Boolean @default(false)
  hasWaiverRestriction     Boolean @default(false)
  hasMedicalRequirement    Boolean @default(false)

  // Relations
  organization        Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facility            Facility?                   @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  events              Event[]
  lessonPlans         LessonPlan[]
  enrollments         Enrollment[]
  lineItems           LineItem[]
  staffAssignments    ProgramStaff[]
  requiredMemberships MembershipInstance[]
  evaluations         Evaluation[]
  evaluationTemplates ProgramEvaluationTemplate[]
  bulkDiscounts       ProgramBulkDiscount[]
  levelRequirements   ProgramLevelRequirement[]
  waiverRequirements  ProgramWaiverRequirement[]
  instances           ProgramInstance[]

  // Registration Queue
  queueConfigs      RegistrationQueueConfig[]
  queueReservations QueueReservation[]

  @@index([facilityId])
}

enum ProgramStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

// Legacy - kept for backwards compatibility during migration
enum RecurrenceType {
  NON_RECURRING // Single date/time event
  RECURRING // Repeats on a schedule
}

enum RegistrationType {
  ALL_INSTANCES // User registers for entire series
  PER_INSTANCE // User registers for individual sessions
}

enum PricingModel {
  FLAT_RATE // Fixed price for entire program
  PER_SESSION // Price calculated per session
}

// Program Bulk Discounts - for family and multi-session discounts
model ProgramBulkDiscount {
  id            String           @id @default(cuid())
  programId     String
  type          BulkDiscountType
  minQuantity   Int // e.g., 2 for 2nd child, 10 for 10-pack
  discountType  DiscountType // PERCENTAGE, FIXED_AMOUNT
  discountValue Decimal          @db.Decimal(10, 2)
  description   String? // Display text for marketing site
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
}

enum BulkDiscountType {
  FAMILY_SIBLING // Nth child discount
  MULTI_SESSION // Buy X, save Y
}

// Program Level Requirements - many-to-many for level restrictions
model ProgramLevelRequirement {
  id        String   @id @default(cuid())
  programId String
  levelId   String
  createdAt DateTime @default(now())

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  level   Level   @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([programId, levelId])
  @@index([programId])
  @@index([levelId])
}

// Legacy - to be deprecated
// Membership Structure
model MembershipGroup {
  id             String   @id @default(cuid())
  organizationId String
  name           String // e.g., "Annual Membership"
  description    String?
  programTypes   String[] // Relevant program types

  // Logic & Defaults
  allowAutoRenew Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  instances    MembershipInstance[]
}

model MembershipInstance {
  id                String @id @default(cuid())
  membershipGroupId String
  name              String // e.g., "FY25"

  // Billing
  price           Decimal         @db.Decimal(10, 2)
  billingInterval BillingInterval

  // Validity
  startDate DateTime
  endDate   DateTime

  // Renewal Logic
  autoRenewDate DateTime? // When to trigger creation of next instance (if handled by system)

  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  group               MembershipGroup     @relation(fields: [membershipGroupId], references: [id], onDelete: Cascade)
  athleteMemberships  AthleteMembership[]
  requiredForEvents   Event[]
  requiredForPrograms Program[]
}

model AthleteMembership {
  id                   String @id @default(cuid())
  athleteId            String
  membershipInstanceId String

  startDate DateTime
  endDate   DateTime?
  status    MembershipStatus @default(ACTIVE)

  // Auto-renewal for the athlete
  autoRenew Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  athlete  Athlete            @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  instance MembershipInstance @relation(fields: [membershipInstanceId], references: [id], onDelete: Cascade)
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  ARCHIVED
}

enum BillingInterval {
  MONTHLY
  YEARLY
  SESSION
}

model Enrollment {
  id               String           @id @default(cuid())
  athleteId String
  programId String
  familyId  String? // The family responsible for this enrollment
  startDate DateTime
  endDate   DateTime?
  status    EnrollmentStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  family  Family? @relation(fields: [familyId], references: [id])
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}

// ============================================
// Program Instances (Individual Sessions)
// ============================================

model ProgramInstance {
  id             String         @id @default(cuid())
  programId      String
  date           DateTime
  startTime      String // e.g., "09:00"
  endTime        String // e.g., "10:30"
  facilityId     String? // Can override program's default facility
  capacity       Int? // Can override program capacity
  status         InstanceStatus @default(SCHEDULED)
  notes          String?
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  program       Program                @relation(fields: [programId], references: [id], onDelete: Cascade)
  facility      Facility?              @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  organization  Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  registrations InstanceRegistration[]
  attendances   InstanceAttendance[]

  @@index([programId])
  @@index([facilityId])
  @@index([organizationId])
  @@index([date])
  @@index([status])
}

enum InstanceStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

// Instance Registration - for per-instance program registrations
model InstanceRegistration {
  id                String             @id @default(cuid())
  programInstanceId String
  athleteId         String
  familyId          String?
  status            RegistrationStatus @default(REGISTERED)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  programInstance ProgramInstance @relation(fields: [programInstanceId], references: [id], onDelete: Cascade)
  athlete         Athlete         @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  family          Family?         @relation(fields: [familyId], references: [id], onDelete: SetNull)

  @@unique([programInstanceId, athleteId])
  @@index([programInstanceId])
  @@index([athleteId])
  @@index([familyId])
  @@index([status])
}

enum RegistrationStatus {
  REGISTERED
  WAITLISTED
  CANCELLED
  ATTENDED
  NO_SHOW
}

// Instance Attendance - tracks attendance for specific program instances
model InstanceAttendance {
  id                String           @id @default(cuid())
  programInstanceId String
  athleteId         String
  status            AttendanceStatus @default(REGISTERED)
  checkedIn         DateTime?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  programInstance ProgramInstance @relation(fields: [programInstanceId], references: [id], onDelete: Cascade)
  athlete         Athlete         @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([programInstanceId, athleteId])
  @@index([programInstanceId])
  @@index([athleteId])
}

// ============================================
// PHASE 3: Events & Attendance
// ============================================

model Event {
  id                  String               @id @default(cuid())
  title               String
  date                DateTime
  startTime           String
  endTime             String
  type                EventType            @default(CLASS)
  description         String?
  meetingLink         String?
  timezone            String?
  capacity            Int?
  location            Json? // { lat, lng, address, name } - for external/custom locations
  details             Json? // { whatToBring, whatToExpect, requirements }
  programId           String?
  coachId             String?
  facilityId          String? // Optional - links to a Facility for scheduling
  requiredMemberships MembershipInstance[]
  organizationId      String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  // Relations
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program          Program?     @relation(fields: [programId], references: [id])
  coach            User?        @relation("EventCoach", fields: [coachId], references: [id])
  facility         Facility?    @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  attendances      Attendance[]
  lineItems        LineItem[]
  media            Media[]
  staffAssignments EventStaff[]
}

enum EventType {
  CLASS
  CAMP
  PARTY
  COMPETITION
  MEETING
  OTHER
}

model Attendance {
  id        String           @id @default(cuid())
  athleteId String
  eventId   String
  status    AttendanceStatus @default(PRESENT)
  checkedIn DateTime?
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([athleteId, eventId])
}

enum AttendanceStatus {
  REGISTERED
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// ============================================
// PHASE 4: Financial System
// ============================================

model Invoice {
  id             String        @id @default(cuid())
  reference      String        @unique
  familyId       String
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime
  subtotal       Decimal       @db.Decimal(10, 2)
  tax            Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  notes          String?
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  family       Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  lineItems    LineItem[]
  payments     Payment[]
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  PARTIAL
}

model LineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  programId   String? // What program is this for?
  eventId     String? // What specific event?
  athleteId   String? // Which athlete?
  discountId  String? // Applied discount
  createdAt   DateTime @default(now())

  // Relations
  invoice  Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  program  Program?  @relation(fields: [programId], references: [id])
  event    Event?    @relation(fields: [eventId], references: [id])
  athlete  Athlete?  @relation(fields: [athleteId], references: [id])
  discount Discount? @relation(fields: [discountId], references: [id])
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String?
  familyId      String
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentType
  status        PaymentStatus @default(PENDING)
  transactionId String? // Legacy field, keeping for backwards compatibility
  processedAt   DateTime?
  createdAt     DateTime      @default(now())

  // Relations
  invoice     Invoice?     @relation(fields: [invoiceId], references: [id])
  family      Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  transaction Transaction? // Linked Adyen transaction
}

enum PaymentType {
  CARD
  BANK
  CASH
  CHECK
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Discount {
  id             String         @id @default(cuid())
  name           String
  code           String         @unique
  type           DiscountType
  amount         Decimal        @db.Decimal(10, 2)
  validFrom      DateTime
  validTo        DateTime?
  userScope      UserScope      @default(ALL)
  productScope   ProductScope   @default(ALL)
  usageLimit     Int?
  usageCount     Int            @default(0)
  status         DiscountStatus @default(ACTIVE)
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lineItems    LineItem[]
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum UserScope {
  ALL
  NEW_USERS
  MEMBERS
  VIP
}

enum ProductScope {
  ALL
  MERCHANDISE
  EVENTS
  MEMBERSHIP
}

enum DiscountStatus {
  ACTIVE
  EXPIRED
  SCHEDULED
  DRAFT
}

model GLCode {
  id             String       @id @default(cuid())
  code           String       @unique
  description    String
  type           GLCodeType
  status         GLCodeStatus @default(ACTIVE)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ledgerEntries LedgerEntry[]
}

enum GLCodeType {
  REVENUE
  EXPENSE
  LIABILITY
  ASSET
  EQUITY
}

enum GLCodeStatus {
  ACTIVE
  INACTIVE
}

model LedgerEntry {
  id             String            @id @default(cuid())
  date           DateTime
  description    String
  glCodeId       String
  reference      String?
  debit          Decimal?          @db.Decimal(10, 2)
  credit         Decimal?          @db.Decimal(10, 2)
  status         LedgerEntryStatus @default(PENDING)
  organizationId String
  createdAt      DateTime          @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  glCode       GLCode       @relation(fields: [glCodeId], references: [id])
}

enum LedgerEntryStatus {
  POSTED
  PENDING
}

// ============================================
// Adyen Transaction Tracking
// ============================================

model Transaction {
  id             String            @id @default(cuid())
  organizationId String
  paymentId      String?           @unique
  pspReference   String            @unique // Adyen PSP reference
  merchantRef    String? // Our internal reference
  type           TransactionType
  amount         Decimal           @db.Decimal(10, 2)
  currency       String            @default("USD")
  status         TransactionStatus
  method         String? // visa, mastercard, applepay, etc.
  description    String?
  metadata       Json?
  settledAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payment      Payment?     @relation(fields: [paymentId], references: [id])

  @@index([organizationId])
  @@index([pspReference])
}

enum TransactionType {
  PAYMENT
  REFUND
  CHARGEBACK
  CAPTURE
  CANCEL
}

enum TransactionStatus {
  AUTHORISED
  CAPTURED
  SETTLED
  REFUSED
  CANCELLED
  ERROR
  PENDING
}

// ============================================
// Payouts (Settlement from Adyen)
// ============================================

model Payout {
  id             String       @id @default(cuid())
  organizationId String
  reference      String       @unique // Adyen payout reference
  amount         Decimal      @db.Decimal(10, 2)
  fees           Decimal      @default(0) @db.Decimal(10, 2)
  net            Decimal      @db.Decimal(10, 2)
  currency       String       @default("USD")
  status         PayoutStatus
  bankAccount    String? // Last 4 digits
  scheduledAt    DateTime?
  paidAt         DateTime?
  createdAt      DateTime     @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

enum PayoutStatus {
  PENDING
  SCHEDULED
  PAID
  FAILED
}

// ============================================
// Recurring Billing
// ============================================

model RecurringCharge {
  id              String          @id @default(cuid())
  organizationId  String
  familyId        String
  athleteId       String?
  description     String
  amount          Decimal         @db.Decimal(10, 2)
  frequency       BillingInterval // MONTHLY, YEARLY, SESSION
  nextChargeDate  DateTime
  lastChargedAt   DateTime?
  status          RecurringStatus
  paymentMethodId String?
  failureCount    Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  family        Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  athlete       Athlete?       @relation(fields: [athleteId], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@index([organizationId])
  @@index([familyId])
  @@index([nextChargeDate])
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  CANCELLED
  FAILED
}

// ============================================
// PHASE 5: Training & Evaluations
// ============================================

model Skill {
  id             String   @id @default(cuid())
  name           String
  category       String // e.g., "Vault", "Bars", "Beam", "Floor"
  level          String? // Legacy field - kept for backwards compatibility
  description    String?  @db.Text
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Age targeting
  minAge          Int? // Suggested minimum age
  maxAge          Int? // Suggested maximum age
  videoUrl        String? // Demo video URL
  imageUrl        String? // Demo image URL

  // Level reference (new system)
  levelId String? // FK to Level model

  // Relations
  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  skillLevel       Level?                    @relation("SkillLevel", fields: [levelId], references: [id], onDelete: SetNull)
  evaluationSkills EvaluationSkill[]
  rotationSkills   RotationSkill[]
  templateSkills   EvaluationTemplateSkill[]
  athleteProgress  AthleteSkillProgress[]

  @@index([levelId])
}

// Evaluation Templates - reusable groupings of skills for assessments
model EvaluationTemplate {
  id             String   @id @default(cuid())
  name           String
  description    String?  @db.Text
  levelId        String? // FK to Level model
  minAge         Int?
  maxAge         Int?
  isActive       Boolean  @default(true)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Auto-sync configuration
  autoSyncEnabled    Boolean  @default(false)
  autoSyncLevels     String[] @default([]) // Level IDs for auto-sync filtering
  autoSyncCategories String[] @default([]) // e.g., ["Vault", "Bars"]

  // Scoring configuration
  scoringType             ScoringType @default(PASS_FAIL)
  pointScaleMin           Int         @default(1)
  pointScaleMax           Int         @default(10)
  pointScalePassThreshold Int         @default(7)

  // Completion requirements for achievements
  completionType      CompletionType @default(PERCENTAGE)
  completionThreshold Decimal        @default(80) @db.Decimal(5, 2)

  // Relations
  organization     Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  level            Level?                      @relation(fields: [levelId], references: [id], onDelete: SetNull)
  skills           EvaluationTemplateSkill[]
  evaluations      Evaluation[]
  programTemplates ProgramEvaluationTemplate[]
  achievements     Achievement[]

  @@index([organizationId])
  @@index([levelId])
}

// Junction table for skills in evaluation templates
model EvaluationTemplateSkill {
  id         String  @id @default(cuid())
  templateId String
  skillId    String
  order      Int     @default(0) // Display order
  isRequired Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  template EvaluationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  skill    Skill              @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([templateId, skillId])
  @@index([templateId])
  @@index([skillId])
}

// Junction table for linking evaluation templates to programs
model ProgramEvaluationTemplate {
  id         String    @id @default(cuid())
  programId  String
  templateId String
  isRequired Boolean   @default(false)
  dueDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  program  Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  template EvaluationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([programId, templateId])
  @@index([programId])
  @@index([templateId])
}

model LessonPlan {
  id             String           @id @default(cuid())
  name           String
  programId      String
  date           DateTime?
  authorId       String
  status         LessonPlanStatus @default(DRAFT)
  theme          String?
  notes          String?
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program      @relation(fields: [programId], references: [id])
  author       User         @relation(fields: [authorId], references: [id])
  rotations    Rotation[]
}

enum LessonPlanStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

model Rotation {
  id           String   @id @default(cuid())
  lessonPlanId String
  name         String
  description  String?
  order        Int      @default(0)
  media        String[] // Array of media URLs
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  lessonPlan LessonPlan      @relation(fields: [lessonPlanId], references: [id], onDelete: Cascade)
  skills     RotationSkill[]
}

model RotationSkill {
  id         String @id @default(cuid())
  rotationId String
  skillId    String

  // Relations
  rotation Rotation @relation(fields: [rotationId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([rotationId, skillId])
}

model Evaluation {
  id           String           @id @default(cuid())
  athleteId    String
  coachId      String
  templateId   String? // Optional link to evaluation template
  programId    String? // Optional link to program
  levelId      String? // FK to Level model
  date         DateTime
  overallScore Decimal          @db.Decimal(3, 1)
  status       EvaluationStatus
  notes        String?          @db.Text
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Relations
  athlete             Athlete              @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  coach               User                 @relation(fields: [coachId], references: [id])
  template            EvaluationTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  program             Program?             @relation(fields: [programId], references: [id], onDelete: SetNull)
  level               Level?               @relation(fields: [levelId], references: [id], onDelete: SetNull)
  skillRatings        EvaluationSkill[]
  athleteAchievements AthleteAchievement[]

  @@index([athleteId])
  @@index([coachId])
  @@index([templateId])
  @@index([programId])
  @@index([levelId])
}

enum EvaluationStatus {
  PENDING // Evaluation assigned but not completed
  IN_PROGRESS // Evaluation started
  PASS
  RETRY
  EXCELLENT
  SATISFACTORY
}

model EvaluationSkill {
  id            String             @id @default(cuid())
  evaluationId  String
  skillId       String
  rating        Int? // Legacy: 1-5, optional (can use attemptStatus instead)
  pointScore    Int? // For POINT_SCALE scoring type
  attemptStatus SkillAttemptStatus @default(NOT_ATTEMPTED)
  passed        Boolean            @default(false) // Computed based on scoring type
  comment       String?

  // Relations
  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id])

  @@unique([evaluationId, skillId])
  @@index([evaluationId])
  @@index([skillId])
}

enum SkillAttemptStatus {
  NOT_ATTEMPTED
  ATTEMPTED
  SUCCEEDED
}

// Scoring types for evaluations
enum ScoringType {
  PASS_FAIL // 3 states: NOT_ATTEMPTED, ATTEMPTED, PASSED
  POINT_SCALE // Configurable range with pass threshold
}

// Completion requirement types for achievements
enum CompletionType {
  PERCENTAGE // e.g., 80% of skills passed
  COUNT // e.g., 15 skills passed
  ALL // All required skills passed
}

// Track athlete progress on individual skills across all evaluations
model AthleteSkillProgress {
  id               String             @id @default(cuid())
  athleteId        String
  skillId          String
  bestStatus       SkillAttemptStatus @default(NOT_ATTEMPTED)
  firstAttemptedAt DateTime?
  firstSucceededAt DateTime?
  attemptCount     Int                @default(0)
  successCount     Int                @default(0)
  lastEvaluatedAt  DateTime
  lastEvaluationId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Relations
  athlete Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([athleteId, skillId])
  @@index([athleteId])
  @@index([skillId])
}

// Achievement definitions linked to evaluation templates
model Achievement {
  id             String   @id @default(cuid())
  templateId     String
  name           String
  description    String?  @db.Text
  badgeImageUrl  String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  template            EvaluationTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  athleteAchievements AthleteAchievement[]

  @@index([templateId])
  @@index([organizationId])
}

// Track athlete achievements earned
model AthleteAchievement {
  id            String   @id @default(cuid())
  athleteId     String
  achievementId String
  evaluationId  String? // The evaluation that earned this achievement
  earnedAt      DateTime @default(now())

  // Best results by category at time of earning
  bestResultsByCategory Json? // { "Vault": 9.5, "Bars": 8.0, ... }
  overallScore          Decimal? @db.Decimal(5, 2)

  // Relations
  athlete     Athlete     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  evaluation  Evaluation? @relation(fields: [evaluationId], references: [id], onDelete: SetNull)

  @@unique([athleteId, achievementId])
  @@index([athleteId])
  @@index([achievementId])
  @@index([evaluationId])
}

// ============================================
// PHASE 6: Communication
// ============================================

model Announcement {
  id              String               @id @default(cuid())
  title           String
  content         String // HTML content from WYSIWYG
  targetScope     AnnouncementScope    @default(ALL)
  targetProgramId String?
  targetEventId   String?
  status          AnnouncementStatus   @default(DRAFT)
  priority        AnnouncementPriority @default(NORMAL)
  publishedAt     DateTime?
  expiresAt       DateTime?
  organizationId  String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Relations
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  readBy       AnnouncementRead[]
}

model AnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation("AnnouncementReads", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
  @@index([announcementId])
}

// System-wide announcements from superadmins (sent to all organizations)
model SystemAnnouncement {
  id          String               @id @default(cuid())
  title       String
  content     String               @db.Text // HTML content from WYSIWYG
  priority    AnnouncementPriority @default(NORMAL)
  status      AnnouncementStatus   @default(DRAFT)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  // Track who created it
  createdById String
  createdBy   User   @relation("SystemAnnouncementCreator", fields: [createdById], references: [id])

  // Read tracking
  readBy SystemAnnouncementRead[]
}

model SystemAnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement SystemAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User               @relation("SystemAnnouncementReads", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
  @@index([announcementId])
}

enum AnnouncementScope {
  ALL
  PROGRAM
  EVENT
  FAMILY
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================
// SMS Messaging
// ============================================

model SmsMessage {
  id             String  @id @default(cuid())
  organizationId String
  familyId       String? // Recipient family (if outbound)
  staffProfileId String? // Recipient staff (if outbound)
  campaignId     String? // Part of a campaign

  // Message details
  to       String // E.164 format phone number
  from     String // Twilio number used
  body     String @db.Text
  segments Int    @default(1) // SMS segment count

  // Twilio tracking
  twilioSid    String?   @unique // Twilio message SID
  twilioStatus SmsStatus @default(QUEUED)

  // Direction
  direction SmsDirection @default(OUTBOUND)

  // Classification
  classification SmsClassification @default(GENERAL)

  // Cost tracking (in cents)
  cost Decimal? @db.Decimal(10, 4)

  // Timestamps
  sentAt      DateTime?
  deliveredAt DateTime?
  failedAt    DateTime?

  // Error handling
  errorCode    String?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  family       Family?      @relation(fields: [familyId], references: [id], onDelete: SetNull)
  campaign     SmsCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([familyId])
  @@index([campaignId])
  @@index([twilioSid])
  @@index([twilioStatus])
  @@index([createdAt])
}

enum SmsStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  UNDELIVERED
  FAILED
}

enum SmsDirection {
  OUTBOUND
  INBOUND
}

enum SmsClassification {
  GENERAL
  REMINDER
  ALERT
  BILLING
  EVENT
  NEWS
}

model SmsCampaign {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  body           String            @db.Text
  classification SmsClassification @default(GENERAL)

  // Targeting
  targetScope     AnnouncementScope @default(ALL) // Reuse existing enum
  targetProgramId String?
  targetEventId   String?

  // Status
  status SmsCampaignStatus @default(DRAFT)

  // Statistics
  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  deliveredCount  Int @default(0)
  failedCount     Int @default(0)

  // Scheduling
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  // Author
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     SmsMessage[]

  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
}

enum SmsCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
  CANCELLED
}

model SmsUsage {
  id             String @id @default(cuid())
  organizationId String

  // Period tracking
  periodStart DateTime
  periodEnd   DateTime

  // Counts
  messagesSent      Int @default(0)
  messagesDelivered Int @default(0)
  messagesFailed    Int @default(0)
  totalSegments     Int @default(0)

  // Cost tracking (in dollars)
  totalCost Decimal @default(0) @db.Decimal(10, 2)

  // Plan-based tracking
  includedMessages Int     @default(0) // From plan
  overageMessages  Int     @default(0) // Beyond plan limit
  overageCost      Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, periodStart])
  @@index([organizationId])
  @@index([periodStart])
}

// ============================================
// Email Campaigns
// ============================================

model EmailMessage {
  id             String  @id @default(cuid())
  organizationId String
  familyId       String? // Recipient family
  campaignId     String? // Part of a campaign

  // Message details
  to       String // Recipient email address
  from     String // Sender email (org's from address)
  subject  String
  htmlBody String  @db.Text
  textBody String? @db.Text

  // SES tracking
  sesMessageId String?     @unique // SES message ID for tracking
  status       EmailStatus @default(QUEUED)

  // Classification
  classification EmailClassification @default(GENERAL)

  // Engagement tracking
  openedAt   DateTime?
  openCount  Int       @default(0)
  clickedAt  DateTime?
  clickCount Int       @default(0)

  // Timestamps
  sentAt       DateTime?
  deliveredAt  DateTime?
  bouncedAt    DateTime?
  complainedAt DateTime?
  failedAt     DateTime?

  // Error handling
  bounceType    String? // "Permanent" or "Transient"
  bounceSubType String? // e.g., "General", "NoEmail", "Suppressed"
  errorCode     String?
  errorMessage  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  family       Family?        @relation(fields: [familyId], references: [id], onDelete: SetNull)
  campaign     EmailCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([familyId])
  @@index([campaignId])
  @@index([sesMessageId])
  @@index([status])
  @@index([createdAt])
}

enum EmailStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
}

enum EmailClassification {
  GENERAL
  PROGRAM_UPDATE
  EVENT_UPDATE
  MEMBERSHIP
  BILLING
  NEWSLETTER
}

model EmailCampaign {
  id             String              @id @default(cuid())
  organizationId String
  name           String
  subject        String
  htmlBody       String              @db.Text
  textBody       String?             @db.Text
  classification EmailClassification @default(GENERAL)

  // Targeting - reuse AnnouncementScope enum
  targetScope     AnnouncementScope @default(ALL)
  targetProgramId String?
  targetEventId   String?

  // Additional targeting options
  targetMembershipStatus String? // "ACTIVE", "EXPIRED", or null for all

  // Status
  status EmailCampaignStatus @default(DRAFT)

  // Statistics
  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  deliveredCount  Int @default(0)
  openedCount     Int @default(0)
  clickedCount    Int @default(0)
  bouncedCount    Int @default(0)
  complainedCount Int @default(0)
  failedCount     Int @default(0)

  // Scheduling
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  // Author
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     EmailMessage[]

  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
  CANCELLED
}

model EmailUsage {
  id             String @id @default(cuid())
  organizationId String

  // Period tracking
  periodStart DateTime
  periodEnd   DateTime

  // Counts
  emailsSent       Int @default(0)
  emailsDelivered  Int @default(0)
  emailsOpened     Int @default(0)
  emailsClicked    Int @default(0)
  emailsBounced    Int @default(0)
  emailsComplained Int @default(0)
  emailsFailed     Int @default(0)

  // Plan-based tracking
  includedEmails Int     @default(0) // From plan
  overageEmails  Int     @default(0) // Beyond plan limit
  overageCost    Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, periodStart])
  @@index([organizationId])
  @@index([periodStart])
}

// ============================================
// PHASE 7: Website Builder
// ============================================

model WebsiteConfig {
  id             String @id @default(cuid())
  organizationId String @unique

  // Theming
  primaryColor   String? @default("#000000")
  secondaryColor String? @default("#ffffff")

  // Assets
  logo    String?
  favicon String?

  // Content
  heroImage          String?
  heroHeadline       String?
  heroSubheadline    String?
  heroText           String? @db.Text
  heroAgeRange       String? // e.g., "All Ages Welcome", "Ages 5-18"
  heroProgramPeriods String? // e.g., "Year-Round Programs", "Fall & Spring Sessions"
  heroLocation       String? // e.g., "Austin, TX"

  // Visibility
  showCalendar     Boolean @default(true)
  showRegistration Boolean @default(true)
  showContact      Boolean @default(true)

  // Domain
  domain            String? @unique
  subdomain         String? @unique // prefix to uplifterinc.com
  emailSenderDomain String?

  // Status
  isPublished Boolean @default(false)

  // SEO
  seoDescription     String? @db.Text // Custom meta description for search engines
  seoKeywords        String? // Comma-separated keywords
  googleVerification String? // Google Search Console verification code

  // Information Boxes (up to 3 configurable boxes on home page)
  infoBox1Title   String?
  infoBox1Content String? @db.Text
  infoBox2Title   String?
  infoBox2Content String? @db.Text
  infoBox3Title   String?
  infoBox3Content String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ============================================
// POS Products & Inventory
// ============================================

model Product {
  id               String   @id @default(cuid())
  organizationId   String
  name             String
  description      String?
  sku              String?
  category         String   @default("General")
  price            Decimal  @db.Decimal(10, 2)
  imageUrl         String?
  maxInventory     Int? // null = unlimited
  currentInventory Int? // null = unlimited
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@unique([organizationId, sku])
  @@index([organizationId])
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  type        StockMovementType
  quantity    Int // positive for additions, negative for sales
  previousQty Int
  newQty      Int
  referenceId String? // invoiceId, orderId, etc.
  notes       String?
  createdBy   String?
  createdAt   DateTime          @default(now())

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

enum StockMovementType {
  SALE
  RESTOCK
  ADJUSTMENT
  RETURN
}

// ============================================
// PHASE 8: Feedback & Feature Requests
// ============================================

enum FeatureStatus {
  SUBMITTED // New submission, pending review
  PLANNED // Accepted and on roadmap
  IN_PROGRESS // Currently being built
  DONE // Completed
  CLOSED // Rejected/won't do
}

model FeatureRequest {
  id              String        @id @default(cuid())
  title           String
  description     String
  status          FeatureStatus @default(SUBMITTED)
  isPublic        Boolean       @default(false) // Only show on public roadmap if true
  targetDate      DateTime? // Target delivery date
  statusChangedAt DateTime? // Last status change timestamp
  categories      String[] // Array of category strings
  mergedIntoId    String? // If merged into another feature
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userId          String? // Author (submitter)

  // Relations
  user       User?            @relation("FeatureRequestAuthor", fields: [userId], references: [id], onDelete: SetNull)
  mergedInto FeatureRequest?  @relation("FeatureMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom FeatureRequest[] @relation("FeatureMerge")
  comments   FeatureComment[]
  votes      FeatureVote[]

  @@index([status])
  @@index([isPublic])
  @@index([userId])
}

model FeatureVote {
  id               String   @id @default(cuid())
  featureRequestId String
  userId           String
  createdAt        DateTime @default(now())

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  user           User           @relation("FeatureVotes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([featureRequestId, userId]) // One vote per user per feature
  @@index([featureRequestId])
  @@index([userId])
}

model FeatureComment {
  id               String   @id @default(cuid())
  featureRequestId String
  content          String
  userId           String
  isStaffReply     Boolean  @default(false) // True if from superadmin/staff
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  user           User           @relation("FeatureComments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([featureRequestId])
  @@index([userId])
}

// ============================================
// Media
// ============================================

model Media {
  id             String    @id @default(cuid())
  url            String
  type           MediaType
  title          String?
  description    String?
  fileSize       Int       @default(0) // File size in bytes
  athleteId      String?
  eventId        String?
  uploadedById   String
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  athlete      Athlete?     @relation(fields: [athleteId], references: [id], onDelete: SetNull)
  event        Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([athleteId])
  @@index([eventId])
  @@index([uploadedById])
}

enum MediaType {
  IMAGE
  VIDEO
}

// ============================================
// Facilities & Equipment
// ============================================

model Facility {
  id             String @id @default(cuid())
  organizationId String
  name           String

  // Address
  street        String?
  city          String?
  stateProvince String?
  postalCode    String?
  country       String?

  // Contact
  phone String?
  email String?

  // Status & Metadata
  status        FacilityStatus @default(ACTIVE)
  isDefault     Boolean        @default(false)
  squareFootage Int?
  maxCapacity   Int?
  description   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trainingZones    TrainingZone[]
  equipment        Equipment[]
  assignments      FacilityAssignment[]
  events           Event[]
  shifts           Shift[]
  programs         Program[]
  programInstances ProgramInstance[]

  @@index([organizationId])
}

enum FacilityStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

model TrainingZone {
  id          String     @id @default(cuid())
  facilityId  String
  name        String
  type        String // e.g., "Floor", "Vault", "Bars", "Beam", "Trampoline"
  capacity    Int?
  status      ZoneStatus @default(OPEN)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  facility  Facility    @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  equipment Equipment[]

  @@index([facilityId])
}

enum ZoneStatus {
  OPEN
  CLOSED
  MAINTENANCE
}

model Equipment {
  id             String  @id @default(cuid())
  organizationId String
  facilityId     String? // Optional - null means org-level equipment
  trainingZoneId String? // Optional - for zone assignment within facility

  name         String
  type         String // e.g., "Apparatus", "Mat", "Training Aid"
  serialNumber String?
  condition    EquipmentCondition @default(GOOD)
  status       EquipmentStatus    @default(ACTIVE)

  // Tracking
  purchaseDate       DateTime?
  lastInspectionDate DateTime?
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facility     Facility?     @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  trainingZone TrainingZone? @relation(fields: [trainingZoneId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([facilityId])
  @@index([trainingZoneId])
}

enum EquipmentCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  UNSAFE
}

enum EquipmentStatus {
  ACTIVE
  RETIRED
  MAINTENANCE
}

model FacilityAssignment {
  id         String  @id @default(cuid())
  facilityId String
  userId     String
  isPrimary  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([facilityId, userId])
  @@index([facilityId])
  @@index([userId])
}

// ============================================
// Reserved Domains/Prefixes
// ============================================

model ReservedDomain {
  id        String             @id @default(cuid())
  pattern   String             @unique // The reserved domain or prefix pattern
  type      ReservedDomainType @default(EXACT)
  reason    String? // Why this is reserved (e.g., "Brand protection", "System use")
  createdBy String? // User ID who created this reservation
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

enum ReservedDomainType {
  EXACT // Exact match (e.g., "admin" blocks only "admin")
  PREFIX // Prefix match (e.g., "test-" blocks "test-anything")
}

// ============================================
// Platform Subscription & Billing
// ============================================

model SubscriptionPlan {
  id          String  @id @default(cuid())
  name        String // e.g., "Free", "Starter", "Gold", "Platinum"
  slug        String  @unique // URL-friendly identifier
  description String?

  // Pricing
  monthlyPrice      Decimal  @db.Decimal(10, 2)
  yearlyPrice       Decimal? @db.Decimal(10, 2) // Optional yearly discount
  transactionFee    Decimal  @db.Decimal(5, 4) // e.g., 0.029 for 2.9%
  perTransactionFee Decimal  @db.Decimal(10, 2) // e.g., 0.30 for $0.30

  // Limits
  maxAthletes Int? // null = unlimited
  maxUsers    Int? // null = unlimited
  maxPrograms Int? // null = unlimited
  maxEvents   Int? // null = unlimited

  // SMS Limits
  smsIncluded    Int? // Messages included per month (null = no SMS)
  smsOverageRate Decimal? @db.Decimal(10, 4) // Cost per message over limit (e.g., 0.05 for $0.05)

  // Email Limits
  emailIncluded    Int? // Emails included per month (null = no email campaigns)
  emailOverageRate Decimal? @db.Decimal(10, 4) // Cost per email over limit

  // Storage Limits
  maxStorageMB Int? // Storage in MB (null = unlimited)

  // Membership Limits
  maxMembershipTypes Int? // Max membership groups (null = unlimited)

  // Features (stored as JSON for flexibility)
  features Json // Array of feature strings

  // Display
  isPopular    Boolean @default(false)
  displayOrder Int     @default(0)

  // Status
  isActive Boolean @default(true)
  isPublic Boolean @default(true) // Can orgs self-select this plan?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  subscriptions OrganizationSubscription[]
}

model OrganizationSubscription {
  id             String @id @default(cuid())
  organizationId String @unique
  planId         String

  // Billing
  status             SubscriptionStatus @default(ACTIVE)
  billingCycle       BillingCycle       @default(MONTHLY)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  // Payment info (stored tokens, not actual card data)
  stripeCustomerId     String?
  stripeSubscriptionId String?

  // Adyen Payment Info
  adyenShopperReference   String? @unique // Unique ID for this org in Adyen
  adyenRecurringDetailRef String? // Primary payment method token ID

  // Admin controls
  isLocked     Boolean   @default(false) // If true, org cannot change plan
  lockedReason String? // Why it's locked (shown to org admins)
  lockedBy     String? // Super admin who locked it
  lockedAt     DateTime?

  // Trial
  trialEndsAt DateTime?

  // Cancellation
  cancelAtPeriodEnd Boolean   @default(false)
  cancelledAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  PAUSED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

// Organization Payment Methods - for SaaS subscription billing via Adyen
model OrganizationPaymentMethod {
  id             String @id @default(cuid())
  organizationId String

  // Adyen Token Info
  storedPaymentMethodId String @unique // Token from Adyen (storedPaymentMethodId)
  shopperReference      String // Links to org's Adyen identity

  // Card Display Info (safe to store - no sensitive data)
  type        String // "scheme", "sepadirectdebit", etc.
  brand       String? // "visa", "mc", "amex"
  lastFour    String // Last 4 digits of card
  expiryMonth String? // "03"
  expiryYear  String? // "2030"
  holderName  String? // Cardholder name

  // Status
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([shopperReference])
}

// ============================================
// PHASE 9: Staff & Scheduling
// ============================================

// Staff Profile - extends User with staff-specific data
model StaffProfile {
  id             String @id @default(cuid())
  userId         String @unique
  organizationId String

  // Employment
  employmentType EmploymentType @default(FULL_TIME)
  title          String? // e.g., "Head Coach", "Assistant Coach"
  hourlyRate     Decimal?       @db.Decimal(10, 2)
  hireDate       DateTime?

  // Certifications (JSON array for flexibility)
  certifications Json? // [{ name, expiresAt, verified }]

  // Contact (override user contact if needed)
  phone            String?
  emergencyContact Json? // { name, phone, relationship }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shifts             Shift[]
  availability       StaffAvailability[]
  eventAssignments   EventStaff[]
  programAssignments ProgramStaff[]

  @@index([organizationId])
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
  VOLUNTEER
}

// Event Staff - many-to-many with roles
model EventStaff {
  id             String         @id @default(cuid())
  eventId        String
  staffProfileId String
  role           EventStaffRole @default(ASSISTANT)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  staffProfile StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@unique([eventId, staffProfileId])
  @@index([eventId])
  @@index([staffProfileId])
}

enum EventStaffRole {
  LEAD
  ASSISTANT
  VOLUNTEER
  OBSERVER
}

// Program Staff - many-to-many with roles (coach assignments)
model ProgramStaff {
  id             String           @id @default(cuid())
  programId      String
  staffProfileId String
  role           ProgramStaffRole @default(ASSISTANT_COACH)
  isPrimary      Boolean          @default(false)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  program      Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  staffProfile StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@unique([programId, staffProfileId])
  @@index([programId])
  @@index([staffProfileId])
}

enum ProgramStaffRole {
  LEAD_COACH
  ASSISTANT_COACH
  SUBSTITUTE
  VOLUNTEER
}

// Work Shifts - one-time scheduling assignments
model Shift {
  id             String  @id @default(cuid())
  organizationId String
  staffProfileId String
  facilityId     String?

  // Time
  date      DateTime
  startTime String // "09:00"
  endTime   String // "17:00"

  // Role/Type
  shiftType String // e.g., "Opening Manager", "Coach", "Front Desk"
  notes     String?

  // Status
  status ShiftStatus @default(SCHEDULED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  staffProfile StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  facility     Facility?    @relation(fields: [facilityId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([staffProfileId])
  @@index([date])
}

enum ShiftStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// Recurring Schedule Templates - weekly patterns
model ScheduleTemplate {
  id             String  @id @default(cuid())
  organizationId String
  name           String // e.g., "Standard Week", "Summer Schedule"
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entries      ScheduleTemplateEntry[]

  @@index([organizationId])
}

model ScheduleTemplateEntry {
  id         String @id @default(cuid())
  templateId String

  dayOfWeek      Int // 0=Sunday, 1=Monday, ... 6=Saturday
  startTime      String // "09:00"
  endTime        String // "17:00"
  shiftType      String // Role/position type
  staffProfileId String? // Optional - can be unassigned
  facilityId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template ScheduleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

// Staff Availability - personal weekly availability
model StaffAvailability {
  id             String @id @default(cuid())
  staffProfileId String

  dayOfWeek   Int // 0=Sunday, 1=Monday, ... 6=Saturday
  startTime   String // "09:00"
  endTime     String // "17:00"
  isAvailable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffProfile StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@unique([staffProfileId, dayOfWeek]) // One entry per day per staff
  @@index([staffProfileId])
}

// ============================================
// PHASE 10: Registration Queue System
// ============================================

// Queue configuration per organization or program
model RegistrationQueueConfig {
  id             String  @id @default(cuid())
  organizationId String
  programId      String? // null = org-wide default

  // Queue settings
  isEnabled          Boolean @default(false)
  reservationMinutes Int     @default(10) // How long a spot is reserved
  maxConcurrent      Int     @default(50) // Max users in registration at once

  // Activation rules
  activationType      QueueActivationType @default(ALWAYS)
  activationThreshold Int? // For THRESHOLD type: activate when X users waiting
  scheduledStart      DateTime? // For SCHEDULED type
  scheduledEnd        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program      Program?     @relation(fields: [programId], references: [id], onDelete: Cascade)
  entries      QueueEntry[]

  @@unique([organizationId, programId])
  @@index([organizationId])
  @@index([programId])
}

enum QueueActivationType {
  ALWAYS // Queue always active when enabled
  THRESHOLD // Activate when concurrent users exceed threshold
  SCHEDULED // Active during scheduled time windows
}

// Track users waiting in queue
model QueueEntry {
  id            String @id @default(cuid())
  queueConfigId String
  sessionToken  String @unique // Browser session identifier

  // User info (may be anonymous until they identify)
  email    String?
  familyId String?

  // Queue status
  position Int // Current position in queue
  status   QueueEntryStatus @default(WAITING)

  // Timing
  enteredAt  DateTime  @default(now())
  admittedAt DateTime?
  exitedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  queueConfig RegistrationQueueConfig @relation(fields: [queueConfigId], references: [id], onDelete: Cascade)
  reservation QueueReservation?

  @@index([queueConfigId, status])
  @@index([sessionToken])
  @@index([status])
}

enum QueueEntryStatus {
  WAITING // In queue
  ADMITTED // Let through, has active reservation
  COMPLETED // Successfully registered
  EXPIRED // Reservation timed out
  ABANDONED // Left the queue
}

// Active reservations for users in registration
model QueueReservation {
  id           String @id @default(cuid())
  queueEntryId String @unique
  programId    String

  // Timing
  startedAt   DateTime  @default(now())
  expiresAt   DateTime
  completedAt DateTime?

  // Status
  status ReservationStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  queueEntry QueueEntry @relation(fields: [queueEntryId], references: [id], onDelete: Cascade)
  program    Program    @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId, status])
  @@index([expiresAt])
  @@index([status])
}

enum ReservationStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

// ============================================
// PHASE 11: Notification Rules System
// ============================================

// Notification trigger types - what events can trigger a notification
enum NotificationTriggerType {
  // Membership-related
  MEMBERSHIP_EXPIRY // Membership is expiring
  MEMBERSHIP_EXPIRED // Membership has expired

  // Payment-related
  PAYMENT_DUE // Payment is due
  PAYMENT_OVERDUE // Payment is overdue
  PAYMENT_RECEIVED // Payment was received

  // Program-related
  PROGRAM_REMINDER // Upcoming class/session reminder
  PROGRAM_ENROLLMENT // Athlete enrolled in program
  PROGRAM_CANCELLATION // Program/class cancelled

  // Event-related
  EVENT_REMINDER // Upcoming event reminder
  EVENT_REGISTRATION_OPEN // Registration opens for an event
  EVENT_REGISTRATION_CLOSE // Registration closing soon

  // Athlete-related
  ATTENDANCE_MISSED // Athlete missed attendance
  SKILL_ACHIEVED // New skill achievement
  EVALUATION_DUE // Evaluation is due
  EVALUATION_COMPLETED // Evaluation was completed
  BIRTHDAY // Athlete birthday

  // Administrative
  WAITLIST_OPENING // Spot available from waitlist
  CONTRACT_RENEWAL // Contract up for renewal
  MAKEUP_CLASS_EXPIRING // Makeup class credit expiring

  // Custom
  CUSTOM // Custom/manual trigger
}

// Action types - what happens when notification triggers
enum NotificationActionType {
  ANNOUNCEMENT // Post an in-app announcement
  EMAIL // Send an email
  SMS // Send an SMS message
  // PUSH                   // Push notification (future - for mobile app)
}

// Recipient types - who receives the notification
enum NotificationRecipientType {
  ALL_FAMILIES // All families in organization
  ALL_ATHLETES // All athletes (via their guardians)
  PROGRAM_MEMBERS // Athletes/families in specific programs
  MEMBERSHIP_HOLDERS // Athletes with specific memberships
  INTERNAL_USERS // Staff, coaches, admins
  CUSTOM // Custom filter combination
}

// Timing direction - before or after the trigger event
enum NotificationTimingDirection {
  BEFORE // X days/hours before event
  AFTER // X days/hours after event
  AT // At the time of event (0 offset)
}

// Timing unit
enum NotificationTimingUnit {
  MINUTES
  HOURS
  DAYS
  WEEKS
  MONTHS
}

// Notification Rule - defines when and how to send notifications
model NotificationRule {
  id             String @id @default(cuid())
  organizationId String

  // Rule identification
  name        String
  description String? @db.Text

  // Trigger configuration
  triggerType NotificationTriggerType

  // Timing configuration
  timingValue     Int                         @default(0) // e.g., 3 (days)
  timingUnit      NotificationTimingUnit      @default(DAYS)
  timingDirection NotificationTimingDirection @default(BEFORE)

  // Action configuration
  actionType NotificationActionType

  // System flag - true for mandatory rules that cannot be disabled/deleted
  isSystem Boolean @default(false)

  // Status
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization         Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template             NotificationTemplate?
  recipientConfig      NotificationRecipientConfig?
  logs                 NotificationLog[]
  deduplicationRecords NotificationDeduplication[]

  @@index([organizationId])
  @@index([triggerType])
  @@index([isSystem])
  @@index([isActive])
}

// Notification Template - the message content with placeholders
model NotificationTemplate {
  id                 String @id @default(cuid())
  notificationRuleId String @unique

  // Email-specific fields
  subject String? // Email subject line (with placeholders)

  // Message content
  body String @db.Text // Main message body (with placeholders)

  // SMS-specific (shorter version)
  smsBody String? @db.Text // SMS-optimized version (shorter)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  notificationRule NotificationRule @relation(fields: [notificationRuleId], references: [id], onDelete: Cascade)
}

// Notification Recipient Config - who receives the notification
model NotificationRecipientConfig {
  id                 String @id @default(cuid())
  notificationRuleId String @unique

  // Primary recipient type
  recipientType NotificationRecipientType @default(ALL_FAMILIES)

  // Filters (JSON for flexibility)
  // Structure: {
  //   programIds?: string[],
  //   membershipGroupIds?: string[],
  //   membershipStatuses?: string[],
  //   athleteStatuses?: string[],
  //   userRoles?: string[],
  //   includeInactive?: boolean
  // }
  filters Json?

  // Include CC recipients (e.g., always CC the admin)
  ccEmails String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  notificationRule NotificationRule @relation(fields: [notificationRuleId], references: [id], onDelete: Cascade)
}

// Notification Log - tracks sent notifications for auditing
model NotificationLog {
  id                 String  @id @default(cuid())
  organizationId     String
  notificationRuleId String?

  // What was sent
  triggerType NotificationTriggerType
  actionType  NotificationActionType

  // Who received it
  recipientEmail String?
  recipientPhone String?
  recipientName  String?
  familyId       String?
  athleteId      String?
  userId         String?

  // Message content (rendered)
  subject String?
  body    String  @db.Text

  // Status
  status NotificationLogStatus @default(PENDING)

  // Links to actual message records
  emailMessageId String?
  smsMessageId   String?
  announcementId String?

  // Error tracking
  errorMessage String? @db.Text

  // Timing
  scheduledFor DateTime?
  sentAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notificationRule NotificationRule? @relation(fields: [notificationRuleId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([notificationRuleId])
  @@index([status])
  @@index([triggerType])
  @@index([createdAt])
  @@index([familyId])
  @@index([athleteId])
}

enum NotificationLogStatus {
  PENDING // Queued but not sent
  SENT // Successfully sent
  DELIVERED // Confirmed delivered
  FAILED // Failed to send
  SKIPPED // Skipped (e.g., recipient opted out)
}

// Notification Deduplication - prevents sending same notification twice for same entity
model NotificationDeduplication {
  id         String   @id @default(cuid())
  ruleId     String
  entityType String // "membership", "invoice", "event", "athlete" (for birthday), etc.
  entityId   String // The specific entity ID
  familyId   String
  sentAt     DateTime @default(now())

  // Relations
  rule NotificationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, entityType, entityId, familyId])
  @@index([ruleId])
  @@index([sentAt])
}

// ============================================
// PHASE 12: Waivers & Digital Signatures
// ============================================

enum WaiverStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// Waiver - top-level waiver entity owned by an organization
model Waiver {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  status         WaiverStatus @default(DRAFT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  organization        Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pages               WaiverPage[]
  programRequirements ProgramWaiverRequirement[]
  signatures          WaiverSignature[]
  acceptances         WaiverAcceptance[]

  @@index([organizationId])
  @@index([status])
}

// WaiverPage - individual page of a waiver with rich text content
model WaiverPage {
  id         String  @id @default(cuid())
  waiverId   String
  pageNumber Int // Ordering: 1, 2, 3...
  title      String? // Optional page title (e.g., "Section A: Liability")
  content    String  @db.Text // HTML content from WYSIWYG editor

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  waiver     Waiver            @relation(fields: [waiverId], references: [id], onDelete: Cascade)
  signatures WaiverSignature[]

  @@index([waiverId])
  @@index([waiverId, pageNumber])
}

// ProgramWaiverRequirement - junction table linking Programs to required Waivers
model ProgramWaiverRequirement {
  id        String   @id @default(cuid())
  programId String
  waiverId  String
  createdAt DateTime @default(now())

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  waiver  Waiver  @relation(fields: [waiverId], references: [id], onDelete: Cascade)

  @@unique([programId, waiverId])
  @@index([programId])
  @@index([waiverId])
}

// WaiverSignature - records a customer's signature on a specific waiver page
model WaiverSignature {
  id            String   @id @default(cuid())
  waiverId      String
  waiverPageId  String
  familyId      String
  athleteId     String?  // The athlete this signature is for (waivers are per-athlete)
  signatureData String   @db.Text // Base64 PNG from signature canvas
  signedByName  String // Full name of signer
  signedByEmail String // Email of signer
  ipAddress     String? // IP address at time of signing
  userAgent     String? // Browser user agent at time of signing
  signedAt      DateTime @default(now())

  // Relations
  waiver     Waiver     @relation(fields: [waiverId], references: [id], onDelete: Cascade)
  waiverPage WaiverPage @relation(fields: [waiverPageId], references: [id], onDelete: Cascade)
  family     Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  athlete    Athlete?   @relation(fields: [athleteId], references: [id], onDelete: SetNull)

  @@unique([waiverPageId, familyId, athleteId]) // One signature per page per family per athlete
  @@index([waiverId])
  @@index([waiverPageId])
  @@index([familyId])
  @@index([athleteId])
}

// WaiverAcceptance - rolled-up record: family has fully signed all pages of a waiver
// This is the table queried to check "has this customer already signed?" for sign-once behavior
model WaiverAcceptance {
  id          String   @id @default(cuid())
  waiverId    String
  familyId    String
  athleteId   String?  // The athlete this acceptance is for (waivers are per-athlete)
  completedAt DateTime @default(now())

  // Relations
  waiver  Waiver   @relation(fields: [waiverId], references: [id], onDelete: Cascade)
  family  Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  athlete Athlete? @relation(fields: [athleteId], references: [id], onDelete: SetNull)

  @@unique([waiverId, familyId, athleteId]) // One acceptance per waiver per family per athlete
  @@index([waiverId])
  @@index([familyId])
  @@index([athleteId])
}
